; Example Vibe program demonstrating new bitcode primitives

; Define a type (using vertical bar delimited symbols for LLVM types)
(define-bitcode-type Point (x |i32|) (y |i32|))

; Define a constant (using vertical bar for type, bytevector for value)
(define-bitcode-constant hello_string |[14 x i8]| #u8(72 101 108 108 111 44 32 87 111 114 108 100 33 0))

; Define a function with typed parameters using DSL (new approach)
; Note: For now, we inline the GEP in the call since we don't have let binding yet
(define-llvm-function (hello (name |i8*|)) |void|
  (llvm-call (llvm-get-function "printf") (list (llvm-gep |[14 x i8]*| (llvm-get-global "hello_string") (list (llvm-const-int |i32| 0) (llvm-const-int |i32| 0)) "") name) "")
  (llvm-ret-void))

; Call the function
(hello "World")
