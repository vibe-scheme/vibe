;; ============================================================================
;; codegen_eval_dsl_list: Evaluate list of DSL expressions to array
;; Parameters: cg, list (AST), array (LLVMValueRef*), max_count
;; Returns: number of elements evaluated
;; ============================================================================
(llvm:define-function (codegen_eval_dsl_list (cg |%CodeGen*|) (list |%ASTNode*|) (array |i8*|) (max_count |i32|)) |i32|
  (let* ((count_ptr (llvm:alloca |i32|))
         (current_ptr (llvm:alloca |%ASTNode*|))
         (i_ptr (llvm:alloca |i32|))
         (current_eval_ptr (llvm:alloca |%ASTNode*|)))
    (llvm:label 'entry
      (let* ((list_null (llvm:icmp 'eq list (llvm:const-null |%ASTNode*|))))
        (llvm:br list_null 'return_zero 'count_loop)))
    (llvm:label 'return_zero
      (llvm:ret (llvm:const-int |i32| 0)))
    (llvm:label 'count_loop
      (llvm:store (llvm:const-int |i32| 0) count_ptr)
      (llvm:store list current_ptr)
      (llvm:br 'count_iter))
    (llvm:label 'count_iter
      (let* ((current_val (llvm:load current_ptr |%ASTNode*|))
             (current_null (llvm:icmp 'eq current_val (llvm:const-null |%ASTNode*|))))
        (llvm:br current_null 'eval_loop 'count_inc)))
    (llvm:label 'count_inc
      (let* ((count_val (llvm:load count_ptr |i32|))
             (count_new (llvm:add count_val (llvm:const-int |i32| 1)))
             (current_val (llvm:load current_ptr |%ASTNode*|))
             (current_cdr_ptr (llvm:gep |%ASTNode| current_val 0 5))
             (current_cdr (llvm:load current_cdr_ptr |%ASTNode*|)))
        (llvm:store count_new count_ptr)
        (llvm:store current_cdr current_ptr)
        (llvm:br 'count_iter)))
    (llvm:label 'eval_loop
      (let* ((count_final (llvm:load count_ptr |i32|))
             (count_ge_max (llvm:icmp 'uge count_final max_count)))
        (llvm:br count_ge_max 'cap_count 'eval_elements)))
    (llvm:label 'cap_count
      (llvm:store max_count count_ptr)
      (llvm:br 'eval_elements))
    (llvm:label 'eval_elements
      (llvm:store (llvm:const-int |i32| 0) i_ptr)
      (llvm:store list current_eval_ptr)
      (llvm:br 'eval_iter))
    (llvm:label 'eval_iter
      (let* ((i_val (llvm:load i_ptr |i32|))
             (count_check (llvm:load count_ptr |i32|))
             (done (llvm:icmp 'uge i_val count_check)))
        (llvm:br done 'return_count 'eval_current)))
    (llvm:label 'eval_current
      (let* ((current_eval_val (llvm:load current_eval_ptr |%ASTNode*|))
             (car_ptr (llvm:gep |%ASTNode| current_eval_val 0 4))
             (car (llvm:load car_ptr |%ASTNode*|))
             (value (llvm:call codegen_eval_dsl_expr cg car))
             (i_val_for_idx (llvm:load i_ptr |i32|))
             (array_idx (llvm:gep |i8*| array i_val_for_idx)))
        (llvm:store value array_idx)
        (let* ((i_val_after (llvm:load i_ptr |i32|))
               (i_new (llvm:add i_val_after (llvm:const-int |i32| 1)))
               (cdr_ptr (llvm:gep |%ASTNode| current_eval_val 0 5))
               (cdr (llvm:load cdr_ptr |%ASTNode*|)))
          (llvm:store i_new i_ptr)
          (llvm:store cdr current_eval_ptr)
          (llvm:br 'eval_iter))))
    (llvm:label 'return_count
      (llvm:ret (llvm:load count_ptr |i32|)))))

