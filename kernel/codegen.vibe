  (llvm:label 'return_slt
    (llvm:ret (llvm:const-int |i32| 40)))
  (llvm:label 'check_sgt
    (let* ((is_sgt (llvm:call codegen_dsl_check_primitive pred_str pred_len (llvm:gep |[4 x i8]| (llvm:get-global .str.pred_sgt) 0 0) (llvm:const-int |i64| 3)))
           (is_sgt_bool (llvm:icmp 'ne is_sgt (llvm:const-int |i32| 0))))
