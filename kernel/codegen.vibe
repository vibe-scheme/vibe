         (gep_result_ptr (llvm:alloca |i8*|)))
    (llvm:label 'entry
      (let* ((module (llvm:load (llvm:gep |%CodeGen| cg 0 6) |i8*|))
             (builder (llvm:load (llvm:gep |%CodeGen| cg 0 7) |i8*|))
             (module_null (llvm:icmp 'eq module (llvm:const-null |i8*|)))
             (builder_null (llvm:icmp 'eq builder (llvm:const-null |i8*|)))
             (either_null (llvm:or module_null builder_null)))
        (llvm:store (llvm:const-null |i8*|) func_val_ptr)
        (llvm:store (llvm:const-null |i8*|) func_type_val_ptr)
        (llvm:store (llvm:const-int |i32| 0) args_count_ptr)
        (llvm:store (llvm:const-null |i8*|) gep_result_ptr)
        (llvm:br either_null 'text_only 'lookup_func)))
    (llvm:label 'lookup_func
      (let* ((func_name_len (llvm:call strlen func_name))
             (found_tracked (llvm:call codegen_get_llvm_function cg func_name func_name_len func_val_ptr func_type_val_ptr))
             (is_tracked (llvm:icmp 'ne found_tracked (llvm:const-int |i32| 0))))
        (llvm:br is_tracked 'build_call 'lookup_in_module)))
    (llvm:label 'lookup_in_module
      (let* ((module (llvm:load (llvm:gep |%CodeGen| cg 0 6) |i8*|))
             (func (llvm:call llvm_get_named_function module func_name))
             (func_null (llvm:icmp 'eq func (llvm:const-null |i8*|))))
        (llvm:br func_null 'return_error 'get_func_type_legacy)))
    (llvm:label 'get_func_type_legacy
      (let* ((module (llvm:load (llvm:gep |%CodeGen| cg 0 6) |i8*|))
             (func (llvm:call llvm_get_named_function module func_name))
             (func_ptr_type (llvm:call llvm_type_of func))
             (func_type_legacy (llvm:call llvm_get_element_type func_ptr_type)))
        (llvm:store func func_val_ptr)
        (llvm:store func_type_legacy func_type_val_ptr)
        (llvm:br 'build_call)))
    (llvm:label 'return_error
      (llvm:ret (llvm:const-int |i32| -1)))
    (llvm:label 'build_call
      (let* ((args_null (llvm:icmp 'eq args (llvm:const-null |%ASTNode*|))))
        (llvm:br args_null 'call_func 'get_first_arg)))
    (llvm:label 'get_first_arg
      (let* ((arg_node (llvm:load (llvm:gep |%ASTNode| args 0 4) |%ASTNode*|))
             (arg_type (llvm:load (llvm:gep |%ASTNode| arg_node 0 0) |i32|))
             (is_atom (llvm:icmp 'eq arg_type (llvm:const-int |i32| 0))))
        (llvm:br is_atom 'check_string_type 'call_func)))
    (llvm:label 'check_string_type
      (let* ((arg_node (llvm:load (llvm:gep |%ASTNode| args 0 4) |%ASTNode*|))
             (atom_type (llvm:load (llvm:gep |%ASTNode| arg_node 0 1) |i32|))
             (is_string (llvm:icmp 'eq atom_type (llvm:const-int |i32| 3))))
        (llvm:br is_string 'build_string_arg 'call_func)))
    (llvm:label 'build_string_arg
      (let* ((arg_node (llvm:load (llvm:gep |%ASTNode| args 0 4) |%ASTNode*|))
             (str_val (llvm:load (llvm:gep |%ASTNode| arg_node 0 2) |i8*|))
             (str_len (llvm:load (llvm:gep |%ASTNode| arg_node 0 3) |i64|))
             (const_name (llvm:call codegen_get_string_constant_name cg str_val str_len))
             (module (llvm:load (llvm:gep |%CodeGen| cg 0 6) |i8*|))
             (global (llvm:call llvm_get_named_global module const_name))
             (global_null (llvm:icmp 'eq global (llvm:const-null |i8*|))))
        (llvm:br global_null 'call_func 'build_gep)))
    (llvm:label 'build_gep
      (let* ((arg_node (llvm:load (llvm:gep |%ASTNode| args 0 4) |%ASTNode*|))
             (str_val (llvm:load (llvm:gep |%ASTNode| arg_node 0 2) |i8*|))
             (str_len (llvm:load (llvm:gep |%ASTNode| arg_node 0 3) |i64|))
             (context (llvm:load (llvm:gep |%CodeGen| cg 0 5) |i8*|))
             (builder (llvm:load (llvm:gep |%CodeGen| cg 0 7) |i8*|))
             (i8_type (llvm:call llvm_get_int8_type context))
             (i32_type (llvm:call llvm_get_int32_type context))
             (len_plus_one (llvm:add str_len (llvm:const-int |i64| 1)))
             (len_plus_one_int (llvm:trunc len_plus_one |i64| |i32|))
             (array_type (llvm:call llvm_get_array_type i8_type len_plus_one_int))
             (zero_const (llvm:call llvm_create_constant_int i32_type (llvm:const-int |i64| 0) (llvm:const-int |i32| 0))))
        (llvm:store zero_const (llvm:gep |i8*| arg_array 0))
        (let* ((const_name (llvm:call codegen_get_string_constant_name cg str_val str_len))
               (module (llvm:load (llvm:gep |%CodeGen| cg 0 6) |i8*|))
               (global (llvm:call llvm_get_named_global module const_name))
               (empty_str (llvm:gep |[1 x i8]| (llvm:get-global .str.empty) 0 0))
               (indices_buf (llvm:call malloc (llvm:const-int |i64| 16)))
               (indices_typed (llvm:bitcast indices_buf |i8**|)))
          (llvm:store zero_const (llvm:gep |i8*| indices_typed 0))
          (llvm:store zero_const (llvm:gep |i8*| indices_typed 1))
          (let* ((gep (llvm:call llvm_build_gep builder array_type global indices_typed (llvm:const-int |i32| 2) empty_str))
                 (gep_null (llvm:icmp 'eq gep (llvm:const-null |i8*|))))
            (llvm:call free indices_buf)
            (llvm:store gep arg_array)
            (llvm:store (llvm:const-int |i32| 1) args_count_ptr)
            (llvm:br gep_null 'call_func_no_args 'call_func)))))
    (llvm:label 'call_func_no_args
      (llvm:store (llvm:const-int |i32| 0) args_count_ptr)
      (llvm:br 'call_func))
    (llvm:label 'call_func
      (let* ((func_type_val (llvm:load func_type_val_ptr |i8*|))
             (func_type_null (llvm:icmp 'eq func_type_val (llvm:const-null |i8*|))))
        (llvm:br func_type_null 'text_only 'build_call_inst)))
    (llvm:label 'build_call_inst
      (let* ((builder (llvm:load (llvm:gep |%CodeGen| cg 0 7) |i8*|))
             (func_val (llvm:load func_val_ptr |i8*|))
             (func_type_val (llvm:load func_type_val_ptr |i8*|))
             (ac (llvm:load args_count_ptr |i32|))
             (empty_str (llvm:gep |[1 x i8]| (llvm:get-global .str.empty) 0 0))
             (call_result (llvm:call llvm_build_call builder func_type_val func_val arg_array ac empty_str)))
        (llvm:br 'done)))
    (llvm:label 'text_only
      (let* ((call_void (llvm:gep |[10 x i8]| (llvm:get-global .str.call_void) 0 0))
             (space (llvm:gep |[2 x i8]| (llvm:get-global .str.space) 0 0))
             (at_sign (llvm:gep |[2 x i8]| (llvm:get-global .str.at_sign) 0 0))
             (lparen (llvm:gep |[2 x i8]| (llvm:get-global .str.lparen) 0 0))
             (rparen (llvm:gep |[2 x i8]| (llvm:get-global .str.rparen) 0 0))
             (func_name_len (llvm:call strlen func_name)))
        (llvm:call codegen_append cg call_void (llvm:const-int |i64| 9))
        (llvm:call codegen_append cg space (llvm:const-int |i64| 1))
        (llvm:call codegen_append cg at_sign (llvm:const-int |i64| 1))
        (llvm:call codegen_append cg func_name func_name_len)
        (llvm:call codegen_append cg lparen (llvm:const-int |i64| 1))
        (llvm:call codegen_append_call_args cg args)
        (llvm:call codegen_append cg rparen (llvm:const-int |i64| 1))
        (llvm:br 'done)))
    (llvm:label 'done
      (llvm:ret (llvm:const-int |i32| 0)))))

;; ============================================================================
;; codegen_dsl_call: Handle llvm:call DSL form
;; Parameters: cg (CodeGen*), args (ASTNode*) — args is (func-name arg1 arg2 ...)
;; Returns: LLVMValueRef for call result, or null on error
;; ============================================================================
(llvm:define-function (codegen_dsl_call (cg |%CodeGen*|) (args |%ASTNode*|)) |i8*|
  (let* ((func_type_ptr (llvm:alloca |i8*|))
         (args_to_eval_ptr (llvm:alloca |%ASTNode*|))
         (name_str_ptr (llvm:alloca |i8*|))
         (args_array_ptr (llvm:alloca |i8*|))
         (func_ptr (llvm:alloca |i8*|))
         (arg_count_ptr (llvm:alloca |i32|))
         (validate_i_ptr (llvm:alloca |i32|)))
    (llvm:label 'entry
      (let* ((builder (llvm:load (llvm:gep |%CodeGen| cg 0 7) |i8*|))
             (builder_null (llvm:icmp 'eq builder (llvm:const-null |i8*|))))
        (llvm:store (llvm:const-null |i8*|) func_type_ptr)
        (llvm:store (llvm:const-null |%ASTNode*|) args_to_eval_ptr)
        (llvm:store (llvm:const-null |i8*|) args_array_ptr)
        (llvm:store (llvm:const-null |i8*|) func_ptr)
        (llvm:store (llvm:const-int |i32| 0) arg_count_ptr)
        (llvm:br builder_null 'error 'get_func)))
    (llvm:label 'get_func
      (let* ((args_null (llvm:icmp 'eq args (llvm:const-null |%ASTNode*|))))
        (llvm:br args_null 'error 'get_func_node)))
    (llvm:label 'get_func_node
      (let* ((func_node (llvm:load (llvm:gep |%ASTNode| args 0 4) |%ASTNode*|))
             (func (llvm:call codegen_eval_dsl_expr cg func_node))
             (func_null (llvm:icmp 'eq func (llvm:const-null |i8*|))))
        (llvm:store func func_ptr)
        (llvm:br func_null 'error 'get_func_type)))
    (llvm:label 'get_func_type
      (let* ((func_val (llvm:load func_ptr |i8*|))
             (stored_func_type (llvm:call codegen_get_function_type_by_value cg func_val))
             (has_stored_type (llvm:icmp 'ne stored_func_type (llvm:const-null |i8*|))))
        (llvm:br has_stored_type 'use_stored_func_type 'fallback_to_llvm_typeof)))
    (llvm:label 'use_stored_func_type
      (let* ((func_val (llvm:load func_ptr |i8*|))
             (stored_ft (llvm:call codegen_get_function_type_by_value cg func_val)))
        (llvm:store stored_ft func_type_ptr)
        (llvm:br 'get_args_list)))
    (llvm:label 'fallback_to_llvm_typeof
      (let* ((func_val (llvm:load func_ptr |i8*|))
             (func_type_from_value (llvm:call llvm_type_of func_val))
             (ft_null (llvm:icmp 'eq func_type_from_value (llvm:const-null |i8*|))))
        (llvm:store func_type_from_value func_type_ptr)
        (llvm:br ft_null 'error 'get_args_list)))
    (llvm:label 'get_args_list
      (let* ((ft_check (llvm:load func_type_ptr |i8*|))
             (ft_null (llvm:icmp 'eq ft_check (llvm:const-null |i8*|))))
        (llvm:br ft_null 'error 'extract_args)))
    (llvm:label 'extract_args
      (let* ((args_list_raw (llvm:load (llvm:gep |%ASTNode| args 0 5) |%ASTNode*|))
             (args_list_null (llvm:icmp 'eq args_list_raw (llvm:const-null |%ASTNode*|))))
        (llvm:store args_list_raw args_to_eval_ptr)
        (llvm:br args_list_null 'eval_args 'check_args_list_form)))
    (llvm:label 'check_args_list_form
      (let* ((args_list_raw (llvm:load args_to_eval_ptr |%ASTNode*|))
             (args_car (llvm:load (llvm:gep |%ASTNode| args_list_raw 0 4) |%ASTNode*|))
             (args_car_type (llvm:load (llvm:gep |%ASTNode| args_car 0 0) |i32|))
             (is_atom (llvm:icmp 'eq args_car_type (llvm:const-int |i32| 0))))
        (llvm:br is_atom 'check_list_name_args 'eval_args)))
    (llvm:label 'check_list_name_args
      (let* ((args_list_raw (llvm:load args_to_eval_ptr |%ASTNode*|))
             (args_car (llvm:load (llvm:gep |%ASTNode| args_list_raw 0 4) |%ASTNode*|))
             (list_name (llvm:load (llvm:gep |%ASTNode| args_car 0 2) |i8*|))
             (list_name_len (llvm:load (llvm:gep |%ASTNode| args_car 0 3) |i64|))
             (dsl_array_str (llvm:gep |[11 x i8]| (llvm:get-global .str.dsl_array) 0 0))
             (is_array (llvm:call codegen_dsl_check_primitive list_name list_name_len dsl_array_str (llvm:const-int |i64| 10)))
             (is_array_bool (llvm:icmp 'ne is_array (llvm:const-int |i32| 0))))
        (llvm:br is_array_bool 'get_array_args 'check_list_form_args)))
    (llvm:label 'check_list_form_args
      (let* ((args_list_raw (llvm:load args_to_eval_ptr |%ASTNode*|))
             (args_car (llvm:load (llvm:gep |%ASTNode| args_list_raw 0 4) |%ASTNode*|))
             (list_name (llvm:load (llvm:gep |%ASTNode| args_car 0 2) |i8*|))
             (list_name_len (llvm:load (llvm:gep |%ASTNode| args_car 0 3) |i64|))
             (dsl_list_str (llvm:gep |[5 x i8]| (llvm:get-global .str.dsl_list) 0 0))
             (is_list (llvm:call codegen_dsl_check_primitive list_name list_name_len dsl_list_str (llvm:const-int |i64| 4)))
             (is_list_bool (llvm:icmp 'ne is_list (llvm:const-int |i32| 0))))
        (llvm:br is_list_bool 'get_list_args 'eval_args)))
    (llvm:label 'get_array_args
      (let* ((args_list_raw (llvm:load args_to_eval_ptr |%ASTNode*|))
             (inner_args (llvm:load (llvm:gep |%ASTNode| args_list_raw 0 5) |%ASTNode*|)))
        (llvm:store inner_args args_to_eval_ptr)
        (llvm:br 'eval_args)))
    (llvm:label 'get_list_args
      (let* ((args_list_raw (llvm:load args_to_eval_ptr |%ASTNode*|))
             (inner_args (llvm:load (llvm:gep |%ASTNode| args_list_raw 0 5) |%ASTNode*|)))
        (llvm:store inner_args args_to_eval_ptr)
        (llvm:br 'eval_args)))
    (llvm:label 'eval_args
      (let* ((args_to_eval (llvm:load args_to_eval_ptr |%ASTNode*|))
             (args_buf (llvm:call malloc (llvm:const-int |i64| 80)))
             (args_buf_typed (llvm:bitcast args_buf |i8**|))
             (arg_count (llvm:call codegen_eval_dsl_list cg args_to_eval args_buf_typed (llvm:const-int |i32| 10)))
             (empty_str (llvm:gep |[1 x i8]| (llvm:get-global .str.empty) 0 0)))
        (llvm:store args_buf args_array_ptr)
        (llvm:store empty_str name_str_ptr)
        (llvm:store arg_count arg_count_ptr)
        (llvm:br 'build_call)))
    (llvm:label 'build_call
      (let* ((fv (llvm:load func_ptr |i8*|))
             (func_null (llvm:icmp 'eq fv (llvm:const-null |i8*|))))
        (llvm:br func_null 'error_with_free 'check_func_type_again)))
    (llvm:label 'check_func_type_again
      (let* ((ft (llvm:load func_type_ptr |i8*|))
             (ft_null (llvm:icmp 'eq ft (llvm:const-null |i8*|))))
        (llvm:br ft_null 'error_with_free 'do_call)))
    (llvm:label 'do_call
      (let* ((ac (llvm:load arg_count_ptr |i32|))
             (arg_count_zero (llvm:icmp 'eq ac (llvm:const-int |i32| 0))))
        (llvm:br arg_count_zero 'call_with_no_args 'validate_args)))
    (llvm:label 'validate_args
      (llvm:store (llvm:const-int |i32| 0) validate_i_ptr)
      (llvm:br 'validate_loop))
    (llvm:label 'validate_loop
      (let* ((i_val (llvm:load validate_i_ptr |i32|))
             (ac (llvm:load arg_count_ptr |i32|))
             (done (llvm:icmp 'uge i_val ac)))
        (llvm:br done 'call_with_args 'check_arg)))
    (llvm:label 'check_arg
      (let* ((i_val (llvm:load validate_i_ptr |i32|))
             (abuf (llvm:load args_array_ptr |i8*|))
             (abuf_typed (llvm:bitcast abuf |i8**|))
             (arg_addr (llvm:gep |i8*| abuf_typed i_val))
             (arg_val (llvm:load arg_addr |i8*|))
             (arg_null (llvm:icmp 'eq arg_val (llvm:const-null |i8*|))))
        (llvm:br arg_null 'arg_error 'next_arg)))
    (llvm:label 'next_arg
      (let* ((i_val (llvm:load validate_i_ptr |i32|))
             (i_new (llvm:add i_val (llvm:const-int |i32| 1))))
        (llvm:store i_new validate_i_ptr)
        (llvm:br 'validate_loop)))
    (llvm:label 'arg_error
      (let* ((abuf (llvm:load args_array_ptr |i8*|)))
        (llvm:call free abuf)
        (llvm:br 'error)))
    (llvm:label 'call_with_no_args
      (let* ((builder (llvm:load (llvm:gep |%CodeGen| cg 0 7) |i8*|))
             (ft (llvm:load func_type_ptr |i8*|))
             (fv (llvm:load func_ptr |i8*|))
             (name (llvm:load name_str_ptr |i8*|))
             (result (llvm:call llvm_build_call builder ft fv (llvm:const-null |i8*|) (llvm:const-int |i32| 0) name))
             (abuf (llvm:load args_array_ptr |i8*|)))
        (llvm:call free abuf)
        (llvm:ret result)))
    (llvm:label 'call_with_args
      (let* ((builder (llvm:load (llvm:gep |%CodeGen| cg 0 7) |i8*|))
             (ft (llvm:load func_type_ptr |i8*|))
             (fv (llvm:load func_ptr |i8*|))
             (name (llvm:load name_str_ptr |i8*|))
             (abuf (llvm:load args_array_ptr |i8*|))
             (abuf_typed (llvm:bitcast abuf |i8**|))
             (ac (llvm:load arg_count_ptr |i32|))
             (result (llvm:call llvm_build_call builder ft fv abuf_typed ac name)))
        (llvm:call free abuf)
        (llvm:ret result)))
    (llvm:label 'error_with_free
      (let* ((abuf (llvm:load args_array_ptr |i8*|))
             (abuf_null (llvm:icmp 'eq abuf (llvm:const-null |i8*|))))
        (llvm:br abuf_null 'error 'free_and_error)))
    (llvm:label 'free_and_error
      (let* ((abuf (llvm:load args_array_ptr |i8*|)))
        (llvm:call free abuf)
        (llvm:br 'error)))
    (llvm:label 'error
      (llvm:ret (llvm:const-null |i8*|)))))

