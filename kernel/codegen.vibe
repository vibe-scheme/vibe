      (llvm:store function_types current_pair)
      (llvm:br 'iterate))
    (llvm:label 'iterate
      (let* ((pair_val (llvm:load current_pair |%ASTNode*|))
             (pair_null (llvm:icmp 'eq pair_val (llvm:const-null |%ASTNode*|))))
        (llvm:br pair_null 'not_found 'check_name)))
    (llvm:label 'check_name
      (let* ((pair_val (llvm:load current_pair |%ASTNode*|))
             (pair_car_ptr (llvm:gep |%ASTNode| pair_val 0 4))
             (name_node (llvm:load pair_car_ptr |%ASTNode*|))
             (stored_name_ptr (llvm:gep |%ASTNode| name_node 0 2))
             (stored_name (llvm:load stored_name_ptr |i8*|))
