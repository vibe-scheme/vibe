;; Codegen utilities migrated to Vibe DSL (Batch 1 + Batch 2)
;; These functions handle AST node creation, integer parsing, type checking,
;; buffer management, string constant collection, and predicate mapping.
;; Struct types come from the build-time prefix (types.vibe).

;; ============================================================================
;; C library: malloc/realloc/memcpy/free/strncmp via ffi_libc_darwin.vibe prefix.
;; strlen remains a plain declare (link-time libc).
;; ============================================================================
(llvm:declare-function (strlen (s |i8*|)) |i64|)

