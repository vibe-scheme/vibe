      (let* ((func_ptr (llvm:gep |%CodeGen| cg 0 8))
             (func (llvm:load func_ptr |i8*|))
             (label_name (llvm:load label_name_out |i8*|))
             (label_len (llvm:load label_len_out |i64|))
             (block (llvm:call codegen_get_or_create_label cg func label_name label_len))
             (block_null (llvm:icmp 'eq block (llvm:const-null |i8*|))))
        (llvm:store block block_ptr)
        (llvm:store block_null block_null_ptr)
        (llvm:br 'get_or_create_block_br)))
    (llvm:label 'get_or_create_block_br
      (let* ((block_null (llvm:load block_null_ptr |i1|)))
        (llvm:br block_null 'error 'position_builder)))
    (llvm:label 'position_builder
      (let* ((builder_ptr (llvm:gep |%CodeGen| cg 0 7))
             (builder (llvm:load builder_ptr |i8*|))
             (block (llvm:load block_ptr |i8*|))
             (saved_block (llvm:call llvm_get_insert_block builder))
             (args_cdr_ptr (llvm:gep |%ASTNode| args 0 5))
             (body (llvm:load args_cdr_ptr |%ASTNode*|)))
