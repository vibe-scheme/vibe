           (first_type_ptr (llvm:gep |%ASTNode| first 0 0))
           (first_type (llvm:load first_type_ptr |i32|))
           (first_is_atom (llvm:icmp 'eq first_type (llvm:const-int |i32| 0))))
      (llvm:br first_is_atom 'gen_call 'next_expr)))
  (llvm:label 'gen_call
    (let* ((car_ptr (llvm:gep |%ASTNode| exprs 0 4))
           (expr (llvm:load car_ptr |%ASTNode*|))
           (expr_car_ptr (llvm:gep |%ASTNode| expr 0 4))
           (first (llvm:load expr_car_ptr |%ASTNode*|))
           (func_name_val_ptr (llvm:gep |%ASTNode| first 0 2))
           (func_name (llvm:load func_name_val_ptr |i8*|))
           (expr_cdr_ptr (llvm:gep |%ASTNode| expr 0 5))
           (args (llvm:load expr_cdr_ptr |%ASTNode*|))
           (call_result (llvm:call codegen_call cg func_name args))
           (call_failed (llvm:icmp 'ne call_result (llvm:const-int |i32| 0))))
      (llvm:br call_failed 'next_expr 'next_expr)))
