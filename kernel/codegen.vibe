           (is_ule_bool (llvm:icmp 'ne is_ule (llvm:const-int |i32| 0))))
      (llvm:br is_ule_bool 'return_ule 'check_sge)))
  (llvm:label 'return_ule
    (llvm:ret (llvm:const-int |i32| 37)))
  (llvm:label 'check_sge
    (let* ((is_sge (llvm:call codegen_dsl_check_primitive pred_str pred_len (llvm:gep |[4 x i8]| (llvm:get-global .str.pred_sge) 0 0) (llvm:const-int |i64| 3)))
           (is_sge_bool (llvm:icmp 'ne is_sge (llvm:const-int |i32| 0))))
      (llvm:br is_sge_bool 'return_sge 'check_slt)))
  (llvm:label 'return_sge
    (llvm:ret (llvm:const-int |i32| 39)))
  (llvm:label 'check_slt
    (let* ((is_slt (llvm:call codegen_dsl_check_primitive pred_str pred_len (llvm:gep |[4 x i8]| (llvm:get-global .str.pred_slt) 0 0) (llvm:const-int |i64| 3)))
           (is_slt_bool (llvm:icmp 'ne is_slt (llvm:const-int |i32| 0))))
