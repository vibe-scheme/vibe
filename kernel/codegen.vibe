      (let* ((lhs_node_ptr (llvm:gep |%ASTNode| args 0 4))
             (lhs_node (llvm:load lhs_node_ptr |%ASTNode*|))
             (lhs (llvm:call codegen_eval_dsl_expr cg lhs_node))
             (lhs_null (llvm:icmp 'eq lhs (llvm:const-null |i8*|))))
        (llvm:store lhs lhs_ptr)
        (llvm:br lhs_null 'error 'get_rhs)))
    (llvm:label 'get_rhs
      (let* ((args_cdr_ptr (llvm:gep |%ASTNode| args 0 5))
             (args_cdr (llvm:load args_cdr_ptr |%ASTNode*|))
             (rhs_node_ptr (llvm:gep |%ASTNode| args_cdr 0 4))
             (rhs_node (llvm:load rhs_node_ptr |%ASTNode*|))
             (rhs (llvm:call codegen_eval_dsl_expr cg rhs_node))
             (rhs_null (llvm:icmp 'eq rhs (llvm:const-null |i8*|))))
        (llvm:store rhs rhs_ptr)
        (llvm:br rhs_null 'error 'build_urem)))
    (llvm:label 'build_urem
      (let* ((builder_ptr (llvm:gep |%CodeGen| cg 0 7))
             (builder (llvm:load builder_ptr |i8*|))
             (lhs (llvm:load lhs_ptr |i8*|))
             (rhs (llvm:load rhs_ptr |i8*|)))
        (llvm:store (llvm:call llvm_build_urem builder lhs rhs (llvm:gep |[1 x i8]| (llvm:get-global .str.empty) 0 0)) result_ptr)
        (llvm:br 'urem_ret)))
    (llvm:label 'urem_ret
      (llvm:ret (llvm:load result_ptr |i8*|)))
    (llvm:label 'error
      (llvm:ret (llvm:const-null |i8*|)))))

(llvm:define-function (codegen_dsl_udiv (cg |%CodeGen*|) (args |%ASTNode*|)) |i8*|
  (let* ((lhs_ptr (llvm:alloca |i8*|))
         (rhs_ptr (llvm:alloca |i8*|))
         (result_ptr (llvm:alloca |i8*|)))
    (llvm:label 'entry
      (let* ((builder_ptr (llvm:gep |%CodeGen| cg 0 7))
             (builder (llvm:load builder_ptr |i8*|))
             (builder_null (llvm:icmp 'eq builder (llvm:const-null |i8*|))))
        (llvm:br builder_null 'error 'get_lhs)))
    (llvm:label 'get_lhs
      (let* ((args_null (llvm:icmp 'eq args (llvm:const-null |%ASTNode*|))))
        (llvm:br args_null 'error 'eval_lhs)))
    (llvm:label 'eval_lhs
      (let* ((lhs_node_ptr (llvm:gep |%ASTNode| args 0 4))
             (lhs_node (llvm:load lhs_node_ptr |%ASTNode*|))
             (lhs (llvm:call codegen_eval_dsl_expr cg lhs_node))
             (lhs_null (llvm:icmp 'eq lhs (llvm:const-null |i8*|))))
        (llvm:store lhs lhs_ptr)
        (llvm:br lhs_null 'error 'get_rhs)))
    (llvm:label 'get_rhs
      (let* ((args_cdr_ptr (llvm:gep |%ASTNode| args 0 5))
             (args_cdr (llvm:load args_cdr_ptr |%ASTNode*|))
             (rhs_node_ptr (llvm:gep |%ASTNode| args_cdr 0 4))
             (rhs_node (llvm:load rhs_node_ptr |%ASTNode*|))
             (rhs (llvm:call codegen_eval_dsl_expr cg rhs_node))
             (rhs_null (llvm:icmp 'eq rhs (llvm:const-null |i8*|))))
        (llvm:store rhs rhs_ptr)
        (llvm:br rhs_null 'error 'build_udiv)))
    (llvm:label 'build_udiv
      (let* ((builder_ptr (llvm:gep |%CodeGen| cg 0 7))
             (builder (llvm:load builder_ptr |i8*|))
             (lhs (llvm:load lhs_ptr |i8*|))
             (rhs (llvm:load rhs_ptr |i8*|)))
        (llvm:store (llvm:call llvm_build_udiv builder lhs rhs (llvm:gep |[1 x i8]| (llvm:get-global .str.empty) 0 0)) result_ptr)
        (llvm:br 'udiv_ret)))
    (llvm:label 'udiv_ret
      (llvm:ret (llvm:load result_ptr |i8*|)))
    (llvm:label 'error
      (llvm:ret (llvm:const-null |i8*|)))))

(llvm:define-function (codegen_dsl_ptrtoint (cg |%CodeGen*|) (args |%ASTNode*|)) |i8*|
  (let* ((value_ptr (llvm:alloca |i8*|))
         (dest_type_ptr (llvm:alloca |i8*|))
         (result_ptr (llvm:alloca |i8*|)))
    (llvm:label 'entry
      (let* ((builder_ptr (llvm:gep |%CodeGen| cg 0 7))
             (builder (llvm:load builder_ptr |i8*|))
             (builder_null (llvm:icmp 'eq builder (llvm:const-null |i8*|))))
        (llvm:br builder_null 'error 'get_value)))
    (llvm:label 'get_value
      (let* ((args_null (llvm:icmp 'eq args (llvm:const-null |%ASTNode*|))))
        (llvm:br args_null 'error 'eval_value)))
    (llvm:label 'eval_value
      (let* ((value_node_ptr (llvm:gep |%ASTNode| args 0 4))
             (value_node (llvm:load value_node_ptr |%ASTNode*|))
             (value (llvm:call codegen_eval_dsl_expr cg value_node))
             (value_null (llvm:icmp 'eq value (llvm:const-null |i8*|))))
        (llvm:store value value_ptr)
        (llvm:br value_null 'error 'get_dest_type)))
    (llvm:label 'get_dest_type
      (let* ((args_cdr_ptr (llvm:gep |%ASTNode| args 0 5))
             (args_cdr (llvm:load args_cdr_ptr |%ASTNode*|))
             (type_node_ptr (llvm:gep |%ASTNode| args_cdr 0 4))
             (type_node (llvm:load type_node_ptr |%ASTNode*|))
             (type_val_ptr (llvm:gep |%ASTNode| type_node 0 2))
             (type_str (llvm:load type_val_ptr |i8*|))
             (type_len_ptr (llvm:gep |%ASTNode| type_node 0 3))
             (type_len (llvm:load type_len_ptr |i64|))
             (dest_type (llvm:call codegen_resolve_type_string cg type_str type_len))
             (dest_type_null (llvm:icmp 'eq dest_type (llvm:const-null |i8*|))))
        (llvm:store dest_type dest_type_ptr)
        (llvm:br dest_type_null 'error 'build_ptrtoint)))
    (llvm:label 'build_ptrtoint
      (let* ((builder_ptr (llvm:gep |%CodeGen| cg 0 7))
             (builder (llvm:load builder_ptr |i8*|))
             (value (llvm:load value_ptr |i8*|))
             (dest_type (llvm:load dest_type_ptr |i8*|)))
        (llvm:store (llvm:call llvm_build_ptrtoint builder value dest_type (llvm:gep |[1 x i8]| (llvm:get-global .str.empty) 0 0)) result_ptr)
        (llvm:br 'ptrtoint_ret)))
    (llvm:label 'ptrtoint_ret
      (llvm:ret (llvm:load result_ptr |i8*|)))
    (llvm:label 'error
      (llvm:ret (llvm:const-null |i8*|)))))

;; ============================================================================
;; Phase 1 Migration: Leaf Helpers
;; ============================================================================

;; debug_log_string: Debug logging utility (no-op in Vibe; omit printf per plan)
(llvm:define-function (debug_log_string (prefix |i8*|) (message |i8*|) (message_len |i64|)) |void|
  (llvm:ret-void))

;; codegen_get_llvm_function: Look up a function by name in the llvm_functions list
;; Returns 1 if found (writing value and type to out params), 0 if not found
(llvm:define-function (codegen_get_llvm_function (cg |%CodeGen*|) (name |i8*|) (name_len |i64|) (func_value_out |i8*|) (func_type_out |i8*|)) |i32|
  (let* ((current_func_ptr (llvm:alloca |%ASTNode*|)))
    (llvm:label 'entry
      (let* ((functions (llvm:load (llvm:gep |%CodeGen| cg 0 14) |%ASTNode*|))
             (functions_null (llvm:icmp 'eq functions (llvm:const-null |%ASTNode*|))))
        (llvm:store functions current_func_ptr)
        (llvm:br functions_null 'not_found 'iterate)))
    (llvm:label 'iterate
      (let* ((current (llvm:load current_func_ptr |%ASTNode*|))
             (current_null (llvm:icmp 'eq current (llvm:const-null |%ASTNode*|))))
        (llvm:br current_null 'not_found 'check_pair)))
    (llvm:label 'check_pair
      (let* ((current (llvm:load current_func_ptr |%ASTNode*|))
             (pair (llvm:load (llvm:gep |%ASTNode| current 0 4) |%ASTNode*|))
             (pair_null (llvm:icmp 'eq pair (llvm:const-null |%ASTNode*|))))
        (llvm:br pair_null 'next 'compare_name)))
    (llvm:label 'compare_name
      (let* ((current (llvm:load current_func_ptr |%ASTNode*|))
             (pair (llvm:load (llvm:gep |%ASTNode| current 0 4) |%ASTNode*|))
             (name_node (llvm:load (llvm:gep |%ASTNode| pair 0 4) |%ASTNode*|))
             (name_node_null (llvm:icmp 'eq name_node (llvm:const-null |%ASTNode*|))))
        (llvm:br name_node_null 'next 'get_name)))
    (llvm:label 'get_name
      (let* ((current (llvm:load current_func_ptr |%ASTNode*|))
             (pair (llvm:load (llvm:gep |%ASTNode| current 0 4) |%ASTNode*|))
             (name_node (llvm:load (llvm:gep |%ASTNode| pair 0 4) |%ASTNode*|))
             (stored_name (llvm:load (llvm:gep |%ASTNode| name_node 0 2) |i8*|))
             (stored_len (llvm:load (llvm:gep |%ASTNode| name_node 0 3) |i64|))
             (len_match (llvm:icmp 'eq stored_len name_len)))
        (llvm:br len_match 'compare_chars 'next)))
    (llvm:label 'compare_chars
      (let* ((current (llvm:load current_func_ptr |%ASTNode*|))
             (pair (llvm:load (llvm:gep |%ASTNode| current 0 4) |%ASTNode*|))
             (name_node (llvm:load (llvm:gep |%ASTNode| pair 0 4) |%ASTNode*|))
             (stored_name (llvm:load (llvm:gep |%ASTNode| name_node 0 2) |i8*|))
             (len_int (llvm:trunc name_len |i64| |i32|))
             (cmp_result (llvm:call strncmp stored_name name len_int))
             (is_match (llvm:icmp 'eq cmp_result (llvm:const-int |i32| 0))))
        (llvm:br is_match 'found 'next)))
    (llvm:label 'found
      (let* ((current (llvm:load current_func_ptr |%ASTNode*|))
             (pair (llvm:load (llvm:gep |%ASTNode| current 0 4) |%ASTNode*|))
             (value_type_pair (llvm:load (llvm:gep |%ASTNode| pair 0 5) |%ASTNode*|))
             (vtp_null (llvm:icmp 'eq value_type_pair (llvm:const-null |%ASTNode*|))))
        (llvm:br vtp_null 'not_found 'extract_value)))
    (llvm:label 'extract_value
      (let* ((current (llvm:load current_func_ptr |%ASTNode*|))
             (pair (llvm:load (llvm:gep |%ASTNode| current 0 4) |%ASTNode*|))
             (value_type_pair (llvm:load (llvm:gep |%ASTNode| pair 0 5) |%ASTNode*|))
             (func_value_node (llvm:load (llvm:gep |%ASTNode| value_type_pair 0 4) |%ASTNode*|))
             (fvn_null (llvm:icmp 'eq func_value_node (llvm:const-null |%ASTNode*|))))
        (llvm:br fvn_null 'not_found 'extract_type)))
    (llvm:label 'extract_type
      (let* ((current (llvm:load current_func_ptr |%ASTNode*|))
             (pair (llvm:load (llvm:gep |%ASTNode| current 0 4) |%ASTNode*|))
             (value_type_pair (llvm:load (llvm:gep |%ASTNode| pair 0 5) |%ASTNode*|))
             (func_value_node (llvm:load (llvm:gep |%ASTNode| value_type_pair 0 4) |%ASTNode*|))
             (func_type_node (llvm:load (llvm:gep |%ASTNode| value_type_pair 0 5) |%ASTNode*|))
             (ftn_null (llvm:icmp 'eq func_type_node (llvm:const-null |%ASTNode*|))))
        (llvm:br ftn_null 'not_found 'cast_back)))
    (llvm:label 'cast_back
      (let* ((current (llvm:load current_func_ptr |%ASTNode*|))
             (pair (llvm:load (llvm:gep |%ASTNode| current 0 4) |%ASTNode*|))
             (value_type_pair (llvm:load (llvm:gep |%ASTNode| pair 0 5) |%ASTNode*|))
             (func_value_node (llvm:load (llvm:gep |%ASTNode| value_type_pair 0 4) |%ASTNode*|))
             (func_type_node (llvm:load (llvm:gep |%ASTNode| value_type_pair 0 5) |%ASTNode*|))
             (func_value_ptr (llvm:load (llvm:gep |%ASTNode| func_value_node 0 2) |i8*|))
             (func_type_ptr_val (llvm:load (llvm:gep |%ASTNode| func_type_node 0 2) |i8*|)))
        (llvm:store func_value_ptr func_value_out)
        (llvm:store func_type_ptr_val func_type_out)
        (llvm:ret (llvm:const-int |i32| 1))))
    (llvm:label 'next
      (let* ((current (llvm:load current_func_ptr |%ASTNode*|))
             (cdr (llvm:load (llvm:gep |%ASTNode| current 0 5) |%ASTNode*|)))
        (llvm:store cdr current_func_ptr)
        (llvm:br 'iterate)))
    (llvm:label 'not_found
      (llvm:ret (llvm:const-int |i32| 0)))))

;; codegen_get_or_create_label: Find existing basic block by name or create a new one
;; Parameters: cg (CodeGen*), func (LLVMValueRef), name (i8*), name_len (i64)
;; Returns: LLVMBasicBlockRef or null on error
(llvm:define-function (codegen_get_or_create_label (cg |%CodeGen*|) (func |i8*|) (name |i8*|) (name_len |i64|)) |i8*|
  (let* ((current_block_ptr (llvm:alloca |i8*|)))
    (llvm:label 'entry
      (let* ((func_null (llvm:icmp 'eq func (llvm:const-null |i8*|))))
        (llvm:br func_null 'error 'check_existing)))
    (llvm:label 'check_existing
      (let* ((first_block (llvm:call llvm_get_first_basic_block func))
             (first_block_null (llvm:icmp 'eq first_block (llvm:const-null |i8*|))))
        (llvm:store first_block current_block_ptr)
        (llvm:br first_block_null 'create_label 'iterate_blocks)))
    (llvm:label 'iterate_blocks
      (let* ((current_block (llvm:load current_block_ptr |i8*|))
             (current_null (llvm:icmp 'eq current_block (llvm:const-null |i8*|))))
        (llvm:br current_null 'create_label 'get_block_name)))
    (llvm:label 'get_block_name
      (let* ((current_block (llvm:load current_block_ptr |i8*|))
             (block_name (llvm:call llvm_get_basic_block_name current_block))
             (block_name_null (llvm:icmp 'eq block_name (llvm:const-null |i8*|))))
        (llvm:br block_name_null 'check_next_block 'compare_names)))
    (llvm:label 'compare_names
      (let* ((current_block (llvm:load current_block_ptr |i8*|))
             (block_name (llvm:call llvm_get_basic_block_name current_block))
             (name_len_int (llvm:trunc name_len |i64| |i32|))
             (cmp_result (llvm:call strncmp block_name name name_len_int))
             (names_match (llvm:icmp 'eq cmp_result (llvm:const-int |i32| 0))))
        (llvm:br names_match 'check_null_term 'check_next_block)))
    (llvm:label 'check_null_term
      (let* ((current_block (llvm:load current_block_ptr |i8*|))
             (block_name (llvm:call llvm_get_basic_block_name current_block))
             (block_name_at_len (llvm:gep |i8| block_name name_len))
             (char_at_len (llvm:load block_name_at_len |i8|))
             (is_null_term (llvm:icmp 'eq char_at_len (llvm:const-int |i8| 0))))
        (llvm:br is_null_term 'found_existing 'check_next_block)))
    (llvm:label 'found_existing
      (let* ((current_block (llvm:load current_block_ptr |i8*|)))
        (llvm:ret current_block)))
    (llvm:label 'check_next_block
      (let* ((current_block (llvm:load current_block_ptr |i8*|))
             (next_block (llvm:call llvm_get_next_basic_block current_block))
             (next_null (llvm:icmp 'eq next_block (llvm:const-null |i8*|))))
        (llvm:store next_block current_block_ptr)
        (llvm:br next_null 'create_label 'iterate_blocks)))
    (llvm:label 'create_label
      (let* ((name_buf_size (llvm:add name_len (llvm:const-int |i64| 1)))
             (name_buf (llvm:call malloc name_buf_size))
             (dummy (llvm:call memcpy name_buf name name_len))
             (null_ptr (llvm:gep |i8| name_buf name_len)))
        (llvm:store (llvm:const-int |i8| 0) null_ptr)
        (let* ((block (llvm:call llvm_append_basic_block func name_buf)))
          (llvm:ret block))))
    (llvm:label 'error
      (llvm:ret (llvm:const-null |i8*|)))))

;; codegen_write_ir_text: Write module IR text to file using LLVM API (Phase 3)
(llvm:define-function (codegen_write_ir_text (cg |%CodeGen*|) (filename |i8*|)) |i32|
  (llvm:label 'entry
    (let* ((cg_null (llvm:icmp 'eq cg (llvm:const-null |%CodeGen*|))))
      (llvm:br cg_null 'error 'get_module)))
  (llvm:label 'get_module
    (let* ((module_ptr (llvm:gep |%CodeGen| cg 0 6))
           (module (llvm:load module_ptr |i8*|))
           (module_null (llvm:icmp 'eq module (llvm:const-null |i8*|))))
      (llvm:br module_null 'error 'write)))
  (llvm:label 'write
    (let* ((module_ptr (llvm:gep |%CodeGen| cg 0 6))
           (module (llvm:load module_ptr |i8*|))
           (error_msg (llvm:alloca |i8*|)))
      (llvm:store (llvm:const-null |i8*|) error_msg)
      (let* ((result (llvm:call llvm_print_module_to_file module filename error_msg))
             (write_failed (llvm:icmp 'ne result (llvm:const-int |i32| 0))))
        (llvm:br write_failed 'error 'success))))
  (llvm:label 'success (llvm:ret (llvm:const-int |i32| 0)))
  (llvm:label 'error (llvm:ret (llvm:const-int |i32| -1))))

;; codegen_append_function_def: Append a function definition to IR buffer
;; Generate: define void @name(i8* %param1, ...) { [body] }
;; Parameters: cg, name, params (AST list), body (IR string), body_len
(llvm:define-function (codegen_append_function_def (cg |%CodeGen*|) (name |i8*|) (params |%ASTNode*|) (body |i8*|) (body_len |i64|)) |void|
  (llvm:label 'entry
    (let* ((name_len (llvm:call strlen name))
           (define_void (llvm:gep |[12 x i8]| (llvm:get-global .str.define_void) 0 0))
           (at_sign (llvm:gep |[2 x i8]| (llvm:get-global .str.at_sign) 0 0))
           (lparen (llvm:gep |[2 x i8]| (llvm:get-global .str.lparen) 0 0))
           (rparen_brace (llvm:gep |[4 x i8]| (llvm:get-global .str.rparen_brace) 0 0))
           (close_brace (llvm:gep |[2 x i8]| (llvm:get-global .str.close_brace) 0 0)))
      (llvm:call codegen_append cg define_void (llvm:const-int |i64| 11))
      (llvm:call codegen_append cg at_sign (llvm:const-int |i64| 1))
      (llvm:call codegen_append cg name name_len)
      (llvm:call codegen_append cg lparen (llvm:const-int |i64| 1))
      (llvm:call codegen_append_params cg params)
      (llvm:call codegen_append cg rparen_brace (llvm:const-int |i64| 3))
      (llvm:call codegen_append cg body body_len)
      (llvm:call codegen_append cg close_brace (llvm:const-int |i64| 1))
      (llvm:ret-void))))

;; codegen_eval_dsl_body: Evaluate list of DSL expressions (no debug logging in kernel)
;; Parameters: cg, body (AST list of expressions)
(llvm:define-function (codegen_eval_dsl_body (cg |%CodeGen*|) (body |%ASTNode*|)) |void|
  (let* ((current_ptr (llvm:alloca |%ASTNode*|)))
    (llvm:label 'entry
      (let* ((body_null (llvm:icmp 'eq body (llvm:const-null |%ASTNode*|))))
        (llvm:br body_null 'done 'check_body_type)))
    (llvm:label 'check_body_type
      (let* ((body_type_ptr (llvm:gep |%ASTNode| body 0 0))
             (body_type (llvm:load body_type_ptr |i32|))
             (is_list (llvm:icmp 'eq body_type (llvm:const-int |i32| 1))))
        (llvm:br is_list 'eval_loop 'done)))
    (llvm:label 'eval_loop
      (llvm:store body current_ptr)
      (llvm:br 'eval_iter))
    (llvm:label 'eval_iter
      (let* ((current_val (llvm:load current_ptr |%ASTNode*|))
             (current_null (llvm:icmp 'eq current_val (llvm:const-null |%ASTNode*|))))
        (llvm:br current_null 'done 'eval_expr)))
    (llvm:label 'eval_expr
      (let* ((current_val (llvm:load current_ptr |%ASTNode*|))
             (car_ptr (llvm:gep |%ASTNode| current_val 0 4))
             (car (llvm:load car_ptr |%ASTNode*|))
             (cdr_ptr (llvm:gep |%ASTNode| current_val 0 5))
             (cdr (llvm:load cdr_ptr |%ASTNode*|)))
        (llvm:call codegen_eval_dsl_expr cg car)
        (llvm:store cdr current_ptr)
        (llvm:br 'eval_iter)))
    (llvm:label 'done
      (llvm:ret-void))))

;; codegen_define_bitcode: Generate LLVM function from define-bitcode (legacy)
;; AST: LIST { ATOM "define-bitcode", LIST { name, param1, ... }, STRING body }
;; Returns: 0 on success, -1 on error
(llvm:define-function (codegen_define_bitcode (cg |%CodeGen*|) (node |%ASTNode*|)) |i32|
  (llvm:label 'entry
    (let* ((car_ptr (llvm:gep |%ASTNode| node 0 4))
           (car (llvm:load car_ptr |%ASTNode*|))
           (car_type_ptr (llvm:gep |%ASTNode| car 0 0))
           (car_type (llvm:load car_type_ptr |i32|))
           (is_atom (llvm:icmp 'eq car_type (llvm:const-int |i32| 0))))
      (llvm:br is_atom 'check_name 'error)))
  (llvm:label 'check_name
    (let* ((cdr_ptr (llvm:gep |%ASTNode| node 0 5))
           (cdr (llvm:load cdr_ptr |%ASTNode*|))
           (cdr_car_ptr (llvm:gep |%ASTNode| cdr 0 4))
           (sig_list (llvm:load cdr_car_ptr |%ASTNode*|))
           (sig_car_ptr (llvm:gep |%ASTNode| sig_list 0 4))
           (func_name_node (llvm:load sig_car_ptr |%ASTNode*|))
           (func_name_val_ptr (llvm:gep |%ASTNode| func_name_node 0 2))
           (func_name (llvm:load func_name_val_ptr |i8*|))
           (cdr_cdr_ptr (llvm:gep |%ASTNode| cdr 0 5))
           (cdr_cdr (llvm:load cdr_cdr_ptr |%ASTNode*|))
           (cdr_cdr_car_ptr (llvm:gep |%ASTNode| cdr_cdr 0 4))
           (ir_body_node (llvm:load cdr_cdr_car_ptr |%ASTNode*|))
           (ir_body_val_ptr (llvm:gep |%ASTNode| ir_body_node 0 2))
           (ir_body (llvm:load ir_body_val_ptr |i8*|))
           (ir_body_len_ptr (llvm:gep |%ASTNode| ir_body_node 0 3))
           (ir_body_len (llvm:load ir_body_len_ptr |i64|))
           (sig_cdr_ptr (llvm:gep |%ASTNode| sig_list 0 5))
           (params_list (llvm:load sig_cdr_ptr |%ASTNode*|)))
      (llvm:call codegen_append_function_def cg func_name params_list ir_body ir_body_len)
      (llvm:ret (llvm:const-int |i32| 0))))
  (llvm:label 'error
    (llvm:ret (llvm:const-int |i32| -1))))

;; codegen_define_bitcode_function: Generate LLVM function with typed params from IR body
;; AST: LIST { ATOM "define-bitcode-function", LIST signature, ATOM return-type, STRING body }
;; Format: "define return-type @name(type1 %param1, ...) {\n[body]\n}\n"
(llvm:define-function (codegen_define_bitcode_function (cg |%CodeGen*|) (node |%ASTNode*|)) |i32|
  (let* ((pos_ptr (llvm:alloca |i64|))
         (func_def_buf_ptr (llvm:alloca |i8*|))
         (str_define (llvm:gep |[8 x i8]| (llvm:get-global .str.define) 0 0))
         (str_space_at (llvm:gep |[3 x i8]| (llvm:get-global .str.space_at) 0 0))
         (str_lparen (llvm:gep |[2 x i8]| (llvm:get-global .str.lparen) 0 0))
         (str_rparen_brace (llvm:gep |[4 x i8]| (llvm:get-global .str.rparen_brace) 0 0))
         (str_newline_close_brace (llvm:gep |[4 x i8]| (llvm:get-global .str.newline_close_brace) 0 0)))
    (llvm:label 'entry
      (let* ((cdr_ptr (llvm:gep |%ASTNode| node 0 5))
             (cdr (llvm:load cdr_ptr |%ASTNode*|))
             (sig_list_node_ptr (llvm:gep |%ASTNode| cdr 0 4))
             (sig_list (llvm:load sig_list_node_ptr |%ASTNode*|))
             (sig_car_ptr (llvm:gep |%ASTNode| sig_list 0 4))
             (func_name_node (llvm:load sig_car_ptr |%ASTNode*|))
             (func_name_val_ptr (llvm:gep |%ASTNode| func_name_node 0 2))
             (func_name (llvm:load func_name_val_ptr |i8*|))
