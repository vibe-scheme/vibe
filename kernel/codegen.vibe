           (size_ptr (llvm:gep |%CodeGen| cg_ptr 0 1))
           (pos_ptr (llvm:gep |%CodeGen| cg_ptr 0 2))
           (str_counter_ptr (llvm:gep |%CodeGen| cg_ptr 0 3))
           (label_counter_ptr (llvm:gep |%CodeGen| cg_ptr 0 4))
