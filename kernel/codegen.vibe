    (llvm:label 'get_llvm_context)
    (let* ((context_ptr (llvm:gep |%CodeGen| cg 0 5))
           (context (llvm:load context_ptr |i8*|))
           (module_ptr (llvm:gep |%CodeGen| cg 0 6))
           (module (llvm:load module_ptr |i8*|))
           (context_null (llvm:icmp 'eq context (llvm:const-null |i8*|)))
           (module_null (llvm:icmp 'eq module (llvm:const-null |i8*|)))
           (any_null (llvm:or context_null module_null)))
      (llvm:br any_null 'error 'resolve_return_type_ffi))
    (llvm:label 'resolve_return_type_ffi)
    (let* ((return_type_ref (llvm:call codegen_resolve_type_string cg return_type return_type_len))
           (return_type_null (llvm:icmp 'eq return_type_ref (llvm:const-null |i8*|))))
      (llvm:br return_type_null 'error 'collect_params_ffi))
    (llvm:label 'collect_params_ffi)
    (let* ((pta (llvm:call malloc (llvm:const-int |i64| 80)))
           (param_count (llvm:call codegen_collect_param_types cg params_list pta (llvm:const-int |i32| 10)))
           (is_vararg_val (llvm:load is_vararg_ptr |i32|))
           (return_type_ref2 (llvm:call codegen_resolve_type_string cg return_type return_type_len))
           (has_params_ffi (llvm:icmp 'ne param_count (llvm:const-int |i32| 0))))
      (llvm:store pta param_types_array_ptr)
      (llvm:br has_params_ffi 'create_func_type_with_params_ffi 'create_func_type_no_params_ffi))
    (llvm:label 'create_func_type_with_params_ffi)
    (let* ((pta2 (llvm:load param_types_array_ptr |i8*|))
           (return_type_ref3 (llvm:call codegen_resolve_type_string cg return_type return_type_len))
           (is_vararg_val2 (llvm:load is_vararg_ptr |i32|))
           (param_count2 (llvm:call codegen_collect_param_types cg params_list pta2 (llvm:const-int |i32| 10)))
           (ft (llvm:call llvm_create_function_type return_type_ref3 pta2 param_count2 is_vararg_val2)))
      (llvm:store ft func_type_ptr)
      (llvm:br 'check_func_type_ffi))
    (llvm:label 'create_func_type_no_params_ffi)
    (let* ((return_type_ref4 (llvm:call codegen_resolve_type_string cg return_type return_type_len))
           (is_vararg_val3 (llvm:load is_vararg_ptr |i32|))
           (ft_no_params (llvm:call llvm_create_function_type return_type_ref4 (llvm:const-null |i8*|) (llvm:const-int |i32| 0) is_vararg_val3)))
      (llvm:store ft_no_params func_type_ptr)
      (llvm:br 'check_func_type_ffi))
    (llvm:label 'check_func_type_ffi)
    (let* ((ft_val (llvm:load func_type_ptr |i8*|))
           (ft_null (llvm:icmp 'eq ft_val (llvm:const-null |i8*|))))
      (llvm:br ft_null 'free_param_types_ffi 'add_function_ffi))
    (llvm:label 'free_param_types_ffi)
    (llvm:call free (llvm:load param_types_array_ptr |i8*|))
    (llvm:br 'error)
    (llvm:label 'add_function_ffi)
    (let* ((func_name_buf_size (llvm:add func_name_len (llvm:const-int |i64| 1)))
           (func_name_buf (llvm:call malloc func_name_buf_size)))
      (llvm:call memcpy func_name_buf func_name func_name_len)
      (let* ((fn_null_ptr (llvm:gep |i8| func_name_buf func_name_len)))
        (llvm:store (llvm:const-int |i8| 0) fn_null_ptr)
        (let* ((module2 (llvm:load (llvm:gep |%CodeGen| cg 0 6) |i8*|))
               (ft_val2 (llvm:load func_type_ptr |i8*|))
               (func (llvm:call llvm_add_function module2 func_name_buf ft_val2)))
          (llvm:call free func_name_buf)
          (let* ((func_null (llvm:icmp 'eq func (llvm:const-null |i8*|))))
            (llvm:br func_null 'free_param_types_ffi 'set_external_linkage)))))
    (llvm:label 'set_external_linkage)
    (let* ((func2 (llvm:call llvm_get_named_function (llvm:load (llvm:gep |%CodeGen| cg 0 6) |i8*|) func_name))
           (ft_val3 (llvm:load func_type_ptr |i8*|)))
      (llvm:call llvm_set_linkage func2 (llvm:const-int |i32| 0))
      (llvm:call codegen_store_llvm_function cg func_name func_name_len func2 ft_val3)
      (llvm:call codegen_store_function_type cg func_name func_name_len ft_val3)
      (llvm:call free (llvm:load param_types_array_ptr |i8*|))
      (llvm:ret (llvm:const-int |i32| 0)))
    (llvm:label 'error)
    (llvm:ret (llvm:const-int |i32| -1))))

;; ============================================================================
;; codegen_write_object_file
;; Write the LLVM module to an object file using TargetMachine API.
;; Parameters: cg (CodeGen*), filename (i8*)
;; Returns: 0 on success, -1 on error
;; ============================================================================
(llvm:define-function (codegen_write_object_file (cg |%CodeGen*|) (filename |i8*|)) |i32|
  (let* ((cg_null (llvm:icmp 'eq cg (llvm:const-null |%CodeGen*|)))
         (triple_ptr (llvm:alloca |i8*|))
         (target_ptr (llvm:alloca |i8*|))
         (error_msg_ptr (llvm:alloca |i8*|))
         (error_msg_emit (llvm:alloca |i8*|))
         (tm_ptr (llvm:alloca |i8*|)))
    (llvm:br cg_null 'error 'get_module)
    (llvm:label 'get_module)
    (let* ((module_ptr (llvm:gep |%CodeGen| cg 0 6))
           (module (llvm:load module_ptr |i8*|))
           (module_null (llvm:icmp 'eq module (llvm:const-null |i8*|))))
      (llvm:br module_null 'error 'get_triple))
    (llvm:label 'get_triple)
    (let* ((default_triple (llvm:call llvm_get_default_target_triple))
           (triple_null (llvm:icmp 'eq default_triple (llvm:const-null |i8*|))))
      (llvm:br triple_null 'use_hardcoded_triple 'use_default_triple))
    (llvm:label 'use_hardcoded_triple)
    (llvm:store (llvm:gep |[19 x i8]| (llvm:get-global .str.target_triple_value) 0 0) triple_ptr)
    (llvm:br 'get_target_impl)
    (llvm:label 'use_default_triple)
    (llvm:store (llvm:call llvm_get_default_target_triple) triple_ptr)
    (llvm:br 'get_target_impl)
    (llvm:label 'get_target_impl)
    (llvm:store (llvm:const-null |i8*|) error_msg_ptr)
    (let* ((triple_to_use (llvm:load triple_ptr |i8*|))
           (target_result (llvm:call llvm_get_target_from_triple triple_to_use target_ptr error_msg_ptr))
           (target_failed (llvm:icmp 'ne target_result (llvm:const-int |i32| 0))))
      (llvm:br target_failed 'error 'create_target_machine))
    (llvm:label 'create_target_machine)
    (let* ((target (llvm:load target_ptr |i8*|))
           (triple_for_tm (llvm:load triple_ptr |i8*|))
           (empty_str (llvm:gep |[1 x i8]| (llvm:get-global .str.empty) 0 0))
           (tm (llvm:call llvm_create_target_machine target triple_for_tm empty_str empty_str (llvm:const-int |i32| 2) (llvm:const-int |i32| 0) (llvm:const-int |i32| 0)))
           (tm_null (llvm:icmp 'eq tm (llvm:const-null |i8*|))))
      (llvm:store tm tm_ptr)
      (llvm:br tm_null 'error 'emit_file))
    (llvm:label 'emit_file)
    (llvm:store (llvm:const-null |i8*|) error_msg_emit)
    (let* ((tm_val (llvm:load tm_ptr |i8*|))
           (module_ptr2 (llvm:gep |%CodeGen| cg 0 6))
           (module2 (llvm:load module_ptr2 |i8*|))
           (emit_result (llvm:call llvm_target_machine_emit_to_file tm_val module2 filename (llvm:const-int |i32| 1) error_msg_emit)))
      (llvm:call llvm_dispose_target_machine tm_val)
      (let* ((emit_failed (llvm:icmp 'ne emit_result (llvm:const-int |i32| 0))))
        (llvm:br emit_failed 'error 'success)))
    (llvm:label 'success)
    (llvm:ret (llvm:const-int |i32| 0))
    (llvm:label 'error)
    (llvm:ret (llvm:const-int |i32| -1))))

;; ============================================================================
;; codegen_main
;; Generate main function wrapping top-level executable expressions.
;; If exprs is null/empty, skips main generation (library module).
;; ============================================================================
(llvm:define-constant .str.main_name |[5 x i8]| #u8(109 97 105 110 0))
(llvm:define-constant .str.define_main |[21 x i8]| #u8(100 101 102 105 110 101 32 105 51 50 32 64 109 97 105 110 40 41 32 123 0))
(llvm:define-constant .str.ret_zero |[12 x i8]| #u8(32 32 114 101 116 32 105 51 50 32 48 0))

(llvm:define-function (codegen_main (cg |%CodeGen*|) (exprs |%ASTNode*|)) |i32|
  (let* ((exprs_null (llvm:icmp 'eq exprs (llvm:const-null |%ASTNode*|))))
    (llvm:br exprs_null 'done_no_main 'check_empty)
    (llvm:label 'check_empty)
    (let* ((exprs_type_ptr (llvm:gep |%ASTNode| exprs 0 0))
           (exprs_type (llvm:load exprs_type_ptr |i32|))
           (is_list (llvm:icmp 'eq exprs_type (llvm:const-int |i32| 1))))
      (llvm:br is_list 'check_car 'has_exprs)
      (llvm:label 'check_car)
      (let* ((exprs_car_ptr (llvm:gep |%ASTNode| exprs 0 4))
             (exprs_car (llvm:load exprs_car_ptr |i8*|))
             (car_null (llvm:icmp 'eq exprs_car (llvm:const-null |i8*|))))
        (llvm:br car_null 'done_no_main 'has_exprs)))
    (llvm:label 'has_exprs)
    (llvm:call codegen_collect_string_constants cg exprs)
    (let* ((context_ptr (llvm:gep |%CodeGen| cg 0 5))
           (context (llvm:load context_ptr |i8*|))
           (module_ptr (llvm:gep |%CodeGen| cg 0 6))
           (module (llvm:load module_ptr |i8*|))
           (context_null (llvm:icmp 'eq context (llvm:const-null |i8*|)))
           (module_null (llvm:icmp 'eq module (llvm:const-null |i8*|)))
           (either_null (llvm:or context_null module_null)))
      (llvm:br either_null 'text_only 'create_main_llvm)
      (llvm:label 'create_main_llvm)
      (let* ((i32_type (llvm:call llvm_get_int32_type context))
             (i32_type_null (llvm:icmp 'eq i32_type (llvm:const-null |i8*|))))
        (llvm:br i32_type_null 'text_only 'create_func_type)
        (llvm:label 'create_func_type)
        (let* ((main_func_type (llvm:call llvm_create_function_type i32_type (llvm:const-null |i8*|) (llvm:const-int |i32| 0) (llvm:const-int |i32| 0)))
               (func_type_null (llvm:icmp 'eq main_func_type (llvm:const-null |i8*|))))
          (llvm:br func_type_null 'text_only 'add_function)
          (llvm:label 'add_function)
          (let* ((main_name_ptr (llvm:gep |[5 x i8]| (llvm:get-global .str.main_name) 0 0))
                 (main_func (llvm:call llvm_add_function module main_name_ptr main_func_type))
                 (main_func_null (llvm:icmp 'eq main_func (llvm:const-null |i8*|))))
            (llvm:br main_func_null 'text_only 'append_block)
            (llvm:label 'append_block)
            (let* ((entry_name_ptr (llvm:gep |[6 x i8]| (llvm:get-global .str.entry_block_name) 0 0))
                   (entry_block (llvm:call llvm_append_basic_block main_func entry_name_ptr))
                   (block_null (llvm:icmp 'eq entry_block (llvm:const-null |i8*|))))
              (llvm:br block_null 'text_only 'create_builder)
              (llvm:label 'create_builder)
              (let* ((builder (llvm:call llvm_create_builder context))
                     (builder_null (llvm:icmp 'eq builder (llvm:const-null |i8*|))))
                (llvm:br builder_null 'text_only 'position_builder)
                (llvm:label 'position_builder)
                (llvm:call llvm_position_builder_at_end builder entry_block)
                (let* ((builder_field_ptr (llvm:gep |%CodeGen| cg 0 7)))
                  (llvm:store builder builder_field_ptr)
                  (let* ((zero_const (llvm:call llvm_create_constant_int i32_type (llvm:const-int |i64| 0) (llvm:const-int |i32| 0)))
                         (zero_null (llvm:icmp 'eq zero_const (llvm:const-null |i8*|))))
                    (llvm:br zero_null 'text_only 'build_ret)
                    (llvm:label 'build_ret)
                    (llvm:call codegen_append_top_level_exprs cg exprs)
                    (llvm:call llvm_build_ret builder zero_const)
                    (llvm:br 'done)))))))))
    (llvm:label 'text_only)
    (let* ((define_main_ptr (llvm:gep |[21 x i8]| (llvm:get-global .str.define_main) 0 0)))
      (llvm:call codegen_append cg define_main_ptr (llvm:const-int |i64| 20))
      (llvm:call codegen_append_top_level_exprs cg exprs)
      (let* ((ret_zero_ptr (llvm:gep |[12 x i8]| (llvm:get-global .str.ret_zero) 0 0)))
        (llvm:call codegen_append cg ret_zero_ptr (llvm:const-int |i64| 11))
        (let* ((close_brace_ptr (llvm:gep |[2 x i8]| (llvm:get-global .str.close_brace) 0 0)))
          (llvm:call codegen_append cg close_brace_ptr (llvm:const-int |i64| 1))
          (llvm:br 'done))))
    (llvm:label 'done_no_main)
    (llvm:call codegen_collect_string_constants cg (llvm:const-null |%ASTNode*|))
    (llvm:br 'done)
    (llvm:label 'done)
    (llvm:ret (llvm:const-int |i32| 0))))

