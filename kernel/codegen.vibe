(llvm:define-function (codegen_map_predicate_string (pred_str |i8*|) (pred_len |i64|)) |i32|
  (let* ((is_eq (llvm:call codegen_dsl_check_primitive pred_str pred_len (llvm:gep |[3 x i8]| (llvm:get-global .str.pred_eq) 0 0) (llvm:const-int |i64| 2)))
         (is_eq_bool (llvm:icmp 'ne is_eq (llvm:const-int |i32| 0))))
    (llvm:br is_eq_bool 'return_eq 'check_ne))
  (llvm:label 'return_eq
    (llvm:ret (llvm:const-int |i32| 32)))
  (llvm:label 'check_ne
    (let* ((is_ne (llvm:call codegen_dsl_check_primitive pred_str pred_len (llvm:gep |[3 x i8]| (llvm:get-global .str.pred_ne) 0 0) (llvm:const-int |i64| 2)))
           (is_ne_bool (llvm:icmp 'ne is_ne (llvm:const-int |i32| 0))))
      (llvm:br is_ne_bool 'return_ne 'check_uge)))
  (llvm:label 'return_ne
    (llvm:ret (llvm:const-int |i32| 33)))
  (llvm:label 'check_uge
    (let* ((is_uge (llvm:call codegen_dsl_check_primitive pred_str pred_len (llvm:gep |[4 x i8]| (llvm:get-global .str.pred_uge) 0 0) (llvm:const-int |i64| 3)))
           (is_uge_bool (llvm:icmp 'ne is_uge (llvm:const-int |i32| 0))))
      (llvm:br is_uge_bool 'return_uge 'check_ult)))
  (llvm:label 'return_uge
    (llvm:ret (llvm:const-int |i32| 35)))
  (llvm:label 'check_ult
    (let* ((is_ult (llvm:call codegen_dsl_check_primitive pred_str pred_len (llvm:gep |[4 x i8]| (llvm:get-global .str.pred_ult) 0 0) (llvm:const-int |i64| 3)))
           (is_ult_bool (llvm:icmp 'ne is_ult (llvm:const-int |i32| 0))))
      (llvm:br is_ult_bool 'return_ult 'check_ugt)))
  (llvm:label 'return_ult
    (llvm:ret (llvm:const-int |i32| 36)))
  (llvm:label 'check_ugt
    (let* ((is_ugt (llvm:call codegen_dsl_check_primitive pred_str pred_len (llvm:gep |[4 x i8]| (llvm:get-global .str.pred_ugt) 0 0) (llvm:const-int |i64| 3)))
           (is_ugt_bool (llvm:icmp 'ne is_ugt (llvm:const-int |i32| 0))))
      (llvm:br is_ugt_bool 'return_ugt 'check_ule)))
  (llvm:label 'return_ugt
