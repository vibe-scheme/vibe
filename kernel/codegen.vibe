             (pred_node (llvm:load pred_node_ptr |%ASTNode*|))
             (pred_node_null (llvm:icmp 'eq pred_node (llvm:const-null |%ASTNode*|))))
        (llvm:br pred_node_null 'error 'extract_pred)))
    (llvm:label 'extract_pred
      (let* ((pred_node_ptr (llvm:gep |%ASTNode| args 0 4))
             (pred_node (llvm:load pred_node_ptr |%ASTNode*|))
