        (llvm:br 'return_block)))
    (llvm:label 'return_block
      (let* ((block (llvm:load block_ptr |i8*|)))
        (llvm:store block result_ptr)
        (llvm:br 'label_ret)))
    (llvm:label 'label_ret
      (llvm:ret (llvm:load result_ptr |i8*|)))
    (llvm:label 'error
      (llvm:ret (llvm:const-null |i8*|)))))

;; ============================================================================
;; Phase 1: codegen_dsl_phi
;; Handle llvm:phi form. Syntax: (llvm:phi type (value1 'label1) (value2 'label2) ...)
;; ============================================================================
(llvm:define-function (codegen_dsl_phi (cg |%CodeGen*|) (args |%ASTNode*|)) |i8*|
  (let* ((phi_type_ptr (llvm:alloca |i8*|))
         (phi_type_null_ptr (llvm:alloca |i1|))
         (phi_ptr (llvm:alloca |i8*|))
         (phi_null_ptr (llvm:alloca |i1|))
         (current_pair_ptr (llvm:alloca |%ASTNode*|))
         (phi_label_name_out (llvm:alloca |i8*|))
         (phi_label_len_out (llvm:alloca |i64|))
         (incoming_value_ptr (llvm:alloca |i8*|))
         (incoming_value_null_ptr (llvm:alloca |i1|))
         (incoming_bb_ptr (llvm:alloca |i8*|))
         (incoming_bb_null_ptr (llvm:alloca |i1|))
         (result_ptr (llvm:alloca |i8*|)))
    (llvm:label 'entry
      (let* ((builder_ptr (llvm:gep |%CodeGen| cg 0 7))
             (builder (llvm:load builder_ptr |i8*|))
             (builder_null (llvm:icmp 'eq builder (llvm:const-null |i8*|))))
        (llvm:br builder_null 'error 'get_phi_type)))
    (llvm:label 'get_phi_type
      (let* ((args_null (llvm:icmp 'eq args (llvm:const-null |%ASTNode*|))))
        (llvm:br args_null 'error 'extract_phi_type)))
    (llvm:label 'extract_phi_type
      (let* ((type_node_ptr (llvm:gep |%ASTNode| args 0 4))
             (type_node (llvm:load type_node_ptr |%ASTNode*|))
             (type_val_ptr (llvm:gep |%ASTNode| type_node 0 2))
             (type_val (llvm:load type_val_ptr |i8*|))
             (type_len_ptr (llvm:gep |%ASTNode| type_node 0 3))
             (type_len (llvm:load type_len_ptr |i64|))
             (phi_type (llvm:call codegen_resolve_type_string cg type_val type_len))
             (phi_type_null (llvm:icmp 'eq phi_type (llvm:const-null |i8*|))))
        (llvm:store phi_type phi_type_ptr)
        (llvm:store phi_type_null phi_type_null_ptr)
        (llvm:br 'extract_phi_type_br)))
    (llvm:label 'extract_phi_type_br
      (let* ((phi_type_null (llvm:load phi_type_null_ptr |i1|)))
        (llvm:br phi_type_null 'error 'build_phi_node)))
    (llvm:label 'build_phi_node
      (let* ((builder_ptr (llvm:gep |%CodeGen| cg 0 7))
             (builder (llvm:load builder_ptr |i8*|))
             (phi_type (llvm:load phi_type_ptr |i8*|))
             (phi (llvm:call llvm_build_phi builder phi_type (llvm:gep |[1 x i8]| (llvm:get-global .str.empty) 0 0)))
             (phi_null (llvm:icmp 'eq phi (llvm:const-null |i8*|))))
        (llvm:store phi phi_ptr)
        (llvm:store phi_null phi_null_ptr)
        (llvm:br 'build_phi_node_br)))
    (llvm:label 'build_phi_node_br
      (let* ((phi_null (llvm:load phi_null_ptr |i1|)))
        (llvm:br phi_null 'error 'get_incoming_pairs)))
    (llvm:label 'get_incoming_pairs
      (let* ((pairs_start_ptr (llvm:gep |%ASTNode| args 0 5))
             (pairs_start (llvm:load pairs_start_ptr |%ASTNode*|)))
        (llvm:store pairs_start current_pair_ptr)
        (llvm:br 'phi_loop)))
    (llvm:label 'phi_loop
      (let* ((current_pair (llvm:load current_pair_ptr |%ASTNode*|))
             (current_pair_null (llvm:icmp 'eq current_pair (llvm:const-null |%ASTNode*|))))
        (llvm:br current_pair_null 'phi_done 'process_pair)))
    (llvm:label 'process_pair
      (let* ((current_pair (llvm:load current_pair_ptr |%ASTNode*|))
             (pair_node_ptr (llvm:gep |%ASTNode| current_pair 0 4))
             (pair_node (llvm:load pair_node_ptr |%ASTNode*|))
             (pair_node_null (llvm:icmp 'eq pair_node (llvm:const-null |%ASTNode*|))))
        (llvm:br pair_node_null 'phi_done 'extract_value_from_pair)))
    (llvm:label 'extract_value_from_pair
      (let* ((current_pair (llvm:load current_pair_ptr |%ASTNode*|))
             (pair_node_ptr (llvm:gep |%ASTNode| current_pair 0 4))
             (pair_node (llvm:load pair_node_ptr |%ASTNode*|))
             (value_node_ptr (llvm:gep |%ASTNode| pair_node 0 4))
             (value_node (llvm:load value_node_ptr |%ASTNode*|))
             (incoming_value (llvm:call codegen_eval_dsl_expr cg value_node))
             (incoming_value_null (llvm:icmp 'eq incoming_value (llvm:const-null |i8*|))))
        (llvm:store incoming_value incoming_value_ptr)
        (llvm:store incoming_value_null incoming_value_null_ptr)
        (llvm:br 'extract_value_from_pair_br)))
    (llvm:label 'extract_value_from_pair_br
      (let* ((incoming_value_null (llvm:load incoming_value_null_ptr |i1|)))
        (llvm:br incoming_value_null 'error 'extract_label_from_pair)))
    (llvm:label 'extract_label_from_pair
      (let* ((current_pair (llvm:load current_pair_ptr |%ASTNode*|))
             (pair_node_ptr (llvm:gep |%ASTNode| current_pair 0 4))
             (pair_node (llvm:load pair_node_ptr |%ASTNode*|))
             (pair_cdr_ptr (llvm:gep |%ASTNode| pair_node 0 5))
             (pair_cdr (llvm:load pair_cdr_ptr |%ASTNode*|))
             (label_node_ptr (llvm:gep |%ASTNode| pair_cdr 0 4))
             (label_node (llvm:load label_node_ptr |%ASTNode*|))
             (phi_extract_result (llvm:call extract_quoted_atom label_node phi_label_name_out phi_label_len_out))
             (phi_extract_failed (llvm:icmp 'ne phi_extract_result (llvm:const-int |i32| 0))))
        (llvm:br phi_extract_failed 'error 'get_phi_bb)))
    (llvm:label 'get_phi_bb
      (let* ((phi_label_name (llvm:load phi_label_name_out |i8*|))
             (phi_label_len (llvm:load phi_label_len_out |i64|))
             (phi_func_ptr (llvm:gep |%CodeGen| cg 0 8))
             (phi_func (llvm:load phi_func_ptr |i8*|))
             (incoming_bb (llvm:call codegen_get_or_create_label cg phi_func phi_label_name phi_label_len))
             (incoming_bb_null (llvm:icmp 'eq incoming_bb (llvm:const-null |i8*|))))
        (llvm:store incoming_bb incoming_bb_ptr)
        (llvm:store incoming_bb_null incoming_bb_null_ptr)
        (llvm:br 'get_phi_bb_br)))
    (llvm:label 'get_phi_bb_br
      (let* ((incoming_bb_null (llvm:load incoming_bb_null_ptr |i1|)))
        (llvm:br incoming_bb_null 'error 'add_one_incoming)))
    (llvm:label 'add_one_incoming
      (let* ((phi (llvm:load phi_ptr |i8*|))
             (incoming_value (llvm:load incoming_value_ptr |i8*|))
             (incoming_bb (llvm:load incoming_bb_ptr |i8*|))
             (val_array (llvm:alloca |i8*|))
             (bb_array (llvm:alloca |i8*|)))
        (llvm:store incoming_value val_array)
        (llvm:store incoming_bb bb_array)
        (llvm:call llvm_add_incoming phi val_array bb_array (llvm:const-int |i32| 1))
        (llvm:br 'add_incoming_done)))
    (llvm:label 'add_incoming_done
      (let* ((current_pair (llvm:load current_pair_ptr |%ASTNode*|))
             (next_pair_ptr (llvm:gep |%ASTNode| current_pair 0 5))
             (next_pair (llvm:load next_pair_ptr |%ASTNode*|)))
        (llvm:store next_pair current_pair_ptr)
        (llvm:br 'phi_loop)))
    (llvm:label 'phi_done
      (let* ((phi (llvm:load phi_ptr |i8*|)))
        (llvm:store phi result_ptr)
        (llvm:br 'phi_ret)))
    (llvm:label 'phi_ret
      (llvm:ret (llvm:load result_ptr |i8*|)))
    (llvm:label 'error
      (llvm:ret (llvm:const-null |i8*|)))))

