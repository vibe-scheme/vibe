             (name_len_int (llvm:trunc name_len |i64| |i32|))
             (cmp_result (llvm:call strncmp name stored_name name_len_int))
             (is_match (llvm:icmp 'eq cmp_result (llvm:const-int |i32| 0))))
        (llvm:br is_match 'found_local 'next_cons)))
    (llvm:label 'found_local
      (let* ((pair_val (llvm:load pair_ptr |%ASTNode*|))
             (pair_cdr_ptr (llvm:gep |%ASTNode| pair_val 0 5))
             (value_list (llvm:load pair_cdr_ptr |%ASTNode*|))
             (value_list_null (llvm:icmp 'eq value_list (llvm:const-null |%ASTNode*|))))
        (llvm:br value_list_null 'not_found 'get_value_node)))
    (llvm:label 'get_value_node
      (let* ((pair_val (llvm:load pair_ptr |%ASTNode*|))
             (value_list (llvm:load (llvm:gep |%ASTNode| pair_val 0 5) |%ASTNode*|))
             (value_list_car_ptr (llvm:gep |%ASTNode| value_list 0 4))
             (value_node (llvm:load value_list_car_ptr |%ASTNode*|))
             (value_node_null (llvm:icmp 'eq value_node (llvm:const-null |%ASTNode*|))))
        (llvm:br value_node_null 'not_found 'extract_value)))
    (llvm:label 'extract_value
      (let* ((pair_val (llvm:load pair_ptr |%ASTNode*|))
             (value_list (llvm:load (llvm:gep |%ASTNode| pair_val 0 5) |%ASTNode*|))
             (value_node (llvm:load (llvm:gep |%ASTNode| value_list 0 4) |%ASTNode*|))
             (value_as_ptr (llvm:load (llvm:gep |%ASTNode| value_node 0 2) |i8*|)))
        (llvm:ret value_as_ptr)))
    (llvm:label 'next_cons
      (let* ((cons_val (llvm:load current_cons_ptr |%ASTNode*|))
             (cons_cdr_ptr (llvm:gep |%ASTNode| cons_val 0 5))
             (next_cons_val (llvm:load cons_cdr_ptr |%ASTNode*|)))
        (llvm:store next_cons_val current_cons_ptr)
        (llvm:br 'search_loop)))
    (llvm:label 'not_found
      (llvm:ret (llvm:const-null |i8*|)))))

;; codegen_dsl_bind_local: Bind a local value to a name in the locals list
(llvm:define-function (codegen_dsl_bind_local (cg |%CodeGen*|) (name |i8*|) (name_len |i64|) (value |i8*|)) |void|
  (let* ((name_buf (llvm:call malloc name_len))
         (name_node (llvm:call malloc (llvm:const-int |i64| 48)))
         (name_node_ptr (llvm:bitcast name_node |%ASTNode*|)))
    (llvm:call memcpy name_buf name name_len)
    (llvm:store (llvm:const-int |i32| 0) (llvm:gep |%ASTNode| name_node_ptr 0 0))
    (llvm:store (llvm:const-int |i32| 1) (llvm:gep |%ASTNode| name_node_ptr 0 1))
    (llvm:store name_buf (llvm:gep |%ASTNode| name_node_ptr 0 2))
    (llvm:store name_len (llvm:gep |%ASTNode| name_node_ptr 0 3))
    (llvm:store (llvm:const-null |i8*|) (llvm:gep |%ASTNode| name_node_ptr 0 4))
    (llvm:store (llvm:const-null |i8*|) (llvm:gep |%ASTNode| name_node_ptr 0 5))
    (let* ((value_node (llvm:call create_pointer_node value))
           (pair (llvm:call create_pair name_node_ptr value_node))
           (local_values_ptr (llvm:gep |%CodeGen| cg 0 10))
           (current_locals (llvm:load local_values_ptr |%ASTNode*|))
           (new_cons (llvm:call create_cons pair current_locals)))
      (llvm:store new_cons local_values_ptr)
      (llvm:ret-void))))

;; codegen_dsl_resolve_param: Look up parameter by name in param_names list
;; Parameters: cg, name, name_len
;; Returns: LLVMValueRef for parameter, or null if not found
(llvm:define-function (codegen_dsl_resolve_param (cg |%CodeGen*|) (name |i8*|) (name_len |i64|)) |i8*|
  (let* ((current_pair (llvm:alloca |%ASTNode*|))
         (index (llvm:alloca |i32|))
         (name_node_final_ptr (llvm:alloca |%ASTNode*|))
         (name_is_null (llvm:icmp 'eq name (llvm:const-null |i8*|)))
         (name_len_too_large (llvm:icmp 'ugt name_len (llvm:const-int |i64| 1000))))
    (llvm:label 'entry
      (llvm:br name_is_null 'return_null 'check_name_len))
    (llvm:label 'return_null
      (llvm:ret (llvm:const-null |i8*|)))
    (llvm:label 'check_name_len
      (llvm:br name_len_too_large 'return_null 'get_param_names))
    (llvm:label 'get_param_names
      (let* ((param_names_ptr (llvm:gep |%CodeGen| cg 0 9))
             (param_names (llvm:load param_names_ptr |%ASTNode*|))
             (param_names_null (llvm:icmp 'eq param_names (llvm:const-null |%ASTNode*|)))
             (current_function_ptr (llvm:gep |%CodeGen| cg 0 8))
             (current_function (llvm:load current_function_ptr |i8*|))
             (func_null (llvm:icmp 'eq current_function (llvm:const-null |i8*|)))
             (any_null (llvm:or param_names_null func_null)))
        (llvm:store param_names current_pair)
        (llvm:store (llvm:const-int |i32| 0) index)
        (llvm:br any_null 'not_found 'search_params)))
    (llvm:label 'search_params
      (llvm:br 'search_loop))
    (llvm:label 'search_loop
      (let* ((pair_val (llvm:load current_pair |%ASTNode*|))
             (pair_null (llvm:icmp 'eq pair_val (llvm:const-null |%ASTNode*|))))
        (llvm:br pair_null 'not_found 'check_pair)))
    (llvm:label 'check_pair
      (let* ((pair_val (llvm:load current_pair |%ASTNode*|))
             (actual_pair_ptr (llvm:gep |%ASTNode| pair_val 0 4))
             (actual_pair (llvm:load actual_pair_ptr |%ASTNode*|))
             (actual_pair_null (llvm:icmp 'eq actual_pair (llvm:const-null |%ASTNode*|))))
        (llvm:br actual_pair_null 'next_pair 'get_name_node)))
    (llvm:label 'get_name_node
      (let* ((pair_val (llvm:load current_pair |%ASTNode*|))
             (actual_pair (llvm:load (llvm:gep |%ASTNode| pair_val 0 4) |%ASTNode*|))
             (pair_car_ptr (llvm:gep |%ASTNode| actual_pair 0 4))
             (name_node (llvm:load pair_car_ptr |%ASTNode*|))
             (name_node_null (llvm:icmp 'eq name_node (llvm:const-null |%ASTNode*|))))
        (llvm:br name_node_null 'next_pair 'check_name_node_type)))
    (llvm:label 'check_name_node_type
      (let* ((pair_val (llvm:load current_pair |%ASTNode*|))
             (actual_pair (llvm:load (llvm:gep |%ASTNode| pair_val 0 4) |%ASTNode*|))
             (name_node (llvm:load (llvm:gep |%ASTNode| actual_pair 0 4) |%ASTNode*|))
             (name_node_type_ptr (llvm:gep |%ASTNode| name_node 0 0))
             (name_node_type (llvm:load name_node_type_ptr |i32|))
             (is_list (llvm:icmp 'eq name_node_type (llvm:const-int |i32| 1))))
        (llvm:store name_node name_node_final_ptr)
        (llvm:br is_list 'extract_atom 'get_stored_name_common)))
    (llvm:label 'extract_atom
      (let* ((pair_val (llvm:load current_pair |%ASTNode*|))
             (actual_pair (llvm:load (llvm:gep |%ASTNode| pair_val 0 4) |%ASTNode*|))
             (name_node (llvm:load (llvm:gep |%ASTNode| actual_pair 0 4) |%ASTNode*|))
             (list_car_ptr (llvm:gep |%ASTNode| name_node 0 4))
             (list_car (llvm:load list_car_ptr |%ASTNode*|))
             (list_car_null (llvm:icmp 'eq list_car (llvm:const-null |%ASTNode*|))))
        (llvm:br list_car_null 'next_pair 'check_car_atom)))
    (llvm:label 'check_car_atom
      (let* ((pair_val (llvm:load current_pair |%ASTNode*|))
             (actual_pair (llvm:load (llvm:gep |%ASTNode| pair_val 0 4) |%ASTNode*|))
             (name_node (llvm:load (llvm:gep |%ASTNode| actual_pair 0 4) |%ASTNode*|))
             (list_car (llvm:load (llvm:gep |%ASTNode| name_node 0 4) |%ASTNode*|))
             (list_car_type_ptr (llvm:gep |%ASTNode| list_car 0 0))
             (list_car_type (llvm:load list_car_type_ptr |i32|))
             (list_car_is_atom (llvm:icmp 'eq list_car_type (llvm:const-int |i32| 0))))
        (llvm:store list_car name_node_final_ptr)
        (llvm:br list_car_is_atom 'get_stored_name_common 'next_pair)))
    (llvm:label 'get_stored_name_common
      (let* ((name_node_final (llvm:load name_node_final_ptr |%ASTNode*|))
             (stored_name (llvm:load (llvm:gep |%ASTNode| name_node_final 0 2) |i8*|))
             (stored_name_len (llvm:load (llvm:gep |%ASTNode| name_node_final 0 3) |i64|))
             (stored_null (llvm:icmp 'eq stored_name (llvm:const-null |i8*|)))
             (stored_len_zero (llvm:icmp 'eq stored_name_len (llvm:const-int |i64| 0)))
             (cannot_compare (llvm:or stored_null stored_len_zero))
             (len_match (llvm:icmp 'eq name_len stored_name_len)))
        (llvm:br cannot_compare 'next_pair 'do_compare)))
    (llvm:label 'do_compare
      (let* ((name_node_final (llvm:load name_node_final_ptr |%ASTNode*|))
             (stored_name (llvm:load (llvm:gep |%ASTNode| name_node_final 0 2) |i8*|))
             (stored_name_len (llvm:load (llvm:gep |%ASTNode| name_node_final 0 3) |i64|))
             (len_match (llvm:icmp 'eq name_len stored_name_len)))
        (llvm:br len_match 'compare_names 'next_pair)))
    (llvm:label 'compare_names
      (let* ((name_node_final (llvm:load name_node_final_ptr |%ASTNode*|))
             (stored_name (llvm:load (llvm:gep |%ASTNode| name_node_final 0 2) |i8*|))
             (name_len_int (llvm:trunc name_len |i64| |i32|))
             (cmp_result (llvm:call strncmp name stored_name name_len_int))
             (is_match (llvm:icmp 'eq cmp_result (llvm:const-int |i32| 0))))
        (llvm:br is_match 'found 'next_pair)))
    (llvm:label 'found
      (let* ((pair_val (llvm:load current_pair |%ASTNode*|))
             (actual_pair (llvm:load (llvm:gep |%ASTNode| pair_val 0 4) |%ASTNode*|))
             (pair_cdr_ptr (llvm:gep |%ASTNode| actual_pair 0 5))
             (pair_cdr_list (llvm:load pair_cdr_ptr |%ASTNode*|))
             (pair_cdr_null (llvm:icmp 'eq pair_cdr_list (llvm:const-null |%ASTNode*|))))
        (llvm:br pair_cdr_null 'not_found 'get_param_value_node)))
    (llvm:label 'get_param_value_node
      (let* ((pair_val (llvm:load current_pair |%ASTNode*|))
             (actual_pair (llvm:load (llvm:gep |%ASTNode| pair_val 0 4) |%ASTNode*|))
             (pair_cdr_list (llvm:load (llvm:gep |%ASTNode| actual_pair 0 5) |%ASTNode*|))
             (index_list_car_ptr (llvm:gep |%ASTNode| pair_cdr_list 0 4))
             (param_value_node (llvm:load index_list_car_ptr |%ASTNode*|))
             (param_value_null (llvm:icmp 'eq param_value_node (llvm:const-null |%ASTNode*|))))
        (llvm:br param_value_null 'not_found 'check_param_type)))
    (llvm:label 'check_param_type
      (let* ((pair_val (llvm:load current_pair |%ASTNode*|))
             (actual_pair (llvm:load (llvm:gep |%ASTNode| pair_val 0 4) |%ASTNode*|))
             (pair_cdr_list (llvm:load (llvm:gep |%ASTNode| actual_pair 0 5) |%ASTNode*|))
             (param_value_node (llvm:load (llvm:gep |%ASTNode| pair_cdr_list 0 4) |%ASTNode*|))
             (param_value_atom_type_ptr (llvm:gep |%ASTNode| param_value_node 0 1))
             (param_value_atom_type (llvm:load param_value_atom_type_ptr |i32|))
             (is_pointer (llvm:icmp 'eq param_value_atom_type (llvm:const-int |i32| 999)))
             (is_number (llvm:icmp 'eq param_value_atom_type (llvm:const-int |i32| 2))))
        (llvm:br is_pointer 'cast_back_param 'check_if_index)))
    (llvm:label 'check_if_index
      (let* ((pair_val (llvm:load current_pair |%ASTNode*|))
             (actual_pair (llvm:load (llvm:gep |%ASTNode| pair_val 0 4) |%ASTNode*|))
             (pair_cdr_list (llvm:load (llvm:gep |%ASTNode| actual_pair 0 5) |%ASTNode*|))
             (param_value_node (llvm:load (llvm:gep |%ASTNode| pair_cdr_list 0 4) |%ASTNode*|))
             (param_value_atom_type (llvm:load (llvm:gep |%ASTNode| param_value_node 0 1) |i32|))
             (is_number (llvm:icmp 'eq param_value_atom_type (llvm:const-int |i32| 2))))
        (llvm:br is_number 'lookup_by_index 'not_found)))
    (llvm:label 'cast_back_param
      (let* ((pair_val (llvm:load current_pair |%ASTNode*|))
             (actual_pair (llvm:load (llvm:gep |%ASTNode| pair_val 0 4) |%ASTNode*|))
             (pair_cdr_list (llvm:load (llvm:gep |%ASTNode| actual_pair 0 5) |%ASTNode*|))
             (param_value_node (llvm:load (llvm:gep |%ASTNode| pair_cdr_list 0 4) |%ASTNode*|))
             (param_value_ptr_field (llvm:gep |%ASTNode| param_value_node 0 2))
             (param_value_ptr (llvm:load param_value_ptr_field |i8*|)))
        (llvm:ret param_value_ptr)))
    (llvm:label 'lookup_by_index
      (let* ((pair_val (llvm:load current_pair |%ASTNode*|))
             (actual_pair (llvm:load (llvm:gep |%ASTNode| pair_val 0 4) |%ASTNode*|))
             (pair_cdr_list (llvm:load (llvm:gep |%ASTNode| actual_pair 0 5) |%ASTNode*|))
             (param_value_node (llvm:load (llvm:gep |%ASTNode| pair_cdr_list 0 4) |%ASTNode*|))
             (index_from_ast (llvm:call parse_int_from_ast param_value_node))
             (current_function_ptr (llvm:gep |%CodeGen| cg 0 8))
             (current_function (llvm:load current_function_ptr |i8*|))
             (func_null (llvm:icmp 'eq current_function (llvm:const-null |i8*|)))
             (param_count (llvm:call llvm_count_params current_function))
             (index_valid (llvm:icmp 'ult index_from_ast param_count)))
        (llvm:br func_null 'not_found 'check_index_valid)))
    (llvm:label 'check_index_valid
      (let* ((pair_val (llvm:load current_pair |%ASTNode*|))
             (actual_pair (llvm:load (llvm:gep |%ASTNode| pair_val 0 4) |%ASTNode*|))
             (pair_cdr_list (llvm:load (llvm:gep |%ASTNode| actual_pair 0 5) |%ASTNode*|))
             (param_value_node (llvm:load (llvm:gep |%ASTNode| pair_cdr_list 0 4) |%ASTNode*|))
             (index_from_ast (llvm:call parse_int_from_ast param_value_node))
             (current_function (llvm:load (llvm:gep |%CodeGen| cg 0 8) |i8*|))
             (param_count (llvm:call llvm_count_params current_function))
             (index_valid (llvm:icmp 'ult index_from_ast param_count)))
        (llvm:br index_valid 'lookup_param 'not_found)))
    (llvm:label 'lookup_param
      (let* ((pair_val (llvm:load current_pair |%ASTNode*|))
             (actual_pair (llvm:load (llvm:gep |%ASTNode| pair_val 0 4) |%ASTNode*|))
             (pair_cdr_list (llvm:load (llvm:gep |%ASTNode| actual_pair 0 5) |%ASTNode*|))
             (param_value_node (llvm:load (llvm:gep |%ASTNode| pair_cdr_list 0 4) |%ASTNode*|))
             (index_from_ast (llvm:call parse_int_from_ast param_value_node))
             (current_function (llvm:load (llvm:gep |%CodeGen| cg 0 8) |i8*|))
             (param_lookup (llvm:call llvm_get_param current_function index_from_ast)))
        (llvm:ret param_lookup)))
    (llvm:label 'next_pair
      (let* ((pair_val (llvm:load current_pair |%ASTNode*|))
             (index_val (llvm:load index |i32|))
             (index_new (llvm:add index_val (llvm:const-int |i32| 1)))
             (pair_cdr_next (llvm:gep |%ASTNode| pair_val 0 5))
             (next_pair_val (llvm:load pair_cdr_next |%ASTNode*|)))
        (llvm:store index_new index)
        (llvm:store next_pair_val current_pair)
        (llvm:br 'search_loop)))
    (llvm:label 'not_found
      (llvm:ret (llvm:const-null |i8*|)))))

;; codegen_collect_param_types: Extract and resolve parameter types from params list
;; Parameters: cg, params (AST list of (param-name type) pairs), array (LLVMTypeRef*), max_count
;; Returns: number of parameters collected
(llvm:define-function (codegen_collect_param_types (cg |%CodeGen*|) (params |%ASTNode*|) (array |i8*|) (max_count |i32|)) |i32|
  (let* ((count (llvm:alloca |i32|))
         (current_ptr (llvm:alloca |%ASTNode*|))
         (params_null (llvm:icmp 'eq params (llvm:const-null |%ASTNode*|))))
    (llvm:store (llvm:const-int |i32| 0) count)
    (llvm:label 'entry
      (llvm:br params_null 'return_zero 'collect_loop))
    (llvm:label 'return_zero
      (llvm:ret (llvm:const-int |i32| 0)))
    (llvm:label 'collect_loop
      (llvm:store params current_ptr)
      (llvm:br 'collect_iter))
    (llvm:label 'collect_iter
      (let* ((current_val (llvm:load current_ptr |%ASTNode*|))
             (current_null (llvm:icmp 'eq current_val (llvm:const-null |%ASTNode*|))))
        (llvm:br current_null 'return_count 'get_param_type)))
    (llvm:label 'get_param_type
      (let* ((count_val (llvm:load count |i32|))
             (count_ge_max (llvm:icmp 'uge count_val max_count)))
        (llvm:br count_ge_max 'return_count 'extract_type)))
    (llvm:label 'extract_type
      (let* ((current_val (llvm:load current_ptr |%ASTNode*|))
             (car_ptr (llvm:gep |%ASTNode| current_val 0 4))
             (param_pair (llvm:load car_ptr |%ASTNode*|))
             (param_pair_null (llvm:icmp 'eq param_pair (llvm:const-null |%ASTNode*|))))
        (llvm:br param_pair_null 'return_count 'get_pair_cdr)))
    (llvm:label 'get_pair_cdr
      (let* ((current_val (llvm:load current_ptr |%ASTNode*|))
             (car_ptr (llvm:gep |%ASTNode| current_val 0 4))
             (param_pair (llvm:load car_ptr |%ASTNode*|))
             (pair_cdr_ptr (llvm:gep |%ASTNode| param_pair 0 5))
             (pair_cdr (llvm:load pair_cdr_ptr |%ASTNode*|))
             (pair_cdr_null (llvm:icmp 'eq pair_cdr (llvm:const-null |%ASTNode*|))))
        (llvm:br pair_cdr_null 'return_count 'get_type_node)))
    (llvm:label 'get_type_node
      (let* ((current_val (llvm:load current_ptr |%ASTNode*|))
             (car_ptr (llvm:gep |%ASTNode| current_val 0 4))
             (param_pair (llvm:load car_ptr |%ASTNode*|))
             (pair_cdr_ptr (llvm:gep |%ASTNode| param_pair 0 5))
             (pair_cdr (llvm:load pair_cdr_ptr |%ASTNode*|))
             (type_node_ptr (llvm:gep |%ASTNode| pair_cdr 0 4))
             (type_node (llvm:load type_node_ptr |%ASTNode*|))
             (type_node_null (llvm:icmp 'eq type_node (llvm:const-null |%ASTNode*|))))
        (llvm:br type_node_null 'return_count 'get_type_string)))
    (llvm:label 'get_type_string
      (let* ((current_val (llvm:load current_ptr |%ASTNode*|))
             (car_ptr (llvm:gep |%ASTNode| current_val 0 4))
             (param_pair (llvm:load car_ptr |%ASTNode*|))
             (pair_cdr_ptr (llvm:gep |%ASTNode| param_pair 0 5))
             (pair_cdr (llvm:load pair_cdr_ptr |%ASTNode*|))
             (type_node_ptr (llvm:gep |%ASTNode| pair_cdr 0 4))
             (type_node (llvm:load type_node_ptr |%ASTNode*|))
             (type_val_ptr (llvm:gep |%ASTNode| type_node 0 2))
             (type_str (llvm:load type_val_ptr |i8*|))
             (type_len_ptr (llvm:gep |%ASTNode| type_node 0 3))
             (type_len (llvm:load type_len_ptr |i64|))
             (type_str_null (llvm:icmp 'eq type_str (llvm:const-null |i8*|)))
             (type_len_zero (llvm:icmp 'eq type_len (llvm:const-int |i64| 0)))
             (type_invalid (llvm:or type_str_null type_len_zero)))
        (llvm:br type_invalid 'return_count 'resolve_type)))
    (llvm:label 'resolve_type
      (let* ((current_val (llvm:load current_ptr |%ASTNode*|))
             (car_ptr (llvm:gep |%ASTNode| current_val 0 4))
             (param_pair (llvm:load car_ptr |%ASTNode*|))
             (pair_cdr_ptr (llvm:gep |%ASTNode| param_pair 0 5))
             (pair_cdr (llvm:load pair_cdr_ptr |%ASTNode*|))
             (type_node_ptr (llvm:gep |%ASTNode| pair_cdr 0 4))
             (type_node (llvm:load type_node_ptr |%ASTNode*|))
             (type_val_ptr (llvm:gep |%ASTNode| type_node 0 2))
             (type_str (llvm:load type_val_ptr |i8*|))
             (type_len_ptr (llvm:gep |%ASTNode| type_node 0 3))
             (type_len (llvm:load type_len_ptr |i64|))
             (param_type (llvm:call codegen_resolve_type_string cg type_str type_len))
             (param_type_null (llvm:icmp 'eq param_type (llvm:const-null |i8*|))))
        (llvm:br param_type_null 'return_count 'store_param_type)))
    (llvm:label 'store_param_type
      (let* ((current_val (llvm:load current_ptr |%ASTNode*|))
             (car_ptr (llvm:gep |%ASTNode| current_val 0 4))
             (param_pair (llvm:load car_ptr |%ASTNode*|))
             (pair_cdr_ptr (llvm:gep |%ASTNode| param_pair 0 5))
             (pair_cdr (llvm:load pair_cdr_ptr |%ASTNode*|))
             (type_node_ptr (llvm:gep |%ASTNode| pair_cdr 0 4))
             (type_node (llvm:load type_node_ptr |%ASTNode*|))
             (type_val_ptr (llvm:gep |%ASTNode| type_node 0 2))
             (type_str (llvm:load type_val_ptr |i8*|))
             (type_len_ptr (llvm:gep |%ASTNode| type_node 0 3))
             (type_len (llvm:load type_len_ptr |i64|))
             (param_type (llvm:call codegen_resolve_type_string cg type_str type_len))
             (count_for_idx (llvm:load count |i32|))
             (array_idx (llvm:gep |i8*| array count_for_idx))
             (count_new (llvm:add count_for_idx (llvm:const-int |i32| 1)))
             (cdr_ptr (llvm:gep |%ASTNode| current_val 0 5))
             (cdr (llvm:load cdr_ptr |%ASTNode*|)))
        (llvm:store param_type array_idx)
        (llvm:store count_new count)
        (llvm:store cdr current_ptr)
        (llvm:br 'collect_iter)))
    (llvm:label 'return_count
      (llvm:ret (llvm:load count |i32|)))))

;; codegen_build_param_names: Create AST list of (name . index) pairs from params
;; Parameters: cg (CodeGen*), func (LLVMValueRef), params (AST list of (param-name type) pairs)
;; Returns: ASTNode* list of (name . index) pairs, or null if params is null
(llvm:define-function (codegen_build_param_names (cg |%CodeGen*|) (func |i8*|) (params |%ASTNode*|)) |%ASTNode*|
  (let* ((result_ptr (llvm:alloca |%ASTNode*|))
         (current_ptr (llvm:alloca |%ASTNode*|))
         (index_ptr (llvm:alloca |i32|))
