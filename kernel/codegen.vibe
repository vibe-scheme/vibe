             (extract_failed (llvm:icmp 'ne extract_result (llvm:const-int |i32| 0))))
        (llvm:br extract_failed 'error 'map_predicate)))
    (llvm:label 'map_predicate
      (let* ((pred_name (llvm:load pred_name_out |i8*|))
             (pred_len (llvm:load pred_len_out |i64|))
             (pred_enum (llvm:call map_predicate_string pred_name pred_len))
             (is_neg_one (llvm:icmp 'eq pred_enum (llvm:const-int |i32| -1)))
             (below_range (llvm:icmp 'ult pred_enum (llvm:const-int |i32| 32)))
             (above_range (llvm:icmp 'ugt pred_enum (llvm:const-int |i32| 41)))
