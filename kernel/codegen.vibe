    (llvm:label 'check_terminator
      (let* ((block (llvm:load block_ptr |i8*|))
             (label_terminator (llvm:call llvm_get_basic_block_terminator block))
             (label_has_no_term (llvm:icmp 'eq label_terminator (llvm:const-null |i8*|))))
        (llvm:store label_has_no_term label_has_no_term_ptr)
        (llvm:br 'check_terminator_br)))
    (llvm:label 'check_terminator_br
      (let* ((label_has_no_term (llvm:load label_has_no_term_ptr |i1|)))
        (llvm:br label_has_no_term 'error 'check_restore)))
    (llvm:label 'check_restore
      (let* ((builder_ptr (llvm:gep |%CodeGen| cg 0 7))
             (builder (llvm:load builder_ptr |i8*|))
             (block (llvm:load block_ptr |i8*|))
             (current_block_after (llvm:call llvm_get_insert_block builder))
             (current_block_null (llvm:icmp 'eq current_block_after (llvm:const-null |i8*|))))
        (llvm:store current_block_null current_block_null_ptr)
        (llvm:br 'check_restore_br)))
    (llvm:label 'check_restore_br
      (let* ((current_block_null (llvm:load current_block_null_ptr |i1|)))
        (llvm:br current_block_null 'return_block 'check_if_still_on_label)))
    (llvm:label 'check_if_still_on_label
      (let* ((builder_ptr (llvm:gep |%CodeGen| cg 0 7))
             (builder (llvm:load builder_ptr |i8*|))
             (block (llvm:load block_ptr |i8*|))
             (current_block_after (llvm:call llvm_get_insert_block builder))
             (still_on_label (llvm:icmp 'eq current_block_after block)))
        (llvm:store still_on_label still_on_label_ptr)
        (llvm:br 'check_if_still_on_label_br)))
    (llvm:label 'check_if_still_on_label_br
      (let* ((still_on_label (llvm:load still_on_label_ptr |i1|)))
        (llvm:br still_on_label 'return_block 'check_saved_null)))
    (llvm:label 'check_saved_null
      (let* ((saved_block (llvm:load saved_block_ptr |i8*|))
             (saved_block_null (llvm:icmp 'eq saved_block (llvm:const-null |i8*|))))
        (llvm:store saved_block_null saved_block_null_ptr)
        (llvm:br 'check_saved_null_br)))
    (llvm:label 'check_saved_null_br
      (let* ((saved_block_null (llvm:load saved_block_null_ptr |i1|)))
        (llvm:br saved_block_null 'return_block 'restore_position)))
    (llvm:label 'restore_position
