           (car_ptr (llvm:gep |%ASTNode| current_val 0 4))
           (pair (llvm:load car_ptr |%ASTNode*|))
           (pair_cdr_ptr (llvm:gep |%ASTNode| pair 0 5))
           (value_node (llvm:load pair_cdr_ptr |%ASTNode*|))
           (value_ptr_field (llvm:gep |%ASTNode| value_node 0 2))
           (value_ptr (llvm:load value_ptr_field |i8*|)))
      (llvm:ret value_ptr)))
    (llvm:label 'next
    (let* ((current_val (llvm:load current |%ASTNode*|))
           (cdr_ptr (llvm:gep |%ASTNode| current_val 0 5))
           (cdr (llvm:load cdr_ptr |%ASTNode*|)))
      (llvm:store cdr current)
      (llvm:br 'iterate)))
    (llvm:label 'not_found
      (llvm:ret (llvm:const-null |i8*|)))))

;; ============================================================================
;; Batch 3: codegen_write_bytevector_to_buffer
;; Write bytevector data with escaping to buffer.
;; ============================================================================
(llvm:define-function (codegen_write_bytevector_to_buffer (buf |i8*|) (pos |i64*|) (data |i8*|) (len |i64|)) |void|
  (let* ((i (llvm:alloca |i64|)))
    (llvm:store (llvm:const-int |i64| 0) i)
    (llvm:br 'loop)
    (llvm:label 'loop
    (let* ((i_val (llvm:load i |i64|))
           (done (llvm:icmp 'uge i_val len)))
      (llvm:br done 'exit 'process_byte))
    (llvm:label 'process_byte
    (let* ((i_val (llvm:load i |i64|))
           (byte_ptr (llvm:gep |i8| data i_val))
           (byte (llvm:load byte_ptr |i8|))
           (byte_int (llvm:zext byte |i8| |i32|))
           (is_null (llvm:icmp 'eq byte_int (llvm:const-int |i32| 0))))
      (llvm:br is_null 'escape_null 'check_quote)))
  (llvm:label 'escape_null
    (let* ((pos_val (llvm:load pos |i64|))
           (dest (llvm:gep |i8| buf pos_val))
           (backslash00 (llvm:gep |[4 x i8]| (llvm:get-global .str.backslash_00) 0 0))
           (pos_val2 (llvm:add pos_val (llvm:const-int |i64| 3))))
      (llvm:call memcpy dest backslash00 (llvm:const-int |i64| 3))
      (llvm:store pos_val2 pos)
      (llvm:br 'increment)))
    (llvm:label 'check_quote
    (let* ((i_val (llvm:load i |i64|))
           (byte_ptr (llvm:gep |i8| data i_val))
           (byte (llvm:load byte_ptr |i8|))
           (byte_int (llvm:zext byte |i8| |i32|))
           (is_quote (llvm:icmp 'eq byte_int (llvm:const-int |i32| 34))))
      (llvm:br is_quote 'escape_quote 'check_backslash)))
    (llvm:label 'escape_quote
    (let* ((pos_val (llvm:load pos |i64|))
           (dest (llvm:gep |i8| buf pos_val))
           (backslash_quote (llvm:gep |[3 x i8]| (llvm:get-global .str.backslash_quote) 0 0))
           (pos_val2 (llvm:add pos_val (llvm:const-int |i64| 2))))
      (llvm:call memcpy dest backslash_quote (llvm:const-int |i64| 2))
      (llvm:store pos_val2 pos)
      (llvm:br 'increment)))
    (llvm:label 'check_backslash
    (let* ((i_val (llvm:load i |i64|))
           (byte_ptr (llvm:gep |i8| data i_val))
           (byte (llvm:load byte_ptr |i8|))
           (byte_int (llvm:zext byte |i8| |i32|))
           (is_backslash (llvm:icmp 'eq byte_int (llvm:const-int |i32| 92))))
      (llvm:br is_backslash 'escape_backslash 'normal_byte)))
    (llvm:label 'escape_backslash
    (let* ((pos_val (llvm:load pos |i64|))
           (dest (llvm:gep |i8| buf pos_val))
           (backslash_backslash (llvm:gep |[3 x i8]| (llvm:get-global .str.backslash_backslash) 0 0))
           (pos_val2 (llvm:add pos_val (llvm:const-int |i64| 2))))
      (llvm:call memcpy dest backslash_backslash (llvm:const-int |i64| 2))
      (llvm:store pos_val2 pos)
      (llvm:br 'increment)))
    (llvm:label 'normal_byte
    (let* ((i_val (llvm:load i |i64|))
           (pos_val (llvm:load pos |i64|))
           (dest (llvm:gep |i8| buf pos_val))
           (byte_ptr (llvm:gep |i8| data i_val))
           (pos_val2 (llvm:add pos_val (llvm:const-int |i64| 1))))
      (llvm:call memcpy dest byte_ptr (llvm:const-int |i64| 1))
      (llvm:store pos_val2 pos)
      (llvm:br 'increment)))
    (llvm:label 'increment
    (let* ((i_val (llvm:load i |i64|))
           (i_new (llvm:add i_val (llvm:const-int |i64| 1))))
      (llvm:store i_new i)
      (llvm:br 'loop))
    (llvm:label 'exit
      (llvm:ret-void))))))

;; ============================================================================
;; Batch 3: codegen_extract_function_name
;; Extract function name from function IR text.
;; ============================================================================
(llvm:define-function (codegen_extract_function_name (func_ir |i8*|) (func_ir_len |i64|)) |i8*|
  (let* ((ir_null (llvm:icmp 'eq func_ir (llvm:const-null |i8*|)))
         (ir_len_zero (llvm:icmp 'eq func_ir_len (llvm:const-int |i64| 0)))
         (ir_invalid (llvm:or ir_null ir_len_zero))
         (pos (llvm:alloca |i64|))
         (name_end_pos (llvm:alloca |i64|))
         (name_buf_ptr (llvm:alloca |i8*|)))
    (llvm:br ir_invalid 'error 'find_at_sign)
    (llvm:label 'find_at_sign
    (llvm:store (llvm:const-int |i64| 0) pos)
    (llvm:br 'search_loop))
    (llvm:label 'search_loop
    (let* ((pos_val (llvm:load pos |i64|))
           (done (llvm:icmp 'uge pos_val func_ir_len)))
      (llvm:br done 'error 'check_char)))
    (llvm:label 'check_char
    (let* ((pos_val (llvm:load pos |i64|))
           (char_ptr (llvm:gep |i8| func_ir pos_val))
           (char (llvm:load char_ptr |i8|))
           (char_int (llvm:zext char |i8| |i32|))
           (is_at (llvm:icmp 'eq char_int (llvm:const-int |i32| 64))))
      (llvm:br is_at 'found_at 'increment)))
    (llvm:label 'increment
    (let* ((pos_val (llvm:load pos |i64|))
           (pos_next (llvm:add pos_val (llvm:const-int |i64| 1))))
      (llvm:store pos_next pos)
      (llvm:br 'search_loop)))
    (llvm:label 'found_at
    (let* ((pos_val (llvm:load pos |i64|))
           (name_start_pos (llvm:add pos_val (llvm:const-int |i64| 1))))
      (llvm:store name_start_pos name_end_pos)
      (llvm:br 'find_paren)))
    (llvm:label 'find_paren
    (let* ((end_pos_val (llvm:load name_end_pos |i64|))
           (end_done (llvm:icmp 'uge end_pos_val func_ir_len)))
      (llvm:br end_done 'error 'check_paren)))
    (llvm:label 'check_paren
    (let* ((end_pos_val (llvm:load name_end_pos |i64|))
           (paren_ptr (llvm:gep |i8| func_ir end_pos_val))
           (paren_char (llvm:load paren_ptr |i8|))
           (paren_int (llvm:zext paren_char |i8| |i32|))
           (is_paren (llvm:icmp 'eq paren_int (llvm:const-int |i32| 40))))
      (llvm:br is_paren 'extract_name 'increment_end)))
    (llvm:label 'increment_end
    (let* ((end_pos_val (llvm:load name_end_pos |i64|))
           (end_pos_next (llvm:add end_pos_val (llvm:const-int |i64| 1))))
      (llvm:store end_pos_next name_end_pos)
      (llvm:br 'find_paren)))
    (llvm:label 'extract_name
    (let* ((pos_val (llvm:load pos |i64|))
           (name_start_pos (llvm:add pos_val (llvm:const-int |i64| 1)))
           (end_pos_val (llvm:load name_end_pos |i64|))
           (name_len (llvm:sub end_pos_val name_start_pos))
           (name_len_zero (llvm:icmp 'eq name_len (llvm:const-int |i64| 0))))
      (llvm:br name_len_zero 'error 'alloc_name)))
    (llvm:label 'alloc_name
    (let* ((pos_val (llvm:load pos |i64|))
           (name_start_pos (llvm:add pos_val (llvm:const-int |i64| 1)))
           (end_pos_val (llvm:load name_end_pos |i64|))
           (name_len (llvm:sub end_pos_val name_start_pos))
           (name_buf_size (llvm:add name_len (llvm:const-int |i64| 1)))
           (name_buf (llvm:call malloc name_buf_size))
           (name_buf_null (llvm:icmp 'eq name_buf (llvm:const-null |i8*|))))
      (llvm:store name_buf name_buf_ptr)
      (llvm:br name_buf_null 'error 'copy_name)))
    (llvm:label 'copy_name
    (let* ((pos_val (llvm:load pos |i64|))
           (name_start_pos (llvm:add pos_val (llvm:const-int |i64| 1)))
           (end_pos_val (llvm:load name_end_pos |i64|))
           (name_len (llvm:sub end_pos_val name_start_pos))
           (name_buf (llvm:load name_buf_ptr |i8*|))
           (name_src (llvm:gep |i8| func_ir name_start_pos))
           (null_ptr (llvm:gep |i8| name_buf name_len)))
      (llvm:call memcpy name_buf name_src name_len)
      (llvm:store (llvm:const-int |i8| 0) null_ptr)
      (llvm:ret name_buf))
    (llvm:label 'error
      (llvm:ret (llvm:const-null |i8*|))))))

;; ============================================================================
;; Batch 3: codegen_append_string_constant
;; Append string constant definition to IR.
;; ============================================================================
(llvm:define-function (codegen_append_string_constant (cg |%CodeGen*|) (name |i8*|) (str |i8*|) (len |i64|)) |void|
  (let* ((at_sign (llvm:gep |[2 x i8]| (llvm:get-global .str.at_sign) 0 0))
         (name_len (llvm:call strlen name))
         (constant_decl (llvm:gep |[22 x i8]| (llvm:get-global .str.constant_decl) 0 0))
         (len_plus_one (llvm:add len (llvm:const-int |i64| 1)))
         (len_str (llvm:call format_number len_plus_one))
         (len_str_len (llvm:call strlen len_str))
         (x_i8_c_quote (llvm:gep |[10 x i8]| (llvm:get-global .str.x_i8_c_quote) 0 0))
         (backslash_00 (llvm:gep |[4 x i8]| (llvm:get-global .str.backslash_00) 0 0))
         (quote_newline (llvm:gep |[3 x i8]| (llvm:get-global .str.quote_newline) 0 0)))
    (llvm:call codegen_append cg at_sign (llvm:const-int |i64| 1))
    (llvm:call codegen_append cg name name_len)
    (llvm:call codegen_append cg constant_decl (llvm:const-int |i64| 21))
    (llvm:call codegen_append cg len_str len_str_len)
    (llvm:call codegen_append cg x_i8_c_quote (llvm:const-int |i64| 9))
    (llvm:call codegen_append_escaped_string cg str len)
    (llvm:call codegen_append cg backslash_00 (llvm:const-int |i64| 3))
    (llvm:call codegen_append cg quote_newline (llvm:const-int |i64| 2))
    (llvm:ret-void)))

;; ============================================================================
;; Minimal repro for let* + store + br DSL bug (see docs/design/let-star-store-br-bug-resolution-plan.md)
;; When this compiles successfully, the bug is fixed.
;; ============================================================================
(llvm:define-function (test_store_br_bug ()) |void|
  (llvm:label 'entry
    (let* ((ptr (llvm:alloca |i32|)))
      (llvm:store (llvm:const-int |i32| 42) ptr)
      (llvm:br 'exit)))
  (llvm:label 'exit
    (llvm:ret-void)))

;; Conditional br in let* (repros bug - see let-star-store-br-bug-resolution-plan.md)
(llvm:define-function (test_cond_br_in_let ()) |void|
  (llvm:label 'entry
    (let* ((x (llvm:alloca |i1|))
           (cond (llvm:const-int |i1| 1)))
      (llvm:store cond x)
      (llvm:br cond 'then 'else)))
  (llvm:label 'then (llvm:ret-void))
  (llvm:label 'else (llvm:ret-void)))

;; ============================================================================
;; codegen_define_string_constant_only
;; Generate string constant definition only (without reference).
;; Used during codegen_collect_string_constants phase.
;; Parameters: cg (CodeGen*), str (i8*), len (i64)
;; Returns: i8* constant name (e.g. ".str.0")
;; ============================================================================
(llvm:define-function (codegen_define_string_constant_only (cg |%CodeGen*|) (str |i8*|) (len |i64|)) |i8*|
  (let* ((counter_ptr (llvm:gep |%CodeGen| cg 0 3))
         (counter (llvm:load counter_ptr |i32|))
         (new_counter (llvm:add counter (llvm:const-int |i32| 1)))
         (name (llvm:call codegen_format_string_name counter))
         (context_ptr (llvm:gep |%CodeGen| cg 0 5))
         (context (llvm:load context_ptr |i8*|))
         (module_ptr (llvm:gep |%CodeGen| cg 0 6))
         (module (llvm:load module_ptr |i8*|))
         (context_null (llvm:icmp 'eq context (llvm:const-null |i8*|)))
         (module_null (llvm:icmp 'eq module (llvm:const-null |i8*|)))
         (can_use_llvm (llvm:or context_null module_null)))
    (llvm:store new_counter counter_ptr)
    (llvm:br can_use_llvm 'text_only 'create_llvm_constant))
  (llvm:label 'create_llvm_constant
    (let* ((counter_ptr (llvm:gep |%CodeGen| cg 0 3))
           (stored_counter (llvm:load counter_ptr |i32|))
           (prev_counter (llvm:sub stored_counter (llvm:const-int |i32| 1)))
           (name (llvm:call codegen_format_string_name prev_counter))
           (context_ptr (llvm:gep |%CodeGen| cg 0 5))
           (context (llvm:load context_ptr |i8*|))
           (module_ptr (llvm:gep |%CodeGen| cg 0 6))
           (module (llvm:load module_ptr |i8*|))
           (i8_type (llvm:call llvm_get_int8_type context))
           (len_plus_one (llvm:add len (llvm:const-int |i64| 1)))
           (len_plus_one_int (llvm:trunc len_plus_one |i64| |i32|))
           (array_type (llvm:call llvm_get_array_type i8_type len_plus_one_int))
           (str_len_int (llvm:trunc len |i64| |i32|))
           (const_str (llvm:call llvm_create_constant_string context str str_len_int (llvm:const-int |i32| 0)))
           (global (llvm:call llvm_add_global module array_type name)))
      (llvm:call llvm_set_initializer global const_str)
      (llvm:call llvm_set_global_constant global (llvm:const-int |i32| 1))
      (llvm:call llvm_set_linkage global (llvm:const-int |i32| 0))
      (llvm:br 'text_only)))
  (llvm:label 'text_only
    (let* ((counter_ptr (llvm:gep |%CodeGen| cg 0 3))
           (stored_counter (llvm:load counter_ptr |i32|))
           (prev_counter (llvm:sub stored_counter (llvm:const-int |i32| 1)))
           (name (llvm:call codegen_format_string_name prev_counter)))
      (llvm:call codegen_append_string_constant cg name str len)
      (llvm:ret name))))

;; ============================================================================
;; codegen_string_literal
;; Generate string constant in IR (creates definition and returns name).
;; Same implementation as codegen_define_string_constant_only.
;; Parameters: cg (CodeGen*), str (i8*), len (i64)
;; Returns: i8* constant name
;; ============================================================================
(llvm:define-function (codegen_string_literal (cg |%CodeGen*|) (str |i8*|) (len |i64|)) |i8*|
  (llvm:ret (llvm:call codegen_define_string_constant_only cg str len)))


;; ============================================================================
;; codegen_parse_function_ir
;; Parse function IR text, wrap in a module, and link into the main module.
;; Parameters: cg (CodeGen*), func_ir (i8*), func_ir_len (i64)
;; Returns: 0 on success, -1 on error
;; ============================================================================
;; String constants for IR module wrapping
(llvm:define-constant .str.data_layout_prefix |[22 x i8]| #u8(116 97 114 103 101 116 32 100 97 116 97 108 97 121 111 117 116 32 61 32 34 0))
(llvm:define-constant .str.data_layout_suffix |[3 x i8]| #u8(34 10 0))
(llvm:define-constant .str.target_triple_prefix |[18 x i8]| #u8(116 97 114 103 101 116 32 116 114 105 112 108 101 32 61 32 34 0))
(llvm:define-constant .str.target_triple_suffix |[4 x i8]| #u8(34 10 10 0))

(llvm:define-function (codegen_parse_function_ir (cg |%CodeGen*|) (func_ir |i8*|) (func_ir_len |i64|)) |i32|
  (let* ((temp_module_ptr (llvm:alloca |i8*|))
         (context_ptr (llvm:gep |%CodeGen| cg 0 5))
         (context (llvm:load context_ptr |i8*|))
         (context_null (llvm:icmp 'eq context (llvm:const-null |i8*|))))
    (llvm:store (llvm:const-null |i8*|) temp_module_ptr)
    (llvm:br context_null 'error 'wrap_module)
    (llvm:label 'wrap_module)
    (let* ((ir_text_null (llvm:icmp 'eq func_ir (llvm:const-null |i8*|)))
           (ir_len_zero (llvm:icmp 'eq func_ir_len (llvm:const-int |i64| 0)))
           (ir_invalid (llvm:or ir_text_null ir_len_zero)))
      (llvm:br ir_invalid 'error 'wrap_module_valid))
    (llvm:label 'wrap_module_valid)
    (let* ((dl_prefix_len (llvm:const-int |i64| 21))
           (dl_val_len (llvm:const-int |i64| 34))
           (dl_suffix_len (llvm:const-int |i64| 2))
           (tt_prefix_len (llvm:const-int |i64| 17))
           (tt_val_len (llvm:const-int |i64| 17))
           (tt_suffix_len (llvm:const-int |i64| 3))
           (total_prefix (llvm:add (llvm:add (llvm:add dl_prefix_len dl_val_len) dl_suffix_len)
                                   (llvm:add (llvm:add tt_prefix_len tt_val_len) tt_suffix_len)))
           (module_ir_size (llvm:add total_prefix func_ir_len))
           (module_ir_size2 (llvm:add module_ir_size (llvm:const-int |i64| 1)))
           (module_ir_buf (llvm:call malloc module_ir_size2))
           (buf_null (llvm:icmp 'eq module_ir_buf (llvm:const-null |i8*|))))
      (llvm:br buf_null 'error 'build_module_ir))
    (llvm:label 'build_module_ir)
    (let* ((pos (llvm:alloca |i64|))
           (buf_ptr (llvm:alloca |i8*|)))
      (llvm:store (llvm:const-int |i64| 0) pos)
      (let* ((ir_size_recalc (llvm:add (llvm:add (llvm:add (llvm:const-int |i64| 21) (llvm:const-int |i64| 34)) (llvm:const-int |i64| 2))
                                       (llvm:add (llvm:add (llvm:const-int |i64| 17) (llvm:const-int |i64| 17)) (llvm:const-int |i64| 3))))
             (total_size (llvm:add (llvm:add ir_size_recalc func_ir_len) (llvm:const-int |i64| 1)))
             (ir_buf (llvm:call malloc total_size)))
        (llvm:store ir_buf buf_ptr)
        (let* ((p0 (llvm:load pos |i64|))
               (d0 (llvm:gep |i8| ir_buf p0)))
          (llvm:call memcpy d0 (llvm:gep |[22 x i8]| (llvm:get-global .str.data_layout_prefix) 0 0) (llvm:const-int |i64| 21))
          (let* ((p1 (llvm:add p0 (llvm:const-int |i64| 21)))
                 (d1 (llvm:gep |i8| ir_buf p1)))
            (llvm:store p1 pos)
            (llvm:call memcpy d1 (llvm:gep |[34 x i8]| (llvm:get-global .str.data_layout_value) 0 0) (llvm:const-int |i64| 34))
            (let* ((p2 (llvm:add p1 (llvm:const-int |i64| 34)))
                   (d2 (llvm:gep |i8| ir_buf p2)))
              (llvm:store p2 pos)
              (llvm:call memcpy d2 (llvm:gep |[3 x i8]| (llvm:get-global .str.data_layout_suffix) 0 0) (llvm:const-int |i64| 2))
              (let* ((p3 (llvm:add p2 (llvm:const-int |i64| 2)))
                     (d3 (llvm:gep |i8| ir_buf p3)))
                (llvm:store p3 pos)
                (llvm:call memcpy d3 (llvm:gep |[18 x i8]| (llvm:get-global .str.target_triple_prefix) 0 0) (llvm:const-int |i64| 17))
                (let* ((p4 (llvm:add p3 (llvm:const-int |i64| 17)))
                       (d4 (llvm:gep |i8| ir_buf p4)))
                  (llvm:store p4 pos)
                  (llvm:call memcpy d4 (llvm:gep |[19 x i8]| (llvm:get-global .str.target_triple_value) 0 0) (llvm:const-int |i64| 17))
                  (let* ((p5 (llvm:add p4 (llvm:const-int |i64| 17)))
                         (d5 (llvm:gep |i8| ir_buf p5)))
                    (llvm:store p5 pos)
                    (llvm:call memcpy d5 (llvm:gep |[4 x i8]| (llvm:get-global .str.target_triple_suffix) 0 0) (llvm:const-int |i64| 3))
                    (let* ((p6 (llvm:add p5 (llvm:const-int |i64| 3)))
                           (func_dest (llvm:gep |i8| ir_buf p6)))
                      (llvm:store p6 pos)
                      (llvm:call memcpy func_dest func_ir func_ir_len)
                      (let* ((p7 (llvm:add p6 func_ir_len))
                             (nl_ptr (llvm:gep |i8| ir_buf p7)))
                        (llvm:store (llvm:const-int |i8| 10) nl_ptr)
                        (let* ((p8 (llvm:add p7 (llvm:const-int |i64| 1)))
                               (null_end (llvm:gep |i8| ir_buf p8)))
                          (llvm:store (llvm:const-int |i8| 0) null_end)
                          (let* ((total_len (llvm:sub p8 (llvm:const-int |i64| 1))))
                            (llvm:br 'parse_module)))))))))))))
    (llvm:label 'parse_module)
    (let* ((ir_buf2 (llvm:load buf_ptr |i8*|))
           (total_prefix2 (llvm:add (llvm:add (llvm:add (llvm:const-int |i64| 21) (llvm:const-int |i64| 34)) (llvm:const-int |i64| 2))
                                    (llvm:add (llvm:add (llvm:const-int |i64| 17) (llvm:const-int |i64| 17)) (llvm:const-int |i64| 3))))
           (total_len2 (llvm:add total_prefix2 func_ir_len))
           (context2 (llvm:load (llvm:gep |%CodeGen| cg 0 5) |i8*|))
           (parse_result (llvm:call llvm_parse_ir_in_context context2 ir_buf2 total_len2 temp_module_ptr)))
      (llvm:call free ir_buf2)
      (let* ((parse_failed (llvm:icmp 'ne parse_result (llvm:const-int |i32| 0))))
        (llvm:br parse_failed 'parse_error_cleanup 'check_temp_module)))
    (llvm:label 'parse_error_cleanup)
    (llvm:ret (llvm:const-int |i32| -1))
    (llvm:label 'check_temp_module)
    (let* ((temp_module_check (llvm:load temp_module_ptr |i8*|))
           (temp_null (llvm:icmp 'eq temp_module_check (llvm:const-null |i8*|))))
      (llvm:br temp_null 'error 'success_parse))
    (llvm:label 'success_parse)
    (let* ((main_module_ptr (llvm:gep |%CodeGen| cg 0 6))
           (main_module (llvm:load main_module_ptr |i8*|))
           (main_null (llvm:icmp 'eq main_module (llvm:const-null |i8*|))))
      (llvm:br main_null 'dispose_temp_and_error 'link_modules))
    (llvm:label 'link_modules)
    (let* ((temp_module (llvm:load temp_module_ptr |i8*|))
           (temp_null2 (llvm:icmp 'eq temp_module (llvm:const-null |i8*|))))
      (llvm:br temp_null2 'error 'do_link))
    (llvm:label 'do_link)
    (let* ((main_mod (llvm:load (llvm:gep |%CodeGen| cg 0 6) |i8*|))
           (temp_mod (llvm:load temp_module_ptr |i8*|))
           (link_result (llvm:call llvm_link_modules2 main_mod temp_mod))
           (link_failed (llvm:icmp 'ne link_result (llvm:const-int |i32| 0))))
      (llvm:br link_failed 'dispose_and_error 'return_success))
    (llvm:label 'return_success)
    (llvm:ret (llvm:const-int |i32| 0))
    (llvm:label 'dispose_temp_and_error)
    (let* ((temp_for_err (llvm:load temp_module_ptr |i8*|))
           (temp_err_null (llvm:icmp 'eq temp_for_err (llvm:const-null |i8*|))))
      (llvm:br temp_err_null 'error 'dispose_temp_error))
    (llvm:label 'dispose_temp_error)
    (llvm:call llvm_dispose_module (llvm:load temp_module_ptr |i8*|))
    (llvm:br 'error)
    (llvm:label 'dispose_and_error)
    (let* ((temp_for_disp (llvm:load temp_module_ptr |i8*|))
           (temp_disp_null (llvm:icmp 'eq temp_for_disp (llvm:const-null |i8*|))))
      (llvm:br temp_disp_null 'error 'dispose_temp_module_error))
    (llvm:label 'dispose_temp_module_error)
    (llvm:call llvm_dispose_module (llvm:load temp_module_ptr |i8*|))
    (llvm:br 'error)
    (llvm:label 'error)
    (llvm:ret (llvm:const-int |i32| -1))))

(llvm:define-constant .str.entry_block_name |[6 x i8]| #u8(101 110 116 114 121 0))

;; ============================================================================
;; codegen_define_llvm_function
;; Process define-llvm-function form using DSL
;; AST: (define-llvm-function (name (p1 t1) ...) return-type (dsl-body ...))
;; Returns: 0 on success, -1 on error
;; ============================================================================
(llvm:define-function (codegen_define_llvm_function (cg |%CodeGen*|) (node |%ASTNode*|)) |i32|
  (let* ((dsl_body_ptr (llvm:alloca |%ASTNode*|))
         (func_type_val_ptr (llvm:alloca |i8*|))
         (func_ref_ptr (llvm:alloca |i8*|))
         (param_types_arr_ptr (llvm:alloca |i8*|))
         (func_name_store (llvm:alloca |i8*|))
         (func_name_len_store (llvm:alloca |i64|))
         (params_list_store (llvm:alloca |%ASTNode*|))
         (return_type_ref_store (llvm:alloca |i8*|))
         (entry_bb_store (llvm:alloca |i8*|))
         (builder_store (llvm:alloca |i8*|))
         (param_names_store (llvm:alloca |%ASTNode*|)))
    (llvm:label 'entry
      ;; Clear local_values at start
      (let* ((local_values_field (llvm:gep |%CodeGen| cg 0 10)))
        (llvm:store (llvm:const-null |%ASTNode*|) local_values_field)
        ;; Parse AST: node.cdr = (sig return-type body)
        (let* ((cdr (llvm:load (llvm:gep |%ASTNode| node 0 5) |%ASTNode*|))
               (sig_list (llvm:load (llvm:gep |%ASTNode| cdr 0 4) |%ASTNode*|))
               (func_name_node (llvm:load (llvm:gep |%ASTNode| sig_list 0 4) |%ASTNode*|))
               (func_name (llvm:load (llvm:gep |%ASTNode| func_name_node 0 2) |i8*|))
               (func_name_len (llvm:load (llvm:gep |%ASTNode| func_name_node 0 3) |i64|))
               (params_list (llvm:load (llvm:gep |%ASTNode| sig_list 0 5) |%ASTNode*|))
               (cdr_cdr (llvm:load (llvm:gep |%ASTNode| cdr 0 5) |%ASTNode*|))
               (return_type_node (llvm:load (llvm:gep |%ASTNode| cdr_cdr 0 4) |%ASTNode*|))
               (return_type (llvm:load (llvm:gep |%ASTNode| return_type_node 0 2) |i8*|))
               (return_type_len (llvm:load (llvm:gep |%ASTNode| return_type_node 0 3) |i64|))
               (cdr_cdr_cdr (llvm:load (llvm:gep |%ASTNode| cdr_cdr 0 5) |%ASTNode*|))
               (cdr_cdr_cdr_null (llvm:icmp 'eq cdr_cdr_cdr (llvm:const-null |%ASTNode*|))))
          (llvm:store func_name func_name_store)
          (llvm:store func_name_len func_name_len_store)
          (llvm:store params_list params_list_store)
          ;; Resolve return type
          (let* ((rt_ref (llvm:call codegen_resolve_type_string cg return_type return_type_len))
                 (rt_null (llvm:icmp 'eq rt_ref (llvm:const-null |i8*|))))
            (llvm:store rt_ref return_type_ref_store)
            (llvm:br cdr_cdr_cdr_null 'error 'try_body_direct)))))
    (llvm:label 'try_body_direct
      ;; Re-navigate to cdr_cdr_cdr
      (let* ((cdr (llvm:load (llvm:gep |%ASTNode| node 0 5) |%ASTNode*|))
             (cdr_cdr (llvm:load (llvm:gep |%ASTNode| cdr 0 5) |%ASTNode*|))
             (cdr_cdr_cdr (llvm:load (llvm:gep |%ASTNode| cdr_cdr 0 5) |%ASTNode*|))
             (body_type (llvm:load (llvm:gep |%ASTNode| cdr_cdr_cdr 0 0) |i32|))
             (is_list (llvm:icmp 'eq body_type (llvm:const-int |i32| 1))))
        (llvm:store cdr_cdr_cdr dsl_body_ptr)
        (llvm:br is_list 'check_context 'try_body_car)))
    (llvm:label 'try_body_car
      (let* ((cdr (llvm:load (llvm:gep |%ASTNode| node 0 5) |%ASTNode*|))
             (cdr_cdr (llvm:load (llvm:gep |%ASTNode| cdr 0 5) |%ASTNode*|))
             (cdr_cdr_cdr (llvm:load (llvm:gep |%ASTNode| cdr_cdr 0 5) |%ASTNode*|))
             (body_car (llvm:load (llvm:gep |%ASTNode| cdr_cdr_cdr 0 4) |%ASTNode*|)))
        (llvm:store body_car dsl_body_ptr)
        (llvm:br 'check_context)))
    (llvm:label 'check_context
      (let* ((context (llvm:load (llvm:gep |%CodeGen| cg 0 5) |i8*|))
             (module (llvm:load (llvm:gep |%CodeGen| cg 0 6) |i8*|))
             (ctx_null (llvm:icmp 'eq context (llvm:const-null |i8*|)))
             (mod_null (llvm:icmp 'eq module (llvm:const-null |i8*|)))
             (any_null (llvm:or ctx_null mod_null))
             (rt_ref (llvm:load return_type_ref_store |i8*|))
             (rt_null (llvm:icmp 'eq rt_ref (llvm:const-null |i8*|)))
             (any_problem (llvm:or any_null rt_null)))
        (llvm:br any_problem 'error 'collect_params)))
    (llvm:label 'collect_params
      (let* ((params_list (llvm:load params_list_store |%ASTNode*|))
             (param_types_array (llvm:call malloc (llvm:const-int |i64| 80)))
             (param_types_typed (llvm:bitcast param_types_array |i8**|))
             (param_count (llvm:call codegen_collect_param_types cg params_list param_types_typed (llvm:const-int |i32| 10)))
             (has_params (llvm:icmp 'ne param_count (llvm:const-int |i32| 0))))
        (llvm:store param_types_array param_types_arr_ptr)
        (llvm:br has_params 'create_func_type_with_params 'create_func_type_no_params)))
    (llvm:label 'create_func_type_with_params
      (let* ((rt_ref (llvm:load return_type_ref_store |i8*|))
             (pta (llvm:load param_types_arr_ptr |i8*|))
             (pta_typed (llvm:bitcast pta |i8**|))
             (params_list (llvm:load params_list_store |%ASTNode*|))
             (param_count (llvm:call codegen_collect_param_types cg params_list pta_typed (llvm:const-int |i32| 10)))
             (ft (llvm:call llvm_create_function_type rt_ref pta_typed param_count (llvm:const-int |i32| 0))))
        (llvm:store ft func_type_val_ptr)
        (llvm:br 'check_func_type)))
    (llvm:label 'create_func_type_no_params
      (let* ((rt_ref (llvm:load return_type_ref_store |i8*|))
             (ft (llvm:call llvm_create_function_type rt_ref (llvm:const-null |i8*|) (llvm:const-int |i32| 0) (llvm:const-int |i32| 0))))
        (llvm:store ft func_type_val_ptr)
        (llvm:br 'check_func_type)))
    (llvm:label 'check_func_type
      (let* ((ft (llvm:load func_type_val_ptr |i8*|))
             (ft_null (llvm:icmp 'eq ft (llvm:const-null |i8*|))))
        (llvm:br ft_null 'free_param_types 'add_function)))
    (llvm:label 'free_param_types
      (let* ((pta (llvm:load param_types_arr_ptr |i8*|)))
        (llvm:call free pta)
        (llvm:br 'error)))
    (llvm:label 'add_function
      (let* ((fn (llvm:load func_name_store |i8*|))
             (fn_len (llvm:load func_name_len_store |i64|))
             (module (llvm:load (llvm:gep |%CodeGen| cg 0 6) |i8*|))
             (buf_size (llvm:add fn_len (llvm:const-int |i64| 1)))
             (name_buf (llvm:call malloc buf_size))
             (dummy (llvm:call memcpy name_buf fn fn_len))
             (null_pos (llvm:gep |i8| name_buf fn_len)))
        (llvm:store (llvm:const-int |i8| 0) null_pos)
        (let* ((existing (llvm:call llvm_get_named_function module name_buf))
               (existing_null (llvm:icmp 'eq existing (llvm:const-null |i8*|))))
          (llvm:br existing_null 'create_new_function 'reuse_existing_function))))
    (llvm:label 'create_new_function
      (let* ((module (llvm:load (llvm:gep |%CodeGen| cg 0 6) |i8*|))
             (fn (llvm:load func_name_store |i8*|))
             (fn_len (llvm:load func_name_len_store |i64|))
             (buf_size (llvm:add fn_len (llvm:const-int |i64| 1)))
             (name_buf (llvm:call malloc buf_size))
             (dummy (llvm:call memcpy name_buf fn fn_len))
             (null_pos (llvm:gep |i8| name_buf fn_len)))
        (llvm:store (llvm:const-int |i8| 0) null_pos)
        (let* ((ft (llvm:load func_type_val_ptr |i8*|))
               (new_func (llvm:call llvm_add_function module name_buf ft))
               (new_func_null (llvm:icmp 'eq new_func (llvm:const-null |i8*|))))
          (llvm:call free name_buf)
          (llvm:store new_func func_ref_ptr)
          (llvm:br new_func_null 'free_param_types 'set_param_names))))
    (llvm:label 'reuse_existing_function
      (let* ((module (llvm:load (llvm:gep |%CodeGen| cg 0 6) |i8*|))
             (fn (llvm:load func_name_store |i8*|))
             (fn_len (llvm:load func_name_len_store |i64|))
             (buf_size (llvm:add fn_len (llvm:const-int |i64| 1)))
             (name_buf (llvm:call malloc buf_size))
             (dummy (llvm:call memcpy name_buf fn fn_len))
             (null_pos (llvm:gep |i8| name_buf fn_len)))
        (llvm:store (llvm:const-int |i8| 0) null_pos)
        (let* ((existing (llvm:call llvm_get_named_function module name_buf)))
          (llvm:call free name_buf)
          (llvm:store existing func_ref_ptr)
          (llvm:br 'set_param_names))))
    (llvm:label 'set_param_names
      (let* ((func_val (llvm:load func_ref_ptr |i8*|))
             (context (llvm:load (llvm:gep |%CodeGen| cg 0 5) |i8*|))
             (entry_name (llvm:gep |[6 x i8]| (llvm:get-global .str.entry_block_name) 0 0))
             (entry_bb (llvm:call llvm_append_basic_block func_val entry_name))
             (builder (llvm:call llvm_create_builder context))
             (builder_null (llvm:icmp 'eq builder (llvm:const-null |i8*|))))
        (llvm:store entry_bb entry_bb_store)
        (llvm:store builder builder_store)
        (llvm:br builder_null 'free_param_types 'position_builder)))
    (llvm:label 'position_builder
      (let* ((builder (llvm:load builder_store |i8*|))
             (entry_bb (llvm:load entry_bb_store |i8*|))
             (func_val (llvm:load func_ref_ptr |i8*|))
             (params_list (llvm:load params_list_store |%ASTNode*|)))
        (llvm:call llvm_position_builder_at_end builder entry_bb)
        (let* ((param_names_list (llvm:call codegen_build_param_names cg func_val params_list)))
          (llvm:store param_names_list param_names_store)
          (llvm:br 'store_and_eval))))
    (llvm:label 'store_and_eval
      (let* ((func_val (llvm:load func_ref_ptr |i8*|))
             (builder (llvm:load builder_store |i8*|))
             (param_names_list (llvm:load param_names_store |%ASTNode*|))
             (fn (llvm:load func_name_store |i8*|))
             (fn_len (llvm:load func_name_len_store |i64|))
             (ft (llvm:load func_type_val_ptr |i8*|))
             (dsl_body (llvm:load dsl_body_ptr |%ASTNode*|)))
        ;; Store func, builder, param_names in CodeGen
        (llvm:store func_val (llvm:gep |%CodeGen| cg 0 8))
        (llvm:store builder (llvm:gep |%CodeGen| cg 0 7))
        (llvm:store param_names_list (llvm:gep |%CodeGen| cg 0 9))
        ;; Store function for later retrieval
        (llvm:call codegen_store_llvm_function cg fn fn_len func_val ft)
