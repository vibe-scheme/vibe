;; ============================================================================
;; codegen_eval_dsl_expr
;; Recursively evaluate DSL AST expression.
;; Handles atoms (symbols, numbers, strings), quotes, let*, and primitive dispatch.
;; Returns: LLVMValueRef for expressions that produce values, null for statements.
;; ============================================================================
(llvm:define-function (codegen_eval_dsl_expr (cg |%CodeGen*|) (expr |%ASTNode*|)) |i8*|
