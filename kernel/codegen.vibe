;; ============================================================================
;; create_int_node - in codegen for now (util.vibe compiler stops before this)
;; Create an AST node for an integer value.
;; ============================================================================
(llvm:define-function (create_int_node (value |i32|)) |%ASTNode*|
  (let* ((node (llvm:call malloc (llvm:const-int |i64| 48)))
         (node_ptr (llvm:bitcast node |%ASTNode*|))
         (type_ptr (llvm:gep |%ASTNode| node_ptr 0 0))
         (atom_type_ptr (llvm:gep |%ASTNode| node_ptr 0 1))
