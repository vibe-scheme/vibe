             (args_cdr_cdr (llvm:load args_cdr_cdr_ptr |%ASTNode*|))
             (type_node_ptr (llvm:gep |%ASTNode| args_cdr_cdr 0 4))
             (type_node (llvm:load type_node_ptr |%ASTNode*|))
             (type_val_ptr (llvm:gep |%ASTNode| type_node 0 2))
             (type_str (llvm:load type_val_ptr |i8*|))
             (type_len_ptr (llvm:gep |%ASTNode| type_node 0 3))
             (type_len (llvm:load type_len_ptr |i64|))
             (target_type (llvm:call codegen_resolve_type_string cg type_str type_len))
             (target_type_null (llvm:icmp 'eq target_type (llvm:const-null |i8*|))))
