;; ============================================================================
;; Tier A: codegen_dsl_icmp
;; Handle llvm:icmp form. Syntax: (llvm:icmp 'pred lhs rhs)
;; ============================================================================
(llvm:define-function (codegen_dsl_icmp (cg |%CodeGen*|) (args |%ASTNode*|)) |i8*|
