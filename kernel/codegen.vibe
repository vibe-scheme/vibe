(llvm:define-constant .str.empty |[1 x i8]| #u8(0))

;; ============================================================================
;; 1. codegen_dsl_check_primitive - wrapper for check_primitive from util (for backward compat in codegen)
;; ============================================================================
(llvm:define-function (codegen_dsl_check_primitive (id |i8*|) (id_len |i64|) (target |i8*|) (target_len |i64|)) |i32|
  (llvm:ret (llvm:call check_primitive id id_len target target_len)))

;; ============================================================================
;; 2. codegen_append
;; Append string to CodeGen buffer, growing via realloc if needed.
;; Parameters: cg (CodeGen*), str (i8*), len (i64)
;; Returns: void
;; ============================================================================
(llvm:define-function (codegen_append (cg |%CodeGen*|) (str |i8*|) (len |i64|)) |void|
  (let* ((pos_ptr (llvm:gep |%CodeGen| cg 0 2))
         (pos (llvm:load pos_ptr |i64|))
         (size_ptr (llvm:gep |%CodeGen| cg 0 1))
         (size (llvm:load size_ptr |i64|))
         (new_pos (llvm:add pos len))
         (needs_grow (llvm:icmp 'ugt new_pos size)))
    (llvm:br needs_grow 'grow 'append)
    (llvm:label 'grow
    (let* ((size_val (llvm:load (llvm:gep |%CodeGen| cg 0 1) |i64|))
           (new_size (llvm:mul size_val (llvm:const-int |i64| 2)))
           (buffer_ptr (llvm:gep |%CodeGen| cg 0 0))
           (old_buffer (llvm:load buffer_ptr |i8*|))
           (new_buffer (llvm:call realloc old_buffer new_size))
           (size_ptr_grow (llvm:gep |%CodeGen| cg 0 1)))
      (llvm:store new_buffer buffer_ptr)
      (llvm:store new_size size_ptr_grow)
      (llvm:br 'append))
    (llvm:label 'append
      (let* ((buffer_ptr_append (llvm:gep |%CodeGen| cg 0 0))
             (buffer (llvm:load buffer_ptr_append |i8*|))
             (pos_val (llvm:load (llvm:gep |%CodeGen| cg 0 2) |i64|))
             (dest (llvm:gep |i8| buffer pos_val))
             (ignored (llvm:call memcpy dest str len))
             (new_pos_append (llvm:add pos_val len))
             (pos_ptr_append (llvm:gep |%CodeGen| cg 0 2)))
        (llvm:store new_pos_append pos_ptr_append)
        (llvm:ret-void))))))

;; ============================================================================
;; 11. codegen_collect_string_constants
;; Collect and generate string constants from expressions (recursive).
;; Parameters: cg (CodeGen*), exprs (ASTNode* list)
;; Returns: void
;; ============================================================================
(llvm:define-function (codegen_collect_string_constants (cg |%CodeGen*|) (exprs |%ASTNode*|)) |void|
  (let* ((is_null (llvm:icmp 'eq exprs (llvm:const-null |%ASTNode*|))))
    (llvm:br is_null 'done 'process_expr)
    (llvm:label 'process_expr
    (let* ((car_ptr (llvm:gep |%ASTNode| exprs 0 4))
           (expr (llvm:load car_ptr |%ASTNode*|))
           (expr_type_ptr (llvm:gep |%ASTNode| expr 0 0))
           (expr_type (llvm:load expr_type_ptr |i32|))
           (is_list (llvm:icmp 'eq expr_type (llvm:const-int |i32| 1))))
      (llvm:br is_list 'check_call 'next_expr)))
    (llvm:label 'check_call
    (let* ((car_ptr (llvm:gep |%ASTNode| exprs 0 4))
           (expr (llvm:load car_ptr |%ASTNode*|))
           (expr_cdr_ptr (llvm:gep |%ASTNode| expr 0 5))
           (args (llvm:load expr_cdr_ptr |%ASTNode*|)))
      (llvm:call codegen_collect_string_constants_from_args cg args)
      (llvm:br 'next_expr))
    (llvm:label 'next_expr
    (let* ((cdr_ptr (llvm:gep |%ASTNode| exprs 0 5))
           (next (llvm:load cdr_ptr |%ASTNode*|)))
      (llvm:call codegen_collect_string_constants cg next)
      (llvm:br 'done))
    (llvm:label 'done
      (llvm:ret-void))))))

;; ============================================================================
;; 12. codegen_collect_string_constants_from_args
;; Collect string constants from function call arguments (recursive).
;; Parameters: cg (CodeGen*), args (ASTNode* list)
;; Returns: void
;; ============================================================================
(llvm:define-function (codegen_collect_string_constants_from_args (cg |%CodeGen*|) (args |%ASTNode*|)) |void|
  (let* ((is_null (llvm:icmp 'eq args (llvm:const-null |%ASTNode*|))))
    (llvm:br is_null 'done 'check_arg)
    (llvm:label 'check_arg
    (let* ((car_ptr (llvm:gep |%ASTNode| args 0 4))
           (arg_node (llvm:load car_ptr |%ASTNode*|))
           (arg_type_ptr (llvm:gep |%ASTNode| arg_node 0 0))
           (arg_type (llvm:load arg_type_ptr |i32|))
           (is_atom (llvm:icmp 'eq arg_type (llvm:const-int |i32| 0))))
      (llvm:br is_atom 'check_string 'next_arg)))
    (llvm:label 'check_string
    (let* ((car_ptr (llvm:gep |%ASTNode| args 0 4))
           (arg_node (llvm:load car_ptr |%ASTNode*|))
           (atom_type_ptr (llvm:gep |%ASTNode| arg_node 0 1))
           (atom_type (llvm:load atom_type_ptr |i32|))
           (is_string (llvm:icmp 'eq atom_type (llvm:const-int |i32| 3))))
      (llvm:br is_string 'gen_constant 'next_arg)))
    (llvm:label 'gen_constant
    (let* ((car_ptr (llvm:gep |%ASTNode| args 0 4))
           (arg_node (llvm:load car_ptr |%ASTNode*|))
           (str_val_ptr (llvm:gep |%ASTNode| arg_node 0 2))
           (str_val (llvm:load str_val_ptr |i8*|))
           (str_len_ptr (llvm:gep |%ASTNode| arg_node 0 3))
           (str_len (llvm:load str_len_ptr |i64|)))
      (llvm:call codegen_define_string_constant_only cg str_val str_len)
      (llvm:br 'next_arg))
    (llvm:label 'next_arg
    (let* ((cdr_ptr (llvm:gep |%ASTNode| args 0 5))
           (next (llvm:load cdr_ptr |%ASTNode*|)))
      (llvm:call codegen_collect_string_constants_from_args cg next)
      (llvm:br 'done))
    (llvm:label 'done
      (llvm:ret-void))))))

;; ============================================================================
;; 13. codegen_format_string_name
;; Format string constant name (e.g., ".str.0").
;; Parameters: num (i32)
;; Returns: i8* buffer with formatted name
;; ============================================================================
(llvm:define-function (codegen_format_string_name (num |i32|)) |i8*|
  (let* ((buffer (llvm:call malloc (llvm:const-int |i64| 16)))
         (dot_str (llvm:gep |i8| buffer (llvm:const-int |i64| 0)))
         (s (llvm:gep |i8| buffer (llvm:const-int |i64| 1)))
         (t (llvm:gep |i8| buffer (llvm:const-int |i64| 2)))
         (r (llvm:gep |i8| buffer (llvm:const-int |i64| 3)))
         (dot2 (llvm:gep |i8| buffer (llvm:const-int |i64| 4)))
         (num_mod (llvm:urem num (llvm:const-int |i32| 10)))
         (num_char (llvm:add num_mod (llvm:const-int |i32| 48)))
         (num_trunc (llvm:trunc num_char |i32| |i8|))
         (num_ptr (llvm:gep |i8| buffer (llvm:const-int |i64| 5)))
         (null_ptr (llvm:gep |i8| buffer (llvm:const-int |i64| 6))))
    (llvm:store (llvm:const-int |i8| 46) dot_str)
    (llvm:store (llvm:const-int |i8| 115) s)
    (llvm:store (llvm:const-int |i8| 116) t)
    (llvm:store (llvm:const-int |i8| 114) r)
    (llvm:store (llvm:const-int |i8| 46) dot2)
    (llvm:store num_trunc num_ptr)
    (llvm:store (llvm:const-int |i8| 0) null_ptr)
    (llvm:ret buffer)))

;; ============================================================================
;; 15. codegen_store_type
;; Store type mapping in CodeGen structure.
;; Parameters: cg (CodeGen*), name (i8*), name_len (i64), type (LLVMTypeRef)
;; Returns: void
;; ============================================================================
(llvm:define-function (codegen_store_type (cg |%CodeGen*|) (name |i8*|) (name_len |i64|) (type |i8*|)) |void|
  (let* ((name_node (llvm:call create_string_node name name_len))
         (type_ptr_cast (llvm:bitcast type |i8*|))
         (type_node (llvm:call create_pointer_node type_ptr_cast))
         (pair (llvm:call create_cons name_node type_node))
         (types_ptr (llvm:gep |%CodeGen| cg 0 13))
         (current_types (llvm:load types_ptr |%ASTNode*|))
         (new_types (llvm:call create_cons pair current_types)))
    (llvm:store new_types types_ptr)
    (llvm:ret-void)))

;; ============================================================================
;; 16. codegen_get_type
;; Look up a type by name and return LLVMTypeRef.
;; Parameters: cg (CodeGen*), name (i8*), name_len (i64)
;; Returns: LLVMTypeRef for the type, or null if not found
;; ============================================================================
(llvm:define-function (codegen_get_type (cg |%CodeGen*|) (name |i8*|) (name_len |i64|)) |i8*|
  (let* ((types_ptr (llvm:gep |%CodeGen| cg 0 13))
         (types (llvm:load types_ptr |%ASTNode*|))
         (current_type (llvm:alloca |%ASTNode*|))
         (types_null (llvm:icmp 'eq types (llvm:const-null |%ASTNode*|))))
    (llvm:br types_null 'not_found_type 'search_loop_type)
    (llvm:label 'search_loop_type
      (llvm:store types current_type)
      (llvm:br 'iterate_type))
    (llvm:label 'iterate_type
      (let* ((current_val_type (llvm:load current_type |%ASTNode*|))
             (current_null_type (llvm:icmp 'eq current_val_type (llvm:const-null |%ASTNode*|))))
        (llvm:br current_null_type 'not_found_type 'check_pair_type)))
    (llvm:label 'check_pair_type
      (let* ((current_val_type (llvm:load current_type |%ASTNode*|))
             (car_ptr_type (llvm:gep |%ASTNode| current_val_type 0 4))
             (pair_type (llvm:load car_ptr_type |%ASTNode*|))
             (pair_null_type (llvm:icmp 'eq pair_type (llvm:const-null |%ASTNode*|))))
        (llvm:br pair_null_type 'next_type 'compare_name_type)))
    (llvm:label 'compare_name_type
      (let* ((current_val_type (llvm:load current_type |%ASTNode*|))
             (car_ptr_type (llvm:gep |%ASTNode| current_val_type 0 4))
             (pair_type (llvm:load car_ptr_type |%ASTNode*|))
             (pair_car_ptr_type (llvm:gep |%ASTNode| pair_type 0 4))
             (name_node_type (llvm:load pair_car_ptr_type |%ASTNode*|))
             (name_node_null_type (llvm:icmp 'eq name_node_type (llvm:const-null |%ASTNode*|))))
        (llvm:br name_node_null_type 'next_type 'get_name_type)))
    (llvm:label 'get_name_type
      (let* ((current_val_type (llvm:load current_type |%ASTNode*|))
             (car_ptr_type (llvm:gep |%ASTNode| current_val_type 0 4))
             (pair_type (llvm:load car_ptr_type |%ASTNode*|))
             (pair_car_ptr_type (llvm:gep |%ASTNode| pair_type 0 4))
             (name_node_type (llvm:load pair_car_ptr_type |%ASTNode*|))
             (stored_name_ptr_type (llvm:gep |%ASTNode| name_node_type 0 2))
             (stored_name_type (llvm:load stored_name_ptr_type |i8*|))
             (stored_len_ptr_type (llvm:gep |%ASTNode| name_node_type 0 3))
             (stored_len_type (llvm:load stored_len_ptr_type |i64|))
             (len_match_type (llvm:icmp 'eq stored_len_type name_len)))
        (llvm:br len_match_type 'compare_chars_type 'next_type)))
    (llvm:label 'compare_chars_type
      (let* ((current_val_type (llvm:load current_type |%ASTNode*|))
             (car_ptr_type (llvm:gep |%ASTNode| current_val_type 0 4))
             (pair_type (llvm:load car_ptr_type |%ASTNode*|))
             (pair_car_ptr_type (llvm:gep |%ASTNode| pair_type 0 4))
             (name_node_type (llvm:load pair_car_ptr_type |%ASTNode*|))
             (stored_name_ptr_type (llvm:gep |%ASTNode| name_node_type 0 2))
             (stored_name_type (llvm:load stored_name_ptr_type |i8*|))
             (len_int_type (llvm:trunc name_len |i64| |i32|))
             (cmp_result_type (llvm:call strncmp stored_name_type name len_int_type))
             (is_match_type (llvm:icmp 'eq cmp_result_type (llvm:const-int |i32| 0))))
        (llvm:br is_match_type 'found_type 'next_type)))
    (llvm:label 'found_type
      (let* ((current_val_type (llvm:load current_type |%ASTNode*|))
             (car_ptr_type (llvm:gep |%ASTNode| current_val_type 0 4))
             (pair_type (llvm:load car_ptr_type |%ASTNode*|))
             (pair_cdr_ptr_type (llvm:gep |%ASTNode| pair_type 0 5))
             (type_node (llvm:load pair_cdr_ptr_type |%ASTNode*|))
             (type_node_null (llvm:icmp 'eq type_node (llvm:const-null |%ASTNode*|))))
        (llvm:br type_node_null 'not_found_type 'extract_type)))
    (llvm:label 'extract_type
      (let* ((current_val_type (llvm:load current_type |%ASTNode*|))
             (car_ptr_type (llvm:gep |%ASTNode| current_val_type 0 4))
             (pair_type (llvm:load car_ptr_type |%ASTNode*|))
             (pair_cdr_ptr_type (llvm:gep |%ASTNode| pair_type 0 5))
             (type_node (llvm:load pair_cdr_ptr_type |%ASTNode*|))
             (type_atom_type_ptr (llvm:gep |%ASTNode| type_node 0 1))
             (type_atom_type (llvm:load type_atom_type_ptr |i32|))
             (is_pointer_type (llvm:icmp 'eq type_atom_type (llvm:const-int |i32| 999))))
        (llvm:br is_pointer_type 'cast_back_type 'not_found_type)))
    (llvm:label 'cast_back_type
      (let* ((current_val_type (llvm:load current_type |%ASTNode*|))
             (car_ptr_type (llvm:gep |%ASTNode| current_val_type 0 4))
             (pair_type (llvm:load car_ptr_type |%ASTNode*|))
             (pair_cdr_ptr_type (llvm:gep |%ASTNode| pair_type 0 5))
             (type_node (llvm:load pair_cdr_ptr_type |%ASTNode*|))
             (type_ptr_field (llvm:gep |%ASTNode| type_node 0 2))
             (type_ptr (llvm:load type_ptr_field |i8*|))
             (type_ref (llvm:bitcast type_ptr |i8*|)))
        (llvm:ret type_ref)))
    (llvm:label 'next_type
      (let* ((current_val_type (llvm:load current_type |%ASTNode*|))
             (cdr_ptr_type (llvm:gep |%ASTNode| current_val_type 0 5))
             (cdr_type (llvm:load cdr_ptr_type |%ASTNode*|)))
        (llvm:store cdr_type current_type)
        (llvm:br 'iterate_type)))
    (llvm:label 'not_found_type
      (llvm:ret (llvm:const-null |i8*|)))))

;; ============================================================================
;; codegen_resolve_type_string
;; Resolve a type string (e.g. "i32", "i8*", "[5 x i8]") to LLVMTypeRef.
;; Handles pointer suffix stripping recursively, primitive types, array types,
;; and named struct types via codegen_get_type.
;; ============================================================================
(llvm:define-constant .str.type_void |[5 x i8]| #u8(118 111 105 100 0))
(llvm:define-constant .str.type_i1 |[3 x i8]| #u8(105 49 0))
(llvm:define-constant .str.type_i8 |[3 x i8]| #u8(105 56 0))
(llvm:define-constant .str.type_i8_ptr |[4 x i8]| #u8(105 56 42 0))
(llvm:define-constant .str.type_i32 |[4 x i8]| #u8(105 51 50 0))
(llvm:define-constant .str.type_i64 |[4 x i8]| #u8(105 54 52 0))
(llvm:define-constant .str.type_i64_ptr |[5 x i8]| #u8(105 54 52 42 0))

(llvm:define-function (codegen_resolve_type_string (cg |%CodeGen*|) (type_str |i8*|) (type_len |i64|)) |i8*|
  ;; Allocas for phi replacement and cross-label values
  (let* ((name_len_ptr (llvm:alloca |i64|))
         (is_pointer_flag_ptr (llvm:alloca |i1|))
         (base_type_ptr (llvm:alloca |i8*|))
         (resolved_type_ptr (llvm:alloca |i8*|))
         ;; Allocas for array parsing
         (num_start (llvm:alloca |i8*|))
         (num_end (llvm:alloca |i8*|))
         (num_value (llvm:alloca |i32|))
         (found_x (llvm:alloca |i32|))
         (num_result (llvm:alloca |i32|))
         (digit_pos (llvm:alloca |i8*|))
         (digit_count (llvm:alloca |i32|))
         ;; Entry: null/empty check
         (type_str_null (llvm:icmp 'eq type_str (llvm:const-null |i8*|)))
         (type_len_zero (llvm:icmp 'eq type_len (llvm:const-int |i64| 0)))
         (type_invalid (llvm:or type_str_null type_len_zero)))
    (llvm:br type_invalid 'error 'check_context))

  (llvm:label 'check_context
    (let* ((context_ptr (llvm:gep |%CodeGen| cg 0 5))
           (context (llvm:load context_ptr |i8*|))
           (context_null (llvm:icmp 'eq context (llvm:const-null |i8*|))))
      (llvm:br context_null 'error 'check_pointer_suffix)))

  (llvm:label 'check_pointer_suffix
    (let* ((last_idx (llvm:sub type_len (llvm:const-int |i64| 1)))
           (last_ptr (llvm:gep |i8| type_str last_idx))
           (last_ch (llvm:load last_ptr |i8|))
           (is_ptr_suffix (llvm:icmp 'eq last_ch (llvm:const-int |i8| 42))))
      (llvm:br is_ptr_suffix 'resolve_pointer_base 'check_void)))

  (llvm:label 'resolve_pointer_base
    (let* ((base_len (llvm:sub type_len (llvm:const-int |i64| 1)))
           (base_type (llvm:call codegen_resolve_type_string cg type_str base_len))
           (base_null (llvm:icmp 'eq base_type (llvm:const-null |i8*|))))
      (llvm:store base_type base_type_ptr)
      (llvm:br base_null 'error 'wrap_pointer)))

  (llvm:label 'wrap_pointer
    (let* ((base_type (llvm:load base_type_ptr |i8*|))
           (ptr_type (llvm:call llvm_get_pointer_type base_type (llvm:const-int |i32| 0))))
      (llvm:ret ptr_type)))

  (llvm:label 'check_void
    (let* ((is_void_len (llvm:icmp 'eq type_len (llvm:const-int |i64| 4))))
      (llvm:br is_void_len 'check_void_str 'check_i1)))

  (llvm:label 'check_void_str
    (let* ((void_str (llvm:gep |[5 x i8]| (llvm:get-global .str.type_void) 0 0))
           (void_cmp (llvm:call strncmp type_str void_str (llvm:const-int |i32| 4)))
           (is_void (llvm:icmp 'eq void_cmp (llvm:const-int |i32| 0))))
      (llvm:br is_void 'return_void 'check_i1)))

  (llvm:label 'return_void
    (let* ((context_ptr (llvm:gep |%CodeGen| cg 0 5))
           (context (llvm:load context_ptr |i8*|))
           (void_type (llvm:call llvm_get_void_type context)))
      (llvm:ret void_type)))

  (llvm:label 'check_i1
    (let* ((is_i1_len (llvm:icmp 'eq type_len (llvm:const-int |i64| 2))))
      (llvm:br is_i1_len 'check_i1_str 'check_i8)))

  (llvm:label 'check_i1_str
    (let* ((i1_str (llvm:gep |[3 x i8]| (llvm:get-global .str.type_i1) 0 0))
           (i1_cmp (llvm:call strncmp type_str i1_str (llvm:const-int |i32| 2)))
           (is_i1 (llvm:icmp 'eq i1_cmp (llvm:const-int |i32| 0))))
      (llvm:br is_i1 'return_i1 'check_i8)))

  (llvm:label 'return_i1
    (let* ((context_ptr (llvm:gep |%CodeGen| cg 0 5))
           (context (llvm:load context_ptr |i8*|))
           (i1_type (llvm:call llvm_get_int1_type context)))
      (llvm:ret i1_type)))

  (llvm:label 'check_i8
    (let* ((is_i8_len (llvm:icmp 'eq type_len (llvm:const-int |i64| 2))))
      (llvm:br is_i8_len 'check_i8_str 'check_i8_ptr)))

  (llvm:label 'check_i8_str
    (let* ((i8_str (llvm:gep |[3 x i8]| (llvm:get-global .str.type_i8) 0 0))
           (i8_cmp (llvm:call strncmp type_str i8_str (llvm:const-int |i32| 2)))
           (is_i8 (llvm:icmp 'eq i8_cmp (llvm:const-int |i32| 0))))
      (llvm:br is_i8 'return_i8 'check_i8_ptr)))

  (llvm:label 'check_i8_ptr
    (let* ((is_i8_ptr_len (llvm:icmp 'eq type_len (llvm:const-int |i64| 3))))
      (llvm:br is_i8_ptr_len 'check_i8_ptr_str 'check_i32)))

  (llvm:label 'check_i8_ptr_str
    (let* ((i8_ptr_str (llvm:gep |[4 x i8]| (llvm:get-global .str.type_i8_ptr) 0 0))
           (i8_ptr_cmp (llvm:call strncmp type_str i8_ptr_str (llvm:const-int |i32| 3)))
           (is_i8_ptr (llvm:icmp 'eq i8_ptr_cmp (llvm:const-int |i32| 0))))
      (llvm:br is_i8_ptr 'return_i8_ptr 'check_i32)))

  (llvm:label 'return_i8
    (let* ((context_ptr (llvm:gep |%CodeGen| cg 0 5))
           (context (llvm:load context_ptr |i8*|))
           (i8_type (llvm:call llvm_get_int8_type context)))
      (llvm:ret i8_type)))

  (llvm:label 'return_i8_ptr
    (let* ((context_ptr (llvm:gep |%CodeGen| cg 0 5))
           (context (llvm:load context_ptr |i8*|))
           (i8_type_base (llvm:call llvm_get_int8_type context))
           (i8_ptr_type (llvm:call llvm_get_pointer_type i8_type_base (llvm:const-int |i32| 0))))
      (llvm:ret i8_ptr_type)))

  (llvm:label 'check_i32
    (let* ((is_i32_len (llvm:icmp 'eq type_len (llvm:const-int |i64| 3))))
      (llvm:br is_i32_len 'check_i32_str 'check_i64)))

  (llvm:label 'check_i32_str
    (let* ((i32_str (llvm:gep |[4 x i8]| (llvm:get-global .str.type_i32) 0 0))
           (i32_cmp (llvm:call strncmp type_str i32_str (llvm:const-int |i32| 3)))
           (is_i32 (llvm:icmp 'eq i32_cmp (llvm:const-int |i32| 0))))
      (llvm:br is_i32 'return_i32 'check_i64)))

  (llvm:label 'return_i32
    (let* ((context_ptr (llvm:gep |%CodeGen| cg 0 5))
           (context (llvm:load context_ptr |i8*|))
           (i32_type (llvm:call llvm_get_int32_type context)))
      (llvm:ret i32_type)))

  (llvm:label 'check_i64
    (let* ((is_i64_ptr_len (llvm:icmp 'eq type_len (llvm:const-int |i64| 4))))
      (llvm:br is_i64_ptr_len 'check_i64_ptr_str 'check_i64_len)))

  (llvm:label 'check_i64_ptr_str
    (let* ((i64_ptr_str (llvm:gep |[5 x i8]| (llvm:get-global .str.type_i64_ptr) 0 0))
           (i64_ptr_cmp (llvm:call strncmp type_str i64_ptr_str (llvm:const-int |i32| 4)))
           (is_i64_ptr (llvm:icmp 'eq i64_ptr_cmp (llvm:const-int |i32| 0))))
      (llvm:br is_i64_ptr 'return_i64_ptr 'check_array)))

  (llvm:label 'return_i64_ptr
    (let* ((context_ptr (llvm:gep |%CodeGen| cg 0 5))
           (context (llvm:load context_ptr |i8*|))
           (i64_type_base (llvm:call llvm_get_int64_type context))
           (i64_ptr_type (llvm:call llvm_get_pointer_type i64_type_base (llvm:const-int |i32| 0))))
      (llvm:ret i64_ptr_type)))

  (llvm:label 'check_i64_len
    (let* ((is_i64_len (llvm:icmp 'eq type_len (llvm:const-int |i64| 3))))
      (llvm:br is_i64_len 'check_i64_str 'check_array)))

  (llvm:label 'check_i64_str
    (let* ((i64_str (llvm:gep |[4 x i8]| (llvm:get-global .str.type_i64) 0 0))
           (i64_cmp (llvm:call strncmp type_str i64_str (llvm:const-int |i32| 3)))
           (is_i64 (llvm:icmp 'eq i64_cmp (llvm:const-int |i32| 0))))
      (llvm:br is_i64 'return_i64 'check_array)))

  (llvm:label 'return_i64
    (let* ((context_ptr (llvm:gep |%CodeGen| cg 0 5))
           (context (llvm:load context_ptr |i8*|))
           (i64_type (llvm:call llvm_get_int64_type context)))
      (llvm:ret i64_type)))

  (llvm:label 'check_array
    (let* ((first_char (llvm:load type_str |i8|))
           (is_bracket (llvm:icmp 'eq first_char (llvm:const-int |i8| 91))))
      (llvm:br is_bracket 'parse_array 'check_named_type)))

  (llvm:label 'check_named_type
    (let* ((last_char_idx (llvm:sub type_len (llvm:const-int |i64| 1)))
           (last_char_ptr (llvm:gep |i8| type_str last_char_idx))
           (last_char (llvm:load last_char_ptr |i8|))
           (is_pointer (llvm:icmp 'eq last_char (llvm:const-int |i8| 42))))
      (llvm:br is_pointer 'lookup_named_type_ptr 'lookup_named_type_direct)))

  (llvm:label 'lookup_named_type_ptr
    (let* ((name_len_val (llvm:sub type_len (llvm:const-int |i64| 1)))
           (last_char_idx (llvm:sub type_len (llvm:const-int |i64| 1)))
           (last_char_ptr (llvm:gep |i8| type_str last_char_idx))
           (last_char (llvm:load last_char_ptr |i8|))
           (is_pointer (llvm:icmp 'eq last_char (llvm:const-int |i8| 42))))
      (llvm:store name_len_val name_len_ptr)
      (llvm:store is_pointer is_pointer_flag_ptr)
      (llvm:br 'lookup_named_type_common)))

  (llvm:label 'lookup_named_type_direct
    (let* ((name_len_val (llvm:add type_len (llvm:const-int |i64| 0)))
           (last_char_idx (llvm:sub type_len (llvm:const-int |i64| 1)))
           (last_char_ptr (llvm:gep |i8| type_str last_char_idx))
           (last_char (llvm:load last_char_ptr |i8|))
           (is_pointer (llvm:icmp 'eq last_char (llvm:const-int |i8| 42))))
      (llvm:store name_len_val name_len_ptr)
      (llvm:store is_pointer is_pointer_flag_ptr)
      (llvm:br 'lookup_named_type_common)))

  (llvm:label 'lookup_named_type_common
    (let* ((name_len_val (llvm:load name_len_ptr |i64|))
           (name_buf_size (llvm:add name_len_val (llvm:const-int |i64| 1)))
           (name_buf (llvm:call malloc name_buf_size))
           (ignored (llvm:call memcpy name_buf type_str name_len_val))
           (name_null_ptr (llvm:gep |i8| name_buf name_len_val)))
      (llvm:store (llvm:const-int |i8| 0) name_null_ptr)
      (let* ((resolved_type (llvm:call codegen_get_type cg name_buf name_len_val)))
        (llvm:call free name_buf)
        (llvm:store resolved_type resolved_type_ptr)
        (let* ((resolved_null (llvm:icmp 'eq resolved_type (llvm:const-null |i8*|))))
          (llvm:br resolved_null 'error 'check_if_pointer)))))

  (llvm:label 'check_if_pointer
    (let* ((is_pointer_flag (llvm:load is_pointer_flag_ptr |i1|)))
      (llvm:br is_pointer_flag 'create_pointer_type 'return_named_type)))

  (llvm:label 'create_pointer_type
    (let* ((resolved_type (llvm:load resolved_type_ptr |i8*|))
           (pointer_type (llvm:call llvm_get_pointer_type resolved_type (llvm:const-int |i32| 0)))
           (pointer_null (llvm:icmp 'eq pointer_type (llvm:const-null |i8*|))))
      (llvm:br pointer_null 'error 'return_pointer_type)))

  (llvm:label 'return_pointer_type
    (let* ((resolved_type (llvm:load resolved_type_ptr |i8*|))
           (pointer_type (llvm:call llvm_get_pointer_type resolved_type (llvm:const-int |i32| 0))))
      (llvm:ret pointer_type)))

  (llvm:label 'return_named_type
    (let* ((resolved_type (llvm:load resolved_type_ptr |i8*|)))
      (llvm:ret resolved_type)))

  ;; Array parsing: "[N x i8]"
  (llvm:label 'parse_array
    (let* ((array_start_plus1 (llvm:gep |i8| type_str (llvm:const-int |i64| 1)))
           (array_len_minus1 (llvm:sub type_len (llvm:const-int |i64| 1))))
      (llvm:store array_start_plus1 num_start)
      (llvm:store array_start_plus1 num_end)
      (llvm:store (llvm:const-int |i32| 0) num_value)
      (llvm:store (llvm:const-int |i32| 0) found_x)
      (llvm:br 'find_x_pattern)))

  (llvm:label 'find_x_pattern
    (let* ((current_pos_val (llvm:load num_end |i8*|))
           (array_start_plus1 (llvm:gep |i8| type_str (llvm:const-int |i64| 1)))
           (current_offset_int (llvm:ptrtoint current_pos_val |i64|))
           (start_offset_int (llvm:ptrtoint array_start_plus1 |i64|))
           (offset (llvm:sub current_offset_int start_offset_int))
           (array_len_minus1 (llvm:sub type_len (llvm:const-int |i64| 1)))
           (max_offset (llvm:sub array_len_minus1 (llvm:const-int |i64| 3)))
           (within_bounds (llvm:icmp 'ult offset max_offset)))
      (llvm:br within_bounds 'check_pattern 'parse_digits)))

  (llvm:label 'check_pattern
    (let* ((current_pos_val (llvm:load num_end |i8*|))
           (current_char (llvm:load current_pos_val |i8|))
           (current_char_int (llvm:zext current_char |i8| |i32|))
           (is_digit_check (llvm:icmp 'uge current_char_int (llvm:const-int |i32| 48)))
           (is_digit_max_check (llvm:icmp 'ule current_char_int (llvm:const-int |i32| 57)))
           (is_valid_digit_check (llvm:and is_digit_check is_digit_max_check)))
      (llvm:br is_valid_digit_check 'check_x_pattern 'increment_pos)))

  (llvm:label 'check_x_pattern
    (let* ((current_pos_val (llvm:load num_end |i8*|))
           (pos_plus1 (llvm:gep |i8| current_pos_val (llvm:const-int |i64| 1)))
           (pos_plus2 (llvm:gep |i8| current_pos_val (llvm:const-int |i64| 2)))
           (pos_plus3 (llvm:gep |i8| current_pos_val (llvm:const-int |i64| 3)))
           (char1 (llvm:load pos_plus1 |i8|))
           (char2 (llvm:load pos_plus2 |i8|))
           (char3 (llvm:load pos_plus3 |i8|))
           (is_space1 (llvm:icmp 'eq char1 (llvm:const-int |i8| 32)))
           (is_x (llvm:icmp 'eq char2 (llvm:const-int |i8| 120)))
           (is_space2 (llvm:icmp 'eq char3 (llvm:const-int |i8| 32)))
           (both_spaces (llvm:and is_space1 is_space2))
           (found_pattern (llvm:and both_spaces is_x)))
      (llvm:br found_pattern 'mark_found_x 'increment_pos)))

  (llvm:label 'mark_found_x
    (let* ((current_pos_val (llvm:load num_end |i8*|))
           (num_end_pos (llvm:gep |i8| current_pos_val (llvm:const-int |i64| 1))))
      (llvm:store num_end_pos num_end)
      (llvm:store (llvm:const-int |i32| 1) found_x)
      (llvm:br 'parse_digits)))

  (llvm:label 'increment_pos
    (let* ((current_pos_val (llvm:load num_end |i8*|))
           (next_pos (llvm:gep |i8| current_pos_val (llvm:const-int |i64| 1))))
      (llvm:store next_pos num_end)
      (llvm:br 'find_x_pattern)))

  (llvm:label 'parse_digits
    (let* ((num_start_val (llvm:load num_start |i8*|))
           (num_end_val (llvm:load num_end |i8*|))
           (num_start_int (llvm:ptrtoint num_start_val |i64|))
           (num_end_int (llvm:ptrtoint num_end_val |i64|))
           (num_len_calc (llvm:sub num_end_int num_start_int))
           (num_len_zero (llvm:icmp 'eq num_len_calc (llvm:const-int |i64| 0))))
      (llvm:br num_len_zero 'error 'convert_digits)))

  (llvm:label 'convert_digits
    (let* ((num_start_val (llvm:load num_start |i8*|)))
      (llvm:store (llvm:const-int |i32| 0) num_result)
      (llvm:store num_start_val digit_pos)
      (llvm:store (llvm:const-int |i32| 0) digit_count)
      (llvm:br 'digit_loop)))

  (llvm:label 'digit_loop
    (let* ((digit_pos_val (llvm:load digit_pos |i8*|))
           (digit_pos_end (llvm:load num_end |i8*|))
           (digit_pos_int (llvm:ptrtoint digit_pos_val |i64|))
           (digit_end_int (llvm:ptrtoint digit_pos_end |i64|))
           (digit_done (llvm:icmp 'uge digit_pos_int digit_end_int)))
      (llvm:br digit_done 'check_element_type 'read_digit)))

  (llvm:label 'read_digit
    (let* ((digit_pos_val (llvm:load digit_pos |i8*|))
           (digit_char (llvm:load digit_pos_val |i8|))
           (digit_int (llvm:zext digit_char |i8| |i32|))
           (is_digit (llvm:icmp 'uge digit_int (llvm:const-int |i32| 48)))
           (is_digit_max (llvm:icmp 'ule digit_int (llvm:const-int |i32| 57)))
           (is_valid_digit (llvm:and is_digit is_digit_max)))
      (llvm:br is_valid_digit 'accumulate_digit 'check_element_type)))

  (llvm:label 'accumulate_digit
    (let* ((digit_pos_val (llvm:load digit_pos |i8*|))
           (digit_char (llvm:load digit_pos_val |i8|))
           (digit_int (llvm:zext digit_char |i8| |i32|))
           (num_result_val (llvm:load num_result |i32|))
           (digit_value (llvm:sub digit_int (llvm:const-int |i32| 48)))
           (num_result_times10 (llvm:mul num_result_val (llvm:const-int |i32| 10)))
           (num_result_new (llvm:add num_result_times10 digit_value)))
      (llvm:store num_result_new num_result)
      (let* ((digit_pos_next (llvm:gep |i8| digit_pos_val (llvm:const-int |i64| 1))))
        (llvm:store digit_pos_next digit_pos)
        (llvm:br 'digit_loop))))

  (llvm:label 'check_element_type
    (let* ((num_end_val_check (llvm:load num_end |i8*|))
           (check_pos (llvm:gep |i8| num_end_val_check (llvm:const-int |i64| 3)))
           (check_char_i (llvm:load check_pos |i8|))
           (check_pos_plus1 (llvm:gep |i8| check_pos (llvm:const-int |i64| 1)))
           (check_char_8 (llvm:load check_pos_plus1 |i8|))
           (check_pos_plus2 (llvm:gep |i8| check_pos (llvm:const-int |i64| 2)))
           (check_char_bracket (llvm:load check_pos_plus2 |i8|))
           (is_i_check (llvm:icmp 'eq check_char_i (llvm:const-int |i8| 105)))
           (is_8_check (llvm:icmp 'eq check_char_8 (llvm:const-int |i8| 56)))
           (is_bracket_check (llvm:icmp 'eq check_char_bracket (llvm:const-int |i8| 93)))
           (is_i8_check (llvm:and is_i_check is_8_check))
           (is_i8_bracket (llvm:and is_i8_check is_bracket_check)))
      (llvm:br is_i8_bracket 'create_array_type 'error)))

  (llvm:label 'create_array_type
    (let* ((context_ptr (llvm:gep |%CodeGen| cg 0 5))
           (context (llvm:load context_ptr |i8*|))
           (num_result_final (llvm:load num_result |i32|))
           (i8_type_arr (llvm:call llvm_get_int8_type context))
           (array_type (llvm:call llvm_get_array_type i8_type_arr num_result_final)))
      (llvm:ret array_type)))

  (llvm:label 'error
    (llvm:ret (llvm:const-null |i8*|))))

;; ============================================================================
;; Tier 2: codegen_append_type_fields
;; Generate field list for type definition (appends " { type1, type2, ... }").
;; Parameters: cg (CodeGen*), fields (ASTNode*)
;; ============================================================================
(llvm:define-function (codegen_append_type_fields (cg |%CodeGen*|) (fields |%ASTNode*|)) |void|
  (let* ((lbrace (llvm:gep |[3 x i8]| (llvm:get-global .str.lbrace) 0 0))
         (rbrace (llvm:gep |[2 x i8]| (llvm:get-global .str.rbrace) 0 0))
         (comma_space (llvm:gep |[3 x i8]| (llvm:get-global .str.comma_space) 0 0))
         (is_null (llvm:icmp 'eq fields (llvm:const-null |%ASTNode*|)))
         (current_field_ptr (llvm:alloca |%ASTNode*|)))
    (llvm:call codegen_append cg lbrace (llvm:const-int |i64| 2))
    (llvm:br is_null 'done 'append_first)
    (llvm:label 'append_first
    (let* ((car_ptr (llvm:gep |%ASTNode| fields 0 4))
           (field_pair (llvm:load car_ptr |%ASTNode*|))
           (field_cdr_ptr (llvm:gep |%ASTNode| field_pair 0 5))
           (field_cdr (llvm:load field_cdr_ptr |%ASTNode*|))
           (field_type_node_ptr (llvm:gep |%ASTNode| field_cdr 0 4))
           (field_type_node (llvm:load field_type_node_ptr |%ASTNode*|))
           (field_type_val_ptr (llvm:gep |%ASTNode| field_type_node 0 2))
           (field_type (llvm:load field_type_val_ptr |i8*|))
           (field_type_len_ptr (llvm:gep |%ASTNode| field_type_node 0 3))
           (field_type_len (llvm:load field_type_len_ptr |i64|))
           (cdr_ptr (llvm:gep |%ASTNode| fields 0 5))
           (next (llvm:load cdr_ptr |%ASTNode*|))
           (has_more (llvm:icmp 'ne next (llvm:const-null |%ASTNode*|))))
      (llvm:store next current_field_ptr)
      (llvm:call codegen_append cg field_type field_type_len)
      (llvm:br has_more 'append_more 'done)))
    (llvm:label 'append_more
    (let* ((current_field (llvm:load current_field_ptr |%ASTNode*|))
           (next_car_ptr (llvm:gep |%ASTNode| current_field 0 4))
           (next_field_pair (llvm:load next_car_ptr |%ASTNode*|))
           (next_field_cdr_ptr (llvm:gep |%ASTNode| next_field_pair 0 5))
           (next_field_cdr (llvm:load next_field_cdr_ptr |%ASTNode*|))
           (next_field_type_node_ptr (llvm:gep |%ASTNode| next_field_cdr 0 4))
           (next_field_type_node (llvm:load next_field_type_node_ptr |%ASTNode*|))
           (next_field_type_val_ptr (llvm:gep |%ASTNode| next_field_type_node 0 2))
           (next_field_type (llvm:load next_field_type_val_ptr |i8*|))
           (next_field_type_len_ptr (llvm:gep |%ASTNode| next_field_type_node 0 3))
           (next_field_type_len (llvm:load next_field_type_len_ptr |i64|))
           (next_cdr_ptr (llvm:gep |%ASTNode| current_field 0 5))
           (next_field (llvm:load next_cdr_ptr |%ASTNode*|))
           (has_more_more (llvm:icmp 'ne next_field (llvm:const-null |%ASTNode*|))))
      (llvm:store next_field current_field_ptr)
      (llvm:call codegen_append cg comma_space (llvm:const-int |i64| 2))
      (llvm:call codegen_append cg next_field_type next_field_type_len)
      (llvm:br has_more_more 'append_more 'done)))
    (llvm:label 'done
      (llvm:call codegen_append cg rbrace (llvm:const-int |i64| 1))
      (llvm:ret-void))))

;; ============================================================================
;; Tier 2: codegen_collect_field_types
;; Collect field types from AST list into array via codegen_resolve_type_string.
;; Parameters: cg (CodeGen*), fields (ASTNode*), types_array (LLVMTypeRef*), max_fields (i32)
;; Returns: number of field types collected
;; ============================================================================
(llvm:define-function (codegen_collect_field_types (cg |%CodeGen*|) (fields |%ASTNode*|) (types_array |i8*|) (max_fields |i32|)) |i32|
  (let* ((count (llvm:alloca |i32|))
         (current_fields_ptr (llvm:alloca |%ASTNode*|))
         (fields_null (llvm:icmp 'eq fields (llvm:const-null |%ASTNode*|))))
    (llvm:store (llvm:const-int |i32| 0) count)
    (llvm:label 'entry
      (llvm:store fields current_fields_ptr)
      (llvm:br fields_null 'done 'collect_loop))
    (llvm:label 'collect_loop
    (let* ((current_fields (llvm:load current_fields_ptr |%ASTNode*|))
           (current_count (llvm:load count |i32|))
           (at_max (llvm:icmp 'uge current_count max_fields)))
      (llvm:br at_max 'done 'get_field_pair)))
    (llvm:label 'get_field_pair
    (let* ((current_fields (llvm:load current_fields_ptr |%ASTNode*|))
           (car_ptr (llvm:gep |%ASTNode| current_fields 0 4))
           (field_pair (llvm:load car_ptr |%ASTNode*|))
           (field_pair_null (llvm:icmp 'eq field_pair (llvm:const-null |%ASTNode*|))))
      (llvm:br field_pair_null 'done 'get_field_type)))
    (llvm:label 'get_field_type
    (let* ((current_fields (llvm:load current_fields_ptr |%ASTNode*|))
           (car_ptr (llvm:gep |%ASTNode| current_fields 0 4))
           (field_pair (llvm:load car_ptr |%ASTNode*|))
           (field_cdr_ptr (llvm:gep |%ASTNode| field_pair 0 5))
           (field_cdr (llvm:load field_cdr_ptr |%ASTNode*|))
           (field_cdr_null (llvm:icmp 'eq field_cdr (llvm:const-null |%ASTNode*|))))
      (llvm:br field_cdr_null 'done 'get_type_node)))
    (llvm:label 'get_type_node
    (let* ((current_fields (llvm:load current_fields_ptr |%ASTNode*|))
           (car_ptr (llvm:gep |%ASTNode| current_fields 0 4))
           (field_pair (llvm:load car_ptr |%ASTNode*|))
           (field_cdr_ptr (llvm:gep |%ASTNode| field_pair 0 5))
           (field_cdr (llvm:load field_cdr_ptr |%ASTNode*|))
           (type_node_ptr (llvm:gep |%ASTNode| field_cdr 0 4))
           (type_node (llvm:load type_node_ptr |%ASTNode*|))
           (type_node_null (llvm:icmp 'eq type_node (llvm:const-null |%ASTNode*|))))
      (llvm:br type_node_null 'done 'resolve_type)))
    (llvm:label 'resolve_type
    (let* ((current_fields (llvm:load current_fields_ptr |%ASTNode*|))
           (car_ptr (llvm:gep |%ASTNode| current_fields 0 4))
           (field_pair (llvm:load car_ptr |%ASTNode*|))
           (field_cdr_ptr (llvm:gep |%ASTNode| field_pair 0 5))
           (field_cdr (llvm:load field_cdr_ptr |%ASTNode*|))
           (type_node_ptr (llvm:gep |%ASTNode| field_cdr 0 4))
           (type_node (llvm:load type_node_ptr |%ASTNode*|))
           (type_val_ptr (llvm:gep |%ASTNode| type_node 0 2))
           (type_str (llvm:load type_val_ptr |i8*|))
           (type_len_ptr (llvm:gep |%ASTNode| type_node 0 3))
           (type_len (llvm:load type_len_ptr |i64|))
           (field_type (llvm:call codegen_resolve_type_string cg type_str type_len))
           (field_type_null (llvm:icmp 'eq field_type (llvm:const-null |i8*|))))
      (llvm:br field_type_null 'done 'store_type)))
    (llvm:label 'store_type
    (let* ((current_fields (llvm:load current_fields_ptr |%ASTNode*|))
           (car_ptr (llvm:gep |%ASTNode| current_fields 0 4))
           (field_pair (llvm:load car_ptr |%ASTNode*|))
           (field_cdr_ptr (llvm:gep |%ASTNode| field_pair 0 5))
           (field_cdr (llvm:load field_cdr_ptr |%ASTNode*|))
           (type_node_ptr (llvm:gep |%ASTNode| field_cdr 0 4))
           (type_node (llvm:load type_node_ptr |%ASTNode*|))
           (type_val_ptr (llvm:gep |%ASTNode| type_node 0 2))
           (type_str (llvm:load type_val_ptr |i8*|))
           (type_len_ptr (llvm:gep |%ASTNode| type_node 0 3))
           (type_len (llvm:load type_len_ptr |i64|))
           (field_type (llvm:call codegen_resolve_type_string cg type_str type_len))
           (count_val (llvm:load count |i32|))
           (array_idx (llvm:gep |i8*| types_array count_val))
           (new_count (llvm:add count_val (llvm:const-int |i32| 1))))
      (llvm:store field_type array_idx)
      (llvm:store new_count count)
      (llvm:br 'continue_collect)))
    (llvm:label 'continue_collect
    (let* ((current_fields (llvm:load current_fields_ptr |%ASTNode*|))
           (cdr_ptr (llvm:gep |%ASTNode| current_fields 0 5))
           (next_fields (llvm:load cdr_ptr |%ASTNode*|))
           (has_more (llvm:icmp 'ne next_fields (llvm:const-null |%ASTNode*|))))
      (llvm:store next_fields current_fields_ptr)
      (llvm:br has_more 'collect_loop 'done)))
    (llvm:label 'done
      (llvm:ret (llvm:load count |i32|)))))

;; ============================================================================
;; Tier 2: codegen_define_llvm_type
;; Define LLVM struct type from AST. Uses let* with labels inside for cross-block
;; access to field_count_ptr, name_buf_ptr, named_struct_type_ptr, types_array_ptr.
;; Uses malloc for types array (512 bytes = 64*8) to avoid bootstrap alloca issues.
;; ============================================================================
(llvm:declare-function (llvm_create_named_struct_type (context |i8*|) (name |i8*|)) |i8*|)
(llvm:declare-function (llvm_set_struct_body (struct_type |i8*|) (field_types |i8*|) (field_count |i32|) (packed |i32|)) |void|)
(llvm:define-function (codegen_define_llvm_type (cg |%CodeGen*|) (node |%ASTNode*|)) |i32|
  (let* ((field_count_ptr (llvm:alloca |i32|))
         (name_buf_ptr (llvm:alloca |i8*|))
         (named_struct_type_ptr (llvm:alloca |i8*|))
         (types_array_ptr (llvm:alloca |i8*|)))
    (llvm:label 'entry
      (let* ((cdr_ptr (llvm:gep |%ASTNode| node 0 5))
             (cdr (llvm:load cdr_ptr |%ASTNode*|))
             (type_name_node_ptr (llvm:gep |%ASTNode| cdr 0 4))
             (type_name_node (llvm:load type_name_node_ptr |%ASTNode*|))
             (type_name_val_ptr (llvm:gep |%ASTNode| type_name_node 0 2))
             (type_name (llvm:load type_name_val_ptr |i8*|))
             (type_name_len_ptr (llvm:gep |%ASTNode| type_name_node 0 3))
             (type_name_len (llvm:load type_name_len_ptr |i64|))
             (cdr_cdr_ptr (llvm:gep |%ASTNode| cdr 0 5))
             (fields_list (llvm:load cdr_cdr_ptr |%ASTNode*|))
             (context_ptr (llvm:gep |%CodeGen| cg 0 5))
             (context (llvm:load context_ptr |i8*|))
             (context_null (llvm:icmp 'eq context (llvm:const-null |i8*|))))
        (llvm:br context_null 'error 'collect_fields)))
    (llvm:label 'collect_fields
      (let* ((cdr_ptr (llvm:gep |%ASTNode| node 0 5))
             (cdr (llvm:load cdr_ptr |%ASTNode*|))
             (cdr_cdr_ptr (llvm:gep |%ASTNode| cdr 0 5))
             (fields_list (llvm:load cdr_cdr_ptr |%ASTNode*|))
             (types_array (llvm:call malloc (llvm:const-int |i64| 512)))
             (field_count (llvm:call codegen_collect_field_types cg fields_list types_array (llvm:const-int |i32| 64)))
             (field_count_zero (llvm:icmp 'eq field_count (llvm:const-int |i32| 0))))
        (llvm:store types_array types_array_ptr)
        (llvm:store field_count field_count_ptr)
        (llvm:br field_count_zero 'free_and_error 'create_struct)))
    (llvm:label 'free_and_error
      (let* ((types_array (llvm:load types_array_ptr |i8*|)))
        (llvm:call free types_array)
        (llvm:br 'error)))
    (llvm:label 'create_struct
      (let* ((cdr_ptr (llvm:gep |%ASTNode| node 0 5))
             (cdr (llvm:load cdr_ptr |%ASTNode*|))
             (type_name_node_ptr (llvm:gep |%ASTNode| cdr 0 4))
             (type_name_node (llvm:load type_name_node_ptr |%ASTNode*|))
             (type_name_val_ptr (llvm:gep |%ASTNode| type_name_node 0 2))
             (type_name (llvm:load type_name_val_ptr |i8*|))
             (type_name_len_ptr (llvm:gep |%ASTNode| type_name_node 0 3))
             (type_name_len (llvm:load type_name_len_ptr |i64|))
             (context_ptr (llvm:gep |%CodeGen| cg 0 5))
             (context (llvm:load context_ptr |i8*|))
             (name_buf_size (llvm:add type_name_len (llvm:const-int |i64| 1)))
             (name_buf (llvm:call malloc name_buf_size))
             (ignored (llvm:call memcpy name_buf type_name type_name_len))
             (null_ptr (llvm:gep |i8| name_buf type_name_len))
             (named_struct_type (llvm:call llvm_create_named_struct_type context name_buf))
             (named_struct_null (llvm:icmp 'eq named_struct_type (llvm:const-null |i8*|))))
        (llvm:store (llvm:const-int |i8| 0) null_ptr)
        (llvm:store name_buf name_buf_ptr)
        (llvm:store named_struct_type named_struct_type_ptr)
        (llvm:br named_struct_null 'free_name_buf_error 'set_struct_body)))
    (llvm:label 'free_name_buf_error
      (let* ((name_buf (llvm:load name_buf_ptr |i8*|)))
        (llvm:call free name_buf)
        (llvm:br 'error)))
    (llvm:label 'set_struct_body
      (let* ((cdr_ptr (llvm:gep |%ASTNode| node 0 5))
             (cdr (llvm:load cdr_ptr |%ASTNode*|))
             (type_name_node_ptr (llvm:gep |%ASTNode| cdr 0 4))
             (type_name_node (llvm:load type_name_node_ptr |%ASTNode*|))
             (type_name_val_ptr (llvm:gep |%ASTNode| type_name_node 0 2))
             (type_name (llvm:load type_name_val_ptr |i8*|))
             (type_name_len_ptr (llvm:gep |%ASTNode| type_name_node 0 3))
             (type_name_len (llvm:load type_name_len_ptr |i64|))
             (cdr_cdr_ptr (llvm:gep |%ASTNode| cdr 0 5))
             (fields_list (llvm:load cdr_cdr_ptr |%ASTNode*|))
             (named_struct_type (llvm:load named_struct_type_ptr |i8*|))
             (field_count (llvm:load field_count_ptr |i32|))
             (name_buf (llvm:load name_buf_ptr |i8*|))
             (types_array (llvm:load types_array_ptr |i8*|))
             (percent (llvm:gep |[2 x i8]| (llvm:get-global .str.percent) 0 0))
