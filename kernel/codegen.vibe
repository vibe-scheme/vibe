;; codegen_append_top_level_exprs: Generate code for top-level expressions (recursive)
;; Parameters: cg, exprs (AST list). Processes function calls, recurses on cdr.
(llvm:define-function (codegen_append_top_level_exprs (cg |%CodeGen*|) (exprs |%ASTNode*|)) |void|
