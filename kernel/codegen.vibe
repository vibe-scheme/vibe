;; ============================================================================
;; codegen_call: Handle function call code generation
;; Parameters: cg (CodeGen*), func_name (i8*), args (ASTNode*)
;; Returns: 0 on success, -1 on error
;; ============================================================================
(llvm:define-function (codegen_call (cg |%CodeGen*|) (func_name |i8*|) (args |%ASTNode*|)) |i32|
  (let* ((func_val_ptr (llvm:alloca |i8*|))
         (func_type_val_ptr (llvm:alloca |i8*|))
