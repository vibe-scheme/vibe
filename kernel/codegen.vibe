;; ============================================================================
;; codegen_init
;; Initialize code generator. Returns CodeGen* or null on error.
;; Parameters: module_name (i8*) - null to use "vibe"
;; ============================================================================
(llvm:define-function (codegen_init (module_name |i8*|)) |%CodeGen*|
  (let* ((cg (llvm:call malloc (llvm:const-int |i64| 112)))
         (cg_ptr (llvm:bitcast cg |%CodeGen*|))
         (ffi_result (llvm:call llvm_ffi_init))
         (llvm_context (llvm:call llvm_create_context))
         (context_null (llvm:icmp 'eq llvm_context (llvm:const-null |i8*|)))
         (module_name_ptr (llvm:alloca |i8*|)))
    (llvm:br context_null 'dispose_context 'check_module_name)
    (llvm:label 'check_module_name
    (let* ((module_name_null (llvm:icmp 'eq module_name (llvm:const-null |i8*|))))
      (llvm:br module_name_null 'use_default_name 'use_provided_name)))
    (llvm:label 'use_default_name
    (let* ((default_name_array (llvm:gep |[5 x i8]| (llvm:get-global .str.module_name) 0 0)))
      (llvm:store default_name_array module_name_ptr)
      (llvm:br 'create_module)))
    (llvm:label 'use_provided_name
    (llvm:store module_name module_name_ptr)
    (llvm:br 'create_module))
    (llvm:label 'create_module
    (let* ((module_name_to_use (llvm:load module_name_ptr |i8*|))
           (llvm_module (llvm:call llvm_create_module llvm_context module_name_to_use))
           (module_null (llvm:icmp 'eq llvm_module (llvm:const-null |i8*|))))
      (llvm:br module_null 'dispose_context 'set_target)))
    (llvm:label 'set_target
    (let* ((target_triple_array (llvm:gep |[19 x i8]| (llvm:get-global .str.target_triple_value) 0 0))
           (data_layout_array (llvm:gep |[34 x i8]| (llvm:get-global .str.data_layout_value) 0 0))
           (buffer_size (llvm:const-int |i64| 65536))
           (buffer (llvm:call malloc buffer_size))
           (buffer_ptr (llvm:gep |%CodeGen| cg_ptr 0 0))
           (size_ptr (llvm:gep |%CodeGen| cg_ptr 0 1))
           (pos_ptr (llvm:gep |%CodeGen| cg_ptr 0 2))
           (str_counter_ptr (llvm:gep |%CodeGen| cg_ptr 0 3))
           (label_counter_ptr (llvm:gep |%CodeGen| cg_ptr 0 4))
           (context_ptr (llvm:gep |%CodeGen| cg_ptr 0 5))
           (module_ptr (llvm:gep |%CodeGen| cg_ptr 0 6))
           (builder_ptr (llvm:gep |%CodeGen| cg_ptr 0 7))
           (current_function_ptr (llvm:gep |%CodeGen| cg_ptr 0 8))
           (param_names_ptr (llvm:gep |%CodeGen| cg_ptr 0 9))
           (local_values_ptr (llvm:gep |%CodeGen| cg_ptr 0 10))
           (function_types_ptr (llvm:gep |%CodeGen| cg_ptr 0 11))
           (constants_ptr (llvm:gep |%CodeGen| cg_ptr 0 12))
           (types_ptr (llvm:gep |%CodeGen| cg_ptr 0 13))
           (llvm_functions_ptr (llvm:gep |%CodeGen| cg_ptr 0 14)))
      (llvm:call llvm_set_target llvm_module target_triple_array)
      (llvm:call llvm_set_data_layout llvm_module data_layout_array)
      (llvm:store buffer buffer_ptr)
      (llvm:store buffer_size size_ptr)
      (llvm:store (llvm:const-int |i64| 0) pos_ptr)
      (llvm:store (llvm:const-int |i32| 0) str_counter_ptr)
      (llvm:store (llvm:const-int |i32| 0) label_counter_ptr)
      (llvm:store llvm_context context_ptr)
      (llvm:store llvm_module module_ptr)
      (llvm:store (llvm:const-null |i8*|) builder_ptr)
      (llvm:store (llvm:const-null |i8*|) current_function_ptr)
      (llvm:store (llvm:const-null |%ASTNode*|) param_names_ptr)
      (llvm:store (llvm:const-null |%ASTNode*|) local_values_ptr)
      (llvm:store (llvm:const-null |%ASTNode*|) function_types_ptr)
      (llvm:store (llvm:const-null |%ASTNode*|) constants_ptr)
      (llvm:store (llvm:const-null |%ASTNode*|) types_ptr)
      (llvm:store (llvm:const-null |%ASTNode*|) llvm_functions_ptr)
      (llvm:call codegen_append cg_ptr (llvm:gep |[39 x i8]| (llvm:get-global .str.target_triple) 0 0) (llvm:const-int |i64| 37))
      (llvm:ret cg_ptr)))
    (llvm:label 'dispose_context
    (llvm:call llvm_dispose_context llvm_context)
    (llvm:br 'error))
    (llvm:label 'error
      (llvm:call free cg)
      (llvm:ret (llvm:const-null |%CodeGen*|)))))

;; ============================================================================
;; codegen_dispose
;; Dispose code generator and clean up LLVM resources.
;; Parameters: cg (CodeGen*)
;; ============================================================================
(llvm:define-function (codegen_dispose (cg |%CodeGen*|)) |void|
  (let* ((cg_null (llvm:icmp 'eq cg (llvm:const-null |%CodeGen*|))))
    (llvm:br cg_null 'done 'dispose_resources))
  (llvm:label 'dispose_resources
    (let* ((builder_ptr (llvm:gep |%CodeGen| cg 0 7))
           (builder (llvm:load builder_ptr |i8*|))
           (builder_null (llvm:icmp 'eq builder (llvm:const-null |i8*|))))
      (llvm:br builder_null 'dispose_module_check 'dispose_builder)))
  (llvm:label 'dispose_builder
    (let* ((builder_ptr (llvm:gep |%CodeGen| cg 0 7))
           (builder (llvm:load builder_ptr |i8*|)))
      (llvm:call llvm_dispose_builder builder)
      (llvm:br 'dispose_module_check)))
  (llvm:label 'dispose_module_check
    (let* ((module_ptr (llvm:gep |%CodeGen| cg 0 6))
           (module (llvm:load module_ptr |i8*|))
           (module_null (llvm:icmp 'eq module (llvm:const-null |i8*|))))
      (llvm:br module_null 'dispose_context 'dispose_module)))
  (llvm:label 'dispose_module
    (let* ((module_ptr (llvm:gep |%CodeGen| cg 0 6))
           (module (llvm:load module_ptr |i8*|)))
      (llvm:call llvm_dispose_module module)
      (llvm:br 'dispose_context)))
  (llvm:label 'dispose_context
    (let* ((context_ptr (llvm:gep |%CodeGen| cg 0 5))
           (context (llvm:load context_ptr |i8*|))
           (context_null (llvm:icmp 'eq context (llvm:const-null |i8*|))))
      (llvm:br context_null 'free_buffer 'dispose_ctx)))
  (llvm:label 'dispose_ctx
    (let* ((context_ptr (llvm:gep |%CodeGen| cg 0 5))
           (context (llvm:load context_ptr |i8*|)))
      (llvm:call llvm_dispose_context context)
      (llvm:br 'free_buffer)))
  (llvm:label 'free_buffer
    (let* ((buffer_ptr (llvm:gep |%CodeGen| cg 0 0))
           (buffer (llvm:load buffer_ptr |i8*|))
           (buffer_null (llvm:icmp 'eq buffer (llvm:const-null |i8*|))))
      (llvm:br buffer_null 'free_cg 'free_buf)))
  (llvm:label 'free_buf
    (let* ((buffer_ptr (llvm:gep |%CodeGen| cg 0 0))
           (buffer (llvm:load buffer_ptr |i8*|)))
      (llvm:call free buffer)
      (llvm:br 'free_cg)))
  (llvm:label 'free_cg
    (let* ((cg_bytes (llvm:bitcast cg |i8*|)))
      (llvm:call free cg_bytes)
      (llvm:br 'done)))
  (llvm:label 'done
    (llvm:ret-void)))

