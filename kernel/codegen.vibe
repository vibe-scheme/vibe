        (let* ((entry_bb (llvm:load entry_bb_store |i8*|))
               (term (llvm:call llvm_get_basic_block_terminator entry_bb))
               (no_term (llvm:icmp 'eq term (llvm:const-null |i8*|))))
          (llvm:br no_term 'error 'cleanup_builder))))
    (llvm:label 'cleanup_builder
      (let* ((builder (llvm:load builder_store |i8*|)))
        (llvm:call llvm_dispose_builder builder)
        ;; Clear CodeGen fields
        (llvm:store (llvm:const-null |i8*|) (llvm:gep |%CodeGen| cg 0 8))
        (llvm:store (llvm:const-null |i8*|) (llvm:gep |%CodeGen| cg 0 7))
        (llvm:store (llvm:const-null |%ASTNode*|) (llvm:gep |%CodeGen| cg 0 9))
        (llvm:store (llvm:const-null |%ASTNode*|) (llvm:gep |%CodeGen| cg 0 10))
        ;; Free param types array
        (let* ((pta (llvm:load param_types_arr_ptr |i8*|)))
          (llvm:call free pta)
          (llvm:ret (llvm:const-int |i32| 0)))))
    (llvm:label 'error
      (llvm:ret (llvm:const-int |i32| -1)))))

;; ============================================================================
;; codegen_define_llvm_ffi_function
;; Process define-llvm-ffi-function form: load library, resolve symbol, create
;; LLVM function declaration with external linkage.
;; Syntax: (define-llvm-ffi-function (name (p1 t1) ...) ret-type (lib sym) [vararg])
;; ============================================================================
(llvm:define-function (codegen_define_llvm_ffi_function (cg |%CodeGen*|) (node |%ASTNode*|)) |i32|
  (let* ((is_vararg_ptr (llvm:alloca |i32|))
         (func_type_ptr (llvm:alloca |i8*|))
         (param_types_array_ptr (llvm:alloca |i8*|))
         (cdr_ptr (llvm:gep |%ASTNode| node 0 5))
         (cdr (llvm:load cdr_ptr |i8*|))
         (sig_list_node_ptr (llvm:gep |%ASTNode| cdr 0 4))
         (sig_list (llvm:load sig_list_node_ptr |i8*|))
         (sig_car_ptr (llvm:gep |%ASTNode| sig_list 0 4))
         (func_name_node (llvm:load sig_car_ptr |i8*|))
         (func_name_val_ptr (llvm:gep |%ASTNode| func_name_node 0 2))
         (func_name (llvm:load func_name_val_ptr |i8*|))
         (func_name_len_ptr (llvm:gep |%ASTNode| func_name_node 0 3))
         (func_name_len (llvm:load func_name_len_ptr |i64|))
         (sig_cdr_ptr (llvm:gep |%ASTNode| sig_list 0 5))
         (params_list (llvm:load sig_cdr_ptr |i8*|))
         (cdr_cdr_ptr (llvm:gep |%ASTNode| cdr 0 5))
         (cdr_cdr (llvm:load cdr_cdr_ptr |i8*|))
         (return_type_node_ptr (llvm:gep |%ASTNode| cdr_cdr 0 4))
         (return_type_node (llvm:load return_type_node_ptr |i8*|))
         (return_type_val_ptr (llvm:gep |%ASTNode| return_type_node 0 2))
         (return_type (llvm:load return_type_val_ptr |i8*|))
         (return_type_len_ptr (llvm:gep |%ASTNode| return_type_node 0 3))
         (return_type_len (llvm:load return_type_len_ptr |i64|))
         (cdr_cdr_cdr_ptr (llvm:gep |%ASTNode| cdr_cdr 0 5))
         (cdr_cdr_cdr (llvm:load cdr_cdr_cdr_ptr |i8*|))
         (lib_info_list_node_ptr (llvm:gep |%ASTNode| cdr_cdr_cdr 0 4))
         (lib_info_list (llvm:load lib_info_list_node_ptr |i8*|))
         (lib_info_car_ptr (llvm:gep |%ASTNode| lib_info_list 0 4))
         (lib_name_node (llvm:load lib_info_car_ptr |i8*|))
         (lib_name_val_ptr (llvm:gep |%ASTNode| lib_name_node 0 2))
         (lib_name (llvm:load lib_name_val_ptr |i8*|))
         (lib_name_len_ptr (llvm:gep |%ASTNode| lib_name_node 0 3))
         (lib_name_len (llvm:load lib_name_len_ptr |i64|))
         (lib_info_cdr_ptr (llvm:gep |%ASTNode| lib_info_list 0 5))
         (lib_info_cdr (llvm:load lib_info_cdr_ptr |i8*|))
         (symbol_info_car_ptr (llvm:gep |%ASTNode| lib_info_cdr 0 4))
         (symbol_name_node (llvm:load symbol_info_car_ptr |i8*|))
         (symbol_name_val_ptr (llvm:gep |%ASTNode| symbol_name_node 0 2))
         (symbol_name (llvm:load symbol_name_val_ptr |i8*|))
         (symbol_name_len_ptr (llvm:gep |%ASTNode| symbol_name_node 0 3))
         (symbol_name_len (llvm:load symbol_name_len_ptr |i64|))
         (vararg_cell_ptr (llvm:gep |%ASTNode| cdr_cdr_cdr 0 5))
         (vararg_cell (llvm:load vararg_cell_ptr |i8*|)))
    (llvm:store (llvm:const-int |i32| 0) is_vararg_ptr)
    (let* ((has_vararg_flag (llvm:icmp 'ne vararg_cell (llvm:const-null |i8*|))))
      (llvm:br has_vararg_flag 'check_vararg_flag 'load_library))
    (llvm:label 'check_vararg_flag)
    (let* ((vararg_flag_node_ptr (llvm:gep |%ASTNode| vararg_cell 0 4))
           (vararg_flag_node (llvm:load vararg_flag_node_ptr |i8*|))
           (vararg_flag_len_ptr (llvm:gep |%ASTNode| vararg_flag_node 0 3))
           (vararg_flag_len (llvm:load vararg_flag_len_ptr |i64|))
           (is_t (llvm:icmp 'eq vararg_flag_len (llvm:const-int |i64| 2))))
      (llvm:br is_t 'set_vararg 'load_library))
    (llvm:label 'set_vararg)
    (llvm:store (llvm:const-int |i32| 1) is_vararg_ptr)
    (llvm:br 'load_library)
    (llvm:label 'load_library)
    (let* ((lib_name_buf_size (llvm:add lib_name_len (llvm:const-int |i64| 1)))
           (lib_name_buf (llvm:call malloc lib_name_buf_size)))
      (llvm:call memcpy lib_name_buf lib_name lib_name_len)
      (let* ((lib_null_ptr (llvm:gep |i8| lib_name_buf lib_name_len)))
        (llvm:store (llvm:const-int |i8| 0) lib_null_ptr)
        (let* ((lib_handle (llvm:call ffi_load_library lib_name_buf)))
          (llvm:call free lib_name_buf)
