;; ============================================================================
;; Tier A: codegen_dsl_urem, codegen_dsl_udiv, codegen_dsl_ptrtoint
;; Same pattern as add/or/sub/and/mul
;; ============================================================================
(llvm:define-function (codegen_dsl_urem (cg |%CodeGen*|) (args |%ASTNode*|)) |i8*|
  (let* ((lhs_ptr (llvm:alloca |i8*|))
         (rhs_ptr (llvm:alloca |i8*|))
         (result_ptr (llvm:alloca |i8*|)))
    (llvm:label 'entry
      (let* ((builder_ptr (llvm:gep |%CodeGen| cg 0 7))
             (builder (llvm:load builder_ptr |i8*|))
             (builder_null (llvm:icmp 'eq builder (llvm:const-null |i8*|))))
        (llvm:br builder_null 'error 'get_lhs)))
    (llvm:label 'get_lhs
      (let* ((args_null (llvm:icmp 'eq args (llvm:const-null |%ASTNode*|))))
        (llvm:br args_null 'error 'eval_lhs)))
