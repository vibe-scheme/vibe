        (llvm:call codegen_dsl_bind_local cg name_str name_len value)
        (llvm:br 'next_binding)))
    (llvm:label 'next_binding
      (let* ((bindings_iter (llvm:load current_bindings |%ASTNode*|))
             (bindings_iter_cdr_ptr (llvm:gep |%ASTNode| bindings_iter 0 5))
             (bindings_iter_cdr (llvm:load bindings_iter_cdr_ptr |%ASTNode*|))
