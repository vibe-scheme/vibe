      (llvm:call codegen_append cg_ptr (llvm:gep |[39 x i8]| (llvm:get-global .str.target_triple) 0 0) (llvm:const-int |i64| 37))
      (llvm:ret cg_ptr)))
  (llvm:label 'dispose_context
    (llvm:call llvm_dispose_context llvm_context)
    (llvm:br 'error))
  (llvm:label 'error
    (llvm:call free cg)
    (llvm:ret (llvm:const-null |%CodeGen*|))))

;; ============================================================================
;; codegen_dispose
;; Dispose code generator and clean up LLVM resources.
;; Parameters: cg (CodeGen*)
;; ============================================================================
(llvm:define-function (codegen_dispose (cg |%CodeGen*|)) |void|
  (let* ((cg_null (llvm:icmp 'eq cg (llvm:const-null |%CodeGen*|))))
    (llvm:br cg_null 'done 'dispose_resources))
  (llvm:label 'dispose_resources
    (let* ((builder_ptr (llvm:gep |%CodeGen| cg 0 7))
           (builder (llvm:load builder_ptr |i8*|))
           (builder_null (llvm:icmp 'eq builder (llvm:const-null |i8*|))))
      (llvm:br builder_null 'dispose_module_check 'dispose_builder)))
  (llvm:label 'dispose_builder
    (let* ((builder_ptr (llvm:gep |%CodeGen| cg 0 7))
           (builder (llvm:load builder_ptr |i8*|)))
      (llvm:call llvm_dispose_builder builder)
      (llvm:br 'dispose_module_check)))
  (llvm:label 'dispose_module_check
    (let* ((module_ptr (llvm:gep |%CodeGen| cg 0 6))
           (module (llvm:load module_ptr |i8*|))
           (module_null (llvm:icmp 'eq module (llvm:const-null |i8*|))))
      (llvm:br module_null 'dispose_context 'dispose_module)))
  (llvm:label 'dispose_module
    (let* ((module_ptr (llvm:gep |%CodeGen| cg 0 6))
           (module (llvm:load module_ptr |i8*|)))
      (llvm:call llvm_dispose_module module)
      (llvm:br 'dispose_context)))
  (llvm:label 'dispose_context
    (let* ((context_ptr (llvm:gep |%CodeGen| cg 0 5))
           (context (llvm:load context_ptr |i8*|))
           (context_null (llvm:icmp 'eq context (llvm:const-null |i8*|))))
      (llvm:br context_null 'free_buffer 'dispose_ctx)))
  (llvm:label 'dispose_ctx
    (let* ((context_ptr (llvm:gep |%CodeGen| cg 0 5))
           (context (llvm:load context_ptr |i8*|)))
      (llvm:call llvm_dispose_context context)
      (llvm:br 'free_buffer)))
  (llvm:label 'free_buffer
    (let* ((buffer_ptr (llvm:gep |%CodeGen| cg 0 0))
           (buffer (llvm:load buffer_ptr |i8*|))
           (buffer_null (llvm:icmp 'eq buffer (llvm:const-null |i8*|))))
      (llvm:br buffer_null 'free_cg 'free_buf)))
  (llvm:label 'free_buf
    (let* ((buffer_ptr (llvm:gep |%CodeGen| cg 0 0))
           (buffer (llvm:load buffer_ptr |i8*|)))
      (llvm:call free buffer)
      (llvm:br 'free_cg)))
  (llvm:label 'free_cg
    (let* ((cg_bytes (llvm:bitcast cg |i8*|)))
      (llvm:call free cg_bytes)
      (llvm:br 'done)))
  (llvm:label 'done
    (llvm:ret-void)))
