}

define %vibe_value @write_int64(%vibe_value %buffer_val, %vibe_value %offset_val, %vibe_value %value_val) {
  %buffer = call i8* @get_buffer_value(%vibe_value %buffer_val)
  %offset = call i64 @get_integer(%vibe_value %offset_val)
