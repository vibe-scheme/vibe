}

; External function declarations
declare void @llvm.memcpy.p0i8.p0i8.i64(i8*, i8*, i64, i1)
declare void @llvm.memset.p0i8.i64(i8*, i8, i64, i1)
declare i8* @GC_malloc(i64)
declare %vibe_value @create_buffer_value(i8*)
declare %vibe_value @create_integer(i64)
declare %vibe_value @create_string(i8*, i64)
declare i8* @get_buffer_value(%vibe_value)
declare i8* @get_string_value(%vibe_value)
declare i64 @get_integer(%vibe_value)
declare i64 @string_length(%vibe_value)
"))

; High-level Scheme interface
(define (make-buffer size)
  "Create a new buffer of the given size"
  (buffer-create size))

(define (buffer-length buffer)
  "Get the length of a buffer"
  (buffer-get-length buffer))

(define (buffer-ref buffer index)
  "Get the byte at the given index in the buffer"
  (buffer-get-byte buffer index))

(define (buffer-set! buffer index value)
  "Set the byte at the given index in the buffer"
  (buffer-set-byte buffer index value))

(define (buffer-copy! src src-start dst dst-start length)
  "Copy bytes from one buffer to another"
  (buffer-copy src src-start dst dst-start length))

(define (buffer-fill! buffer value)
  "Fill a buffer with the given byte value"
  (buffer-fill buffer value))

(define (buffer->string buffer)
  "Convert a buffer to a string"
  (buffer-to-string buffer))

(define (string->buffer string)
  "Convert a string to a buffer"
  (string-to-buffer string))

(define (read-int8 buffer offset)
  "Read a signed 8-bit integer from the buffer"
  (read-int8-from-buffer buffer offset))

(define (read-uint8 buffer offset)
  "Read an unsigned 8-bit integer from the buffer"
  (read-uint8-from-buffer buffer offset))

(define (read-int16 buffer offset)
  "Read a signed 16-bit integer from the buffer"
  (read-int16-from-buffer buffer offset))

(define (read-uint16 buffer offset)
  "Read an unsigned 16-bit integer from the buffer"
  (read-uint16-from-buffer buffer offset))

(define (read-int32 buffer offset)
  "Read a signed 32-bit integer from the buffer"
  (read-int32-from-buffer buffer offset))

(define (read-uint32 buffer offset)
  "Read an unsigned 32-bit integer from the buffer"
  (read-uint32-from-buffer buffer offset))

(define (read-int64 buffer offset)
  "Read a signed 64-bit integer from the buffer"
  (read-int64-from-buffer buffer offset))

(define (read-uint64 buffer offset)
  "Read an unsigned 64-bit integer from the buffer"
  (read-uint64-from-buffer buffer offset))

(define (write-int8! buffer offset value)
  "Write a signed 8-bit integer to the buffer"
  (write-int8-to-buffer buffer offset value))

(define (write-uint8! buffer offset value)
  "Write an unsigned 8-bit integer to the buffer"
  (write-uint8-to-buffer buffer offset value))

(define (write-int16! buffer offset value)
  "Write a signed 16-bit integer to the buffer"
  (write-int16-to-buffer buffer offset value))

(define (write-uint16! buffer offset value)
  "Write an unsigned 16-bit integer to the buffer"
  (write-uint16-to-buffer buffer offset value))

(define (write-int32! buffer offset value)
  "Write a signed 32-bit integer to the buffer"
  (write-int32-to-buffer buffer offset value))

(define (write-uint32! buffer offset value)
  "Write an unsigned 32-bit integer to the buffer"
  (write-uint32-to-buffer buffer offset value))

(define (write-int64! buffer offset value)
  "Write a signed 64-bit integer to the buffer"
  (write-int64-to-buffer buffer offset value))

(define (write-uint64! buffer offset value)
  "Write an unsigned 64-bit integer to the buffer"
  (write-uint64-to-buffer buffer offset value))) 