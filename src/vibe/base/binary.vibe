  %data = load i8*, i8** %data_ptr
  %ptr = getelementptr i8, i8* %data, i64 %offset
  %ptr_i16 = bitcast i8* %ptr to i16*
  %value_i16 = trunc i64 %value to i16
  store i16 %value_i16, i16* %ptr_i16
