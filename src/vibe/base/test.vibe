;; Test Runner Library
(define-library-vibe (vibe test)
  "Test runner utilities for executing R7RS test suites"
  (export run-tests! test-begin test-end test-assert test-equal test-error
          test-group test-group-begin test-group-end
          current-test-group current-test-results
          test-passed! test-failed!
          set-test-parallelism! current-test-parallelism
          set-test-timeout! current-test-timeout
          set-test-retries! current-test-retries
          set-test-filter! current-test-filter)
  
  (import (vibe core types)
          (vibe core primitives)
          (vibe core special)
          (vibe base file)
          (vibe base event)
          (vibe base queue)
          (vibe base thread))

;; Test results record
(define-record-type test-result
  (make-test-result group name passed? error message duration retries)
  test-result?
  (group test-result-group)       ; Test group name
  (name test-result-name)         ; Test name
  (passed? test-result-passed?)   ; Whether the test passed
  (error test-result-error)       ; Error object if test failed
  (message test-result-message)   ; Additional message
  (duration test-result-duration) ; Test duration in milliseconds
  (retries test-result-retries))  ; Number of retries before success/failure

;; Test group state
(define current-group '())
(define test-results '())
(define test-queue (make-queue))
(define test-parallelism 4)    ; Default to 4 parallel tests
(define test-start-time 0)     ; Track overall test suite duration
(define test-timeout 5000)     ; Default timeout: 5 seconds
(define test-retries 3)        ; Default retries: 3 attempts
(define test-filter #f)        ; Test filter predicate
(define completed-tests 0)     ; Track completed tests for progress
(define total-tests 0)         ; Track total tests for progress

;; Mutex for thread-safe operations
(define test-mutex (make-mutex))

;; Configuration getters/setters
(define-vibe (current-test-parallelism) test-parallelism)
(define-vibe (set-test-parallelism! n) (set! test-parallelism n))
(define-vibe (current-test-timeout) test-timeout)
(define-vibe (set-test-timeout! n) (set! test-timeout n))
(define-vibe (current-test-retries) test-retries)
(define-vibe (set-test-retries! n) (set! test-retries n))
(define-vibe (current-test-filter) test-filter)
(define-vibe (set-test-filter! pred) (set! test-filter pred))

(define-vibe (current-test-group)
  "Get the current test group name"
  (if (null? current-group)
      "default"
      (car current-group)))

(define-vibe (current-test-results)
  "Get the current test results"
  test-results)

(define-vibe (test-group-begin name)
  "Begin a new test group"
  (set! current-group (cons name current-group)))

(define-vibe (test-group-end)
  "End the current test group"
  (unless (null? current-group)
    (set! current-group (cdr current-group))))

(define-vibe (test-group name thunk)
  "Run tests in a named group"
  (test-group-begin name)
  (thunk)
  (test-group-end))

(define-vibe (test-passed! name duration retries)
  "Record a passed test"
  (with-mutex test-mutex
    (set! completed-tests (+ completed-tests 1))
    (set! test-results
          (cons (make-test-result (current-test-group) name #t #f #f duration retries)
                test-results))
    (update-progress!)))

(define-vibe (test-failed! name error message duration retries)
  "Record a failed test"
  (with-mutex test-mutex
    (set! completed-tests (+ completed-tests 1))
    (set! test-results
          (cons (make-test-result (current-test-group) name #f error message duration retries)
                test-results))
    (update-progress!)))

(define-vibe (format-duration ms)
  "Format duration in milliseconds to a human-readable string"
  (cond
   ((< ms 1000) (string-append (number->string ms) "ms"))
   ((< ms 60000) (string-append (number->string (/ ms 1000)) "s"))
   (else (string-append (number->string (/ ms 60000)) "m"))))

(define-vibe (format-progress total completed)
  "Format progress bar"
  (let* ((width 50)
         (progress (min width (floor (* width (/ completed total)))))
         (remaining (- width progress))
         (percent (floor (* 100 (/ completed total)))))
    (string-append "["
                  (make-string progress #\#)
                  (make-string remaining #\space)
                  "] "
                  (number->string completed)
                  "/"
                  (number->string total)
                  " ("
                  (number->string percent)
                  "%)")))

(define-vibe (update-progress!)
  "Update progress display"
  (display "\x1B[s")  ; Save cursor position
  (display "\x1B[H")  ; Move to top
  (display "\x1B[K")  ; Clear line
  (display (format-progress total-tests completed-tests))
  (display "\x1B[u")) ; Restore cursor position

(define-vibe (test-begin name)
  "Begin a test suite"
  (set! current-group '())
  (set! test-results '())
  (set! completed-tests 0)
  (set! total-tests 0)
  (set! test-start-time (current-milliseconds))
  (display "\x1B[2J\x1B[H")) ; Clear screen and move to top

(define-vibe (run-test-with-timeout! thunk timeout)
  "Run a test with timeout"
  (let* ((result-queue (make-queue))
         (thread (make-thread
                 (lambda ()
                   (guard (err (else (enqueue! result-queue (cons 'error err))))
                     (let ((result (thunk)))
                       (enqueue! result-queue (cons 'success result))))))))
    (thread-start! thread)
    (let ((result (dequeue! result-queue timeout)))
      (if result
          (if (eq? (car result) 'success)
              (cdr result)
              (raise (cdr result)))
          (begin
            (thread-terminate! thread)
            (raise 'timeout))))))

(define-vibe (run-test-with-retry! thunk max-retries)
  "Run a test with retry on failure"
  (let loop ((retries 0))
    (guard (err
           (else
            (if (< retries max-retries)
                (loop (+ retries 1))
                (cons retries (raise err)))))
      (cons retries (thunk)))))

(define-vibe (should-run-test? group name)
  "Check if a test should be run based on filter"
  (or (not test-filter)
      (test-filter group name)))

(define-vibe (run-test! test-thunk)
  "Run a single test with timing"
  (let ((start-time (current-milliseconds)))
    (test-thunk)
    (- (current-milliseconds) start-time)))

(define-vibe (enqueue-test! group name test-thunk)
  "Enqueue a test if it matches the filter"
  (when (should-run-test? group name)
    (set! total-tests (+ total-tests 1))
    (enqueue! test-queue
             (lambda ()
               (let* ((result (run-test-with-retry!
                             (lambda ()
                               (run-test-with-timeout!
                                test-thunk
                                test-timeout))
                             test-retries))
                      (retries (car result))
                      (duration (cdr result)))
                 (values duration retries))))))

(define-vibe (test-assert name expr)
  "Assert that expr evaluates to true"
  (enqueue-test! (current-test-group) name
                (lambda ()
                  (guard (err
                         (else
                          (test-failed! name err "Assertion failed with error"
                                      (run-test! (lambda () #f)) 0)))
                    (let-values (((duration retries) (run-test! (lambda () expr))))
                      (if expr
                          (test-passed! name duration retries)
                          (test-failed! name #f "Assertion failed" duration retries)))))))

(define-vibe (test-equal name expected expr)
  "Assert that expr evaluates to expected value"
  (enqueue-test! (current-test-group) name
                (lambda ()
                  (guard (err
                         (else
                          (test-failed! name err "Equality test failed with error"
                                      (run-test! (lambda () #f)) 0)))
                    (let*-values (((duration retries) (run-test! (lambda () expr)))
                                ((actual) expr))
                      (if (equal? expected actual)
                          (test-passed! name duration retries)
                          (test-failed! name #f
                                      (string-append "Expected: " (write-to-string expected)
                                                   ", Got: " (write-to-string actual))
                                      duration retries)))))))

(define-vibe (test-error name expr)
  "Assert that expr signals an error"
  (enqueue-test! (current-test-group) name
                (lambda ()
                  (guard (err
                         (else
                          (let-values (((duration retries) (run-test! (lambda () #t))))
                            (test-passed! name duration retries)
                            #t)))
                    (let-values (((duration retries) (run-test! (lambda () expr))))
                      (test-failed! name #f "Expected error but none occurred"
                                  duration retries))))))

(define-vibe (process-test-queue!)
  "Process all tests in the queue using parallel workers"
  (let ((workers (make-vector test-parallelism #f)))
    ;; Start workers
    (do ((i 0 (+ i 1)))
        ((= i test-parallelism))
      (vector-set! workers i
                  (make-thread
                   (lambda ()
                     (let loop ()
                       (let ((test (dequeue! test-queue #f)))
                         (when test
                           (test)
                           (loop))))))))
    
    ;; Wait for all workers to finish
    (for-each thread-join! (vector->list workers))))

(define-vibe (run-tests! file)
  "Run tests from a file"
  (load file)
  (process-test-queue!)) 